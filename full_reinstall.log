SQL> CREATE OR REPLACE PACKAGE BODY PKG_ARCHIVE_PARTITION
  2  AS
  3    /*
  4      Package      : PKG_ARCHIVE_PARTITION
  5      Developer    : Tomasz Lesinski
  6      Date         : 2026-05-28
  7      Purpose      : Partition operations - exchange staging, load staging data,
  8                     build staging indexes, exchange, drop staging
  9  
 10      Prerequisite : PKG_SQL, PKG_TL_LOGGING
 11  
 12      Change History:
 13      ------------------------------------------------------------------------------
 14      Version    Date         Programmer         Description
 15      ------------------------------------------------------------------------------
 16      1.0        2026-05-28   Tomasz Lesinski    Initial version
 17      1.1        2026-05-28   Tomasz Lesinski    Add PARALLEL_DEGREE support
 18    */
 19    FUNCTION fn_normalize_execute(p_execute IN VARCHAR2) RETURN VARCHAR2 IS
 20    BEGIN
 21      RETURN CASE WHEN UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN 'Y' ELSE 'N' END;
 22    END;
 23  
 24    FUNCTION fn_qualified_table
 25    (
 26      p_owner          IN VARCHAR2,
 27      p_table          IN VARCHAR2,
 28      p_source_db_link IN VARCHAR2 DEFAULT NULL
 29    )
 30    RETURN VARCHAR2
 31    IS
 32      l_name VARCHAR2(400);
 33    BEGIN
 34      l_name := PKG_SQL.fn_assert_simple_name(p_owner) || '.' || PKG_SQL.fn_assert_simple_name(p_table);
 35  
 36      IF p_source_db_link IS NOT NULL AND UPPER(TRIM(p_source_db_link)) NOT IN ('LOCAL', 'NONE') THEN
 37        l_name := l_name || '@' || PKG_SQL.fn_assert_simple_name(p_source_db_link);
 38      END IF;
 39  
 40      RETURN l_name;
 41    END fn_qualified_table;
 42  
 43    FUNCTION fn_normalize_tablespace_name(p_tablespace_name IN VARCHAR2) RETURN VARCHAR2 IS
 44    BEGIN
 45      IF p_tablespace_name IS NULL OR TRIM(p_tablespace_name) IS NULL THEN
 46        raise_application_error(-20045, 'TABLESPACE_NAME is required for exchange staging objects');
 47      END IF;
 48  
 49      RETURN PKG_SQL.fn_assert_simple_name(p_tablespace_name);
 50    END fn_normalize_tablespace_name;
 51  
 52    FUNCTION fn_high_value_to_date(p_high_value IN VARCHAR2) RETURN DATE IS
 53      l_date DATE;
 54    BEGIN
 55      IF p_high_value IS NULL OR UPPER(TRIM(p_high_value)) = 'MAXVALUE' THEN
 56        RETURN NULL;
 57      END IF;
 58  
 59      EXECUTE IMMEDIATE 'SELECT ' || p_high_value || ' FROM dual' INTO l_date;
 60      RETURN l_date;
 61    EXCEPTION
 62      WHEN OTHERS THEN
 63        RETURN NULL;
 64    END fn_high_value_to_date;
 65  
 66    FUNCTION fn_first_partition_key_column
 67    (
 68      p_owner IN VARCHAR2,
 69      p_table IN VARCHAR2
 70    )
 71    RETURN VARCHAR2
 72    IS
 73      l_column_name VARCHAR2(128);
 74    BEGIN
 75      SELECT column_name
 76        INTO l_column_name
 77        FROM all_part_key_columns
 78       WHERE owner = UPPER(p_owner)
 79         AND name = UPPER(p_table)
 80         AND object_type = 'TABLE'
 81         AND column_position = 1;
 82  
 83      RETURN PKG_SQL.fn_assert_simple_name(l_column_name);
 84    END fn_first_partition_key_column;
 85  
 86    FUNCTION fn_first_subpartition_key_column
 87    (
 88      p_owner IN VARCHAR2,
 89      p_table IN VARCHAR2
 90    )
 91    RETURN VARCHAR2
 92    IS
 93      l_column_name VARCHAR2(128);
 94    BEGIN
 95      SELECT column_name
 96        INTO l_column_name
 97        FROM all_subpart_key_columns
 98       WHERE owner = UPPER(p_owner)
 99         AND name = UPPER(p_table)
100         AND object_type = 'TABLE'
101         AND column_position = 1;
102  
103      RETURN PKG_SQL.fn_assert_simple_name(l_column_name);
104    END fn_first_subpartition_key_column;
105  
106    PROCEDURE prc_build_staging_indexes
107    (
108      p_target_owner       IN VARCHAR2,
109      p_target_table       IN VARCHAR2,
110      p_staging_table_name IN VARCHAR2,
111      p_execute            IN VARCHAR2 DEFAULT 'Y',
112      p_log_id             IN NUMBER DEFAULT NULL,
113      p_parallel_degree    IN NUMBER DEFAULT 4,
114      p_tablespace_name    IN VARCHAR2
115    )
116    IS
117      l_sql          CLOB;
118      l_column_list  VARCHAR2(4000);
119      l_sql_rowcount NUMBER;
120      l_index_name   VARCHAR2(128);
121      l_tablespace   VARCHAR2(128);
122    BEGIN
123      l_tablespace := fn_normalize_tablespace_name(p_tablespace_name);
124  
125      FOR r IN (
126        SELECT i.index_name, i.uniqueness
127          FROM all_indexes i
128          JOIN all_part_indexes p
129            ON p.owner = i.owner
130           AND p.index_name = i.index_name
131         WHERE i.owner = UPPER(p_target_owner)
132           AND i.table_owner = UPPER(p_target_owner)
133           AND i.table_name = UPPER(p_target_table)
134           AND i.index_type = 'NORMAL'
135           AND p.locality = 'LOCAL'
136         ORDER BY i.index_name
137      ) LOOP
138        SELECT LISTAGG(
139                 PKG_SQL.fn_assert_simple_name(column_name) ||
140                 CASE WHEN descend = 'DESC' THEN ' DESC' END,
141                 ', '
142               ) WITHIN GROUP (ORDER BY column_position)
143          INTO l_column_list
144          FROM all_ind_columns
145         WHERE index_owner = UPPER(p_target_owner)
146           AND table_owner = UPPER(p_target_owner)
147           AND table_name = UPPER(p_target_table)
148           AND index_name = r.index_name;
149  
150        l_index_name := SUBSTR('STG_' || r.index_name || '_' || TO_CHAR(SYSTIMESTAMP, 'HH24MISSFF3'), 1, 128);
151  
152        l_sql := 'CREATE ' ||
153                 CASE WHEN r.uniqueness = 'UNIQUE' THEN 'UNIQUE ' END ||
154                 'INDEX ' ||
155                 PKG_SQL.fn_assert_simple_name(p_target_owner) || '.' ||
156                 PKG_SQL.fn_assert_simple_name(l_index_name) ||
157                 ' ON ' ||
158                 fn_qualified_table(p_target_owner, p_staging_table_name) ||
159                 '(' || l_column_list || ')' ||
160                 ' TABLESPACE ' || l_tablespace ||
161                 ' PARALLEL ' || p_parallel_degree;
162  
163        l_sql_rowcount := PKG_SQL.fn_run_sql(p_log_id, l_sql, p_execute);
164      END LOOP;
165    END prc_build_staging_indexes;
166  
167    PROCEDURE prc_create_exchange_staging
168    (
169      p_target_owner       IN VARCHAR2,
170      p_target_table       IN VARCHAR2,
171      p_partition_name     IN VARCHAR2,
172      p_staging_table_name OUT VARCHAR2,
173      p_execute            IN VARCHAR2 DEFAULT 'Y',
174      p_log_id             IN NUMBER DEFAULT NULL,
175      p_tablespace_name    IN VARCHAR2
176    )
177    IS
178      l_sql          CLOB;
179      l_sql_rowcount NUMBER;
180      l_tablespace   VARCHAR2(128);
181    BEGIN
182      l_tablespace := fn_normalize_tablespace_name(p_tablespace_name);
183  
184      p_staging_table_name := SUBSTR(
185        'STG_TMP_ARCH_' || TO_CHAR(STG_TMP_ARCH_SEQ.NEXTVAL),
186        1,
187        128
188      );
189  
190      l_sql := 'CREATE TABLE ' ||
191               fn_qualified_table(p_target_owner, p_staging_table_name) ||
192               ' TABLESPACE ' || l_tablespace ||
193               ' FOR EXCHANGE WITH TABLE ' ||
194               fn_qualified_table(p_target_owner, p_target_table);
195  
196      l_sql_rowcount := PKG_SQL.fn_run_sql(p_log_id, l_sql, p_execute);
197  
198    END prc_create_exchange_staging;
199  
200    PROCEDURE prc_load_exchange_staging
201    (
202      p_source_db_link     IN VARCHAR2,
203      p_source_owner       IN VARCHAR2,
204      p_source_table       IN VARCHAR2,
205      p_target_owner       IN VARCHAR2,
206      p_target_table       IN VARCHAR2,
207      p_staging_table_name IN VARCHAR2,
208      p_high_value         IN VARCHAR2,
209      p_prev_high_value    IN VARCHAR2 DEFAULT NULL,
210      p_execute            IN VARCHAR2 DEFAULT 'Y',
211      p_log_id             IN NUMBER DEFAULT NULL,
212      p_parallel_degree    IN NUMBER DEFAULT 4,
213      p_rows_loaded        OUT NUMBER
214    )
215    IS
216      l_sql          CLOB;
217      l_key_column   VARCHAR2(128);
218      l_high_date    DATE;
219      l_low_date     DATE;
220    BEGIN
221      l_key_column := fn_first_partition_key_column(p_target_owner, p_target_table);
222      l_high_date := fn_high_value_to_date(p_high_value);
223      l_low_date := fn_high_value_to_date(p_prev_high_value);
224  
225      IF l_high_date IS NULL THEN
226        raise_application_error(-20041, 'EXCHANGE requires a DATE high value for target partition');
227      END IF;
228  
229      l_sql := 'INSERT /*+ APPEND PARALLEL(' || p_parallel_degree || ') */ INTO ' ||
230               fn_qualified_table(p_target_owner, p_staging_table_name) ||
231               ' SELECT * FROM ' ||
232               fn_qualified_table(p_source_owner, p_source_table, p_source_db_link) ||
233               ' WHERE ' || l_key_column || ' < DATE ''' || TO_CHAR(l_high_date, 'YYYY-MM-DD') || '''';
234  
235      IF l_low_date IS NOT NULL THEN
236        l_sql := l_sql || ' AND ' || l_key_column || ' >= DATE ''' || TO_CHAR(l_low_date, 'YYYY-MM-DD') || '''';
237      END IF;
238  
239      p_rows_loaded := PKG_SQL.fn_run_sql(p_log_id, l_sql, p_execute);
240    END prc_load_exchange_staging;
241  
242    PROCEDURE prc_load_exchange_staging_subpartition
243    (
244      p_source_db_link            IN VARCHAR2,
245      p_source_owner              IN VARCHAR2,
246      p_source_table              IN VARCHAR2,
247      p_target_owner              IN VARCHAR2,
248      p_target_table              IN VARCHAR2,
249      p_staging_table_name        IN VARCHAR2,
250      p_partition_high_value      IN VARCHAR2,
251      p_prev_partition_high_value IN VARCHAR2 DEFAULT NULL,
252      p_subpartition_high_value   IN VARCHAR2,
253      p_execute                   IN VARCHAR2 DEFAULT 'Y',
254      p_log_id                    IN NUMBER DEFAULT NULL,
255      p_parallel_degree           IN NUMBER DEFAULT 4,
256      p_rows_loaded               OUT NUMBER
257    )
258    IS
259      l_sql             CLOB;
260      l_part_key_column VARCHAR2(128);
261      l_sub_key_column  VARCHAR2(128);
262      l_high_date       DATE;
263      l_low_date        DATE;
264    BEGIN
265      l_part_key_column := fn_first_partition_key_column(p_target_owner, p_target_table);
266      l_sub_key_column := fn_first_subpartition_key_column(p_target_owner, p_target_table);
267      l_high_date := fn_high_value_to_date(p_partition_high_value);
268      l_low_date := fn_high_value_to_date(p_prev_partition_high_value);
269  
270      IF l_high_date IS NULL THEN
271        raise_application_error(-20043, 'EXCHANGE SUBPARTITION requires a DATE partition high value');
272      END IF;
273  
274      IF p_subpartition_high_value IS NULL OR TRIM(p_subpartition_high_value) = '#' THEN
275        raise_application_error(-20044, 'EXCHANGE SUBPARTITION requires a list subpartition high value');
276      END IF;
277  
278      l_sql := 'INSERT /*+ APPEND PARALLEL(' || p_parallel_degree || ') */ INTO ' ||
279               fn_qualified_table(p_target_owner, p_staging_table_name) ||
280               ' SELECT * FROM ' ||
281               fn_qualified_table(p_source_owner, p_source_table, p_source_db_link) ||
282               ' WHERE ' || l_part_key_column || ' < DATE ''' || TO_CHAR(l_high_date, 'YYYY-MM-DD') || '''' ||
283               ' AND ' || l_sub_key_column || ' IN (' || p_subpartition_high_value || ')';
284  
285      IF l_low_date IS NOT NULL THEN
286        l_sql := l_sql || ' AND ' || l_part_key_column || ' >= DATE ''' || TO_CHAR(l_low_date, 'YYYY-MM-DD') || '''';
287      END IF;
288  
289      p_rows_loaded := PKG_SQL.fn_run_sql(p_log_id, l_sql, p_execute);
290    END prc_load_exchange_staging_subpartition;
291  
292    PROCEDURE prc_exchange_partition
293    (
294      p_target_owner       IN VARCHAR2,
295      p_target_table       IN VARCHAR2,
