SQL> CREATE OR REPLACE PACKAGE BODY PKG_ARCHIVE_RUNNER
  2  AS
  3    /*
  4      Package      : PKG_ARCHIVE_RUNNER
  5      Developer    : Tomasz Lesinski
  6      Date         : 2026-05-28
  7      Purpose      : Archive runner - orchestrates DISCOVER -> ARCHIVE -> QUALITY
  8                     -> TRUNCATE flow for one or all tables
  9  
 10      Prerequisite : PKG_ARCHIVE_DISCOVERY, PKG_ARCHIVE_IMPORT, PKG_ARCHIVE_QUALITY,
 11                     PKG_ARCHIVE_TRUNCATE, PKG_ARCHIVE_LOG
 12  
 13      Change History:
 14      ------------------------------------------------------------------------------
 15      Version    Date         Programmer         Description
 16      ------------------------------------------------------------------------------
 17      1.0        2026-05-28   Tomasz Lesinski    Initial version
 18    */
 19    FUNCTION fn_normalize_execute(p_execute IN VARCHAR2) RETURN VARCHAR2 IS
 20    BEGIN
 21      RETURN CASE WHEN UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN 'Y' ELSE 'N' END;
 22    END;
 23  
 24    FUNCTION fn_normalize_stop_step(p_stop_after_step IN VARCHAR2) RETURN VARCHAR2 IS
 25      l_step VARCHAR2(30);
 26    BEGIN
 27      l_step := UPPER(NVL(TRIM(p_stop_after_step), 'QUALITY'));
 28      IF l_step NOT IN ('DISCOVER', 'ARCHIVE', 'QUALITY', 'TRUNCATE') THEN
 29        raise_application_error(-20030, 'Unsupported stop step: ' || p_stop_after_step);
 30      END IF;
 31      RETURN l_step;
 32    END;
 33  
 34    FUNCTION fn_total_steps(p_stop_step IN VARCHAR2) RETURN PLS_INTEGER IS
 35    BEGIN
 36      CASE p_stop_step
 37        WHEN 'DISCOVER' THEN RETURN 1;
 38        WHEN 'ARCHIVE'  THEN RETURN 2;
 39        WHEN 'QUALITY'  THEN RETURN 3;
 40        WHEN 'TRUNCATE' THEN RETURN 4;
 41      END CASE;
 42    END;
 43  
 44    PROCEDURE prc_run_table
 45    (
 46      p_source_db_link   IN VARCHAR2,
 47      p_owner            IN VARCHAR2,
 48      p_table_name       IN VARCHAR2,
 49      p_execute          IN VARCHAR2 DEFAULT 'N',
 50      p_stop_after_step  IN VARCHAR2 DEFAULT 'QUALITY',
 51      p_truncate_execute IN VARCHAR2 DEFAULT 'N'
 52    )
 53    IS
 54      l_run_id           NUMBER;
 55      l_execute_flag     VARCHAR2(1);
 56      l_truncate_execute VARCHAR2(1);
 57      l_stop_step        VARCHAR2(30);
 58      l_total_steps      PLS_INTEGER;
 59      l_target_owner     VARCHAR2(128);
 60      l_target_table     VARCHAR2(128);
 61    BEGIN
 62      l_execute_flag := fn_normalize_execute(p_execute);
 63      l_truncate_execute := fn_normalize_execute(p_truncate_execute);
 64      l_stop_step := fn_normalize_stop_step(p_stop_after_step);
 65      l_total_steps := fn_total_steps(l_stop_step);
 66      l_run_id := PKG_ARCHIVE_LOG.fn_create_run('RUNNER', p_source_db_link, p_owner, p_table_name, p_execute);
 67  
 68      SELECT target_owner, target_table_name
 69        INTO l_target_owner, l_target_table
 70        FROM TW_ARCHIVE_TABLES
 71       WHERE enabled_flag = 'Y'
 72         AND source_db_link = UPPER(p_source_db_link)
 73         AND source_owner = UPPER(p_owner)
 74         AND source_table_name = UPPER(p_table_name);
 75  
 76      DBMS_OUTPUT.PUT_LINE('RUNNER ' || UPPER(p_source_db_link) || '.' || UPPER(p_owner) || '.' || UPPER(p_table_name) ||
 77                           ' execute=' || l_execute_flag || ' stop_after=' || l_stop_step ||
 78                           ' truncate_execute=' || l_truncate_execute);
 79      PKG_ARCHIVE_LOG.prc_log_message
 80      (
 81        p_run_id  => l_run_id,
 82        p_log_msg => 'Started RUNNER with parameters:' || CHR(10) ||
 83                     '  p_source_db_link    => ' || UPPER(p_source_db_link) || CHR(10) ||
 84                     '  p_owner             => ' || UPPER(p_owner) || CHR(10) ||
 85                     '  p_table_name        => ' || UPPER(p_table_name) || CHR(10) ||
 86                     '  p_execute           => ' || l_execute_flag || CHR(10) ||
 87                     '  p_stop_after_step   => ' || l_stop_step || CHR(10) ||
 88                     '  p_truncate_execute  => ' || l_truncate_execute || CHR(10) ||
 89                     '  total_steps         => ' || l_total_steps
 90      );
 91  
 92      PKG_ARCHIVE_LOG.prc_log_message
 93      (
 94        p_run_id  => l_run_id,
 95        p_log_msg => 'Step 1/' || l_total_steps || ': DISCOVER - discovering new source partitions'
 96      );
 97      PKG_ARCHIVE_DISCOVERY.prc_discover(l_execute_flag, l_target_owner, l_target_table);
 98      IF l_stop_step = 'DISCOVER' THEN
 99        PKG_ARCHIVE_LOG.prc_log_message(p_run_id => l_run_id, p_log_msg => 'Runner finished at stop step DISCOVER');
100        PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
101        RETURN;
102      END IF;
103  
104      PKG_ARCHIVE_LOG.prc_log_message
105      (
106        p_run_id  => l_run_id,
107        p_log_msg => 'Step 2/' || l_total_steps || ': ARCHIVE - importing source data via exchange staging'
108      );
109      PKG_ARCHIVE_IMPORT.prc_import(l_execute_flag, l_target_owner, l_target_table);
110      IF l_stop_step = 'ARCHIVE' THEN
111        PKG_ARCHIVE_LOG.prc_log_message(p_run_id => l_run_id, p_log_msg => 'Runner finished at stop step ARCHIVE');
112        PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
113        RETURN;
114      END IF;
115  
116      PKG_ARCHIVE_LOG.prc_log_message
117      (
118        p_run_id  => l_run_id,
119        p_log_msg => 'Step 3/' || l_total_steps || ': QUALITY - comparing source vs target row counts'
120      );
121      PKG_ARCHIVE_QUALITY.prc_quality(l_execute_flag, l_target_owner, l_target_table);
122      IF l_stop_step = 'QUALITY' THEN
123        PKG_ARCHIVE_LOG.prc_log_message(p_run_id => l_run_id, p_log_msg => 'Runner finished at stop step QUALITY (TRUNCATE skipped)');
124        PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
125        RETURN;
126      END IF;
127  
128      PKG_ARCHIVE_LOG.prc_log_message
129      (
130        p_run_id  => l_run_id,
131        p_log_msg => 'Step 4/' || l_total_steps || ': TRUNCATE - requesting source truncate through agent' ||
132                     CASE WHEN l_truncate_execute = 'Y' THEN '' ELSE ' (preview mode)' END
133      );
134      PKG_ARCHIVE_TRUNCATE.prc_truncate(l_truncate_execute, l_target_owner, l_target_table);
135      PKG_ARCHIVE_LOG.prc_log_message(p_run_id => l_run_id, p_log_msg => 'Runner finished all steps');
136      PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
137    EXCEPTION
138      WHEN OTHERS THEN
139        IF l_run_id IS NOT NULL THEN
140          PKG_ARCHIVE_LOG.prc_log_error_stack(l_run_id);
141          PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', SQLERRM);
142        END IF;
143        RAISE;
144    END;
145  
146    PROCEDURE prc_run_all
147    (
148      p_execute          IN VARCHAR2 DEFAULT 'N',
149      p_stop_after_step  IN VARCHAR2 DEFAULT 'QUALITY',
150      p_truncate_execute IN VARCHAR2 DEFAULT 'N'
151    )
152    IS
153      l_run_id           NUMBER;
154      l_execute_flag     VARCHAR2(1);
155      l_truncate_execute VARCHAR2(1);
156      l_stop_step        VARCHAR2(30);
157      l_total_steps      PLS_INTEGER;
158    BEGIN
159      l_execute_flag := fn_normalize_execute(p_execute);
160      l_truncate_execute := fn_normalize_execute(p_truncate_execute);
161      l_stop_step := fn_normalize_stop_step(p_stop_after_step);
162      l_total_steps := fn_total_steps(l_stop_step);
163      l_run_id := PKG_ARCHIVE_LOG.fn_create_run('RUNNER', NULL, NULL, NULL, l_execute_flag);
164  
165      DBMS_OUTPUT.PUT_LINE('RUNNER ALL execute=' || l_execute_flag || ' stop_after=' || l_stop_step ||
166                           ' truncate_execute=' || l_truncate_execute);
167      PKG_ARCHIVE_LOG.prc_log_message
168      (
169        p_run_id  => l_run_id,
170        p_log_msg => 'Started RUNNER ALL with parameters:' || CHR(10) ||
171                     '  p_execute          => ' || l_execute_flag || CHR(10) ||
172                     '  p_stop_after_step  => ' || l_stop_step || CHR(10) ||
173                     '  p_truncate_execute => ' || l_truncate_execute || CHR(10) ||
174                     '  total_steps        => ' || l_total_steps
175      );
176  
177      PKG_ARCHIVE_LOG.prc_log_message
178      (
179        p_run_id  => l_run_id,
180        p_log_msg => 'Step 1/' || l_total_steps || ': DISCOVER - discovering new source partitions'
181      );
182      PKG_ARCHIVE_DISCOVERY.prc_discover(l_execute_flag);
183      IF l_stop_step = 'DISCOVER' THEN
184        PKG_ARCHIVE_LOG.prc_log_message(p_run_id => l_run_id, p_log_msg => 'Runner finished at stop step DISCOVER');
185        PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
186        RETURN;
187      END IF;
188  
189      PKG_ARCHIVE_LOG.prc_log_message
190      (
191        p_run_id  => l_run_id,
192        p_log_msg => 'Step 2/' || l_total_steps || ': ARCHIVE - importing source data via exchange staging'
193      );
194      PKG_ARCHIVE_IMPORT.prc_import(l_execute_flag);
195      IF l_stop_step = 'ARCHIVE' THEN
196        PKG_ARCHIVE_LOG.prc_log_message(p_run_id => l_run_id, p_log_msg => 'Runner finished at stop step ARCHIVE');
197        PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
198        RETURN;
199      END IF;
200  
201      PKG_ARCHIVE_LOG.prc_log_message
202      (
203        p_run_id  => l_run_id,
204        p_log_msg => 'Step 3/' || l_total_steps || ': QUALITY - comparing source vs target row counts'
205      );
206      PKG_ARCHIVE_QUALITY.prc_quality(l_execute_flag);
207      IF l_stop_step = 'QUALITY' THEN
208        PKG_ARCHIVE_LOG.prc_log_message(p_run_id => l_run_id, p_log_msg => 'Runner finished at stop step QUALITY (TRUNCATE skipped)');
209        PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
210        RETURN;
211      END IF;
212  
213      PKG_ARCHIVE_LOG.prc_log_message
214      (
215        p_run_id  => l_run_id,
216        p_log_msg => 'Step 4/' || l_total_steps || ': TRUNCATE - requesting source truncate through agent' ||
217                     CASE WHEN l_truncate_execute = 'Y' THEN '' ELSE ' (preview mode)' END
218      );
219      PKG_ARCHIVE_TRUNCATE.prc_truncate(l_truncate_execute);
220  
221      PKG_ARCHIVE_LOG.prc_log_message(p_run_id => l_run_id, p_log_msg => 'Runner finished all steps');
222      PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
223    EXCEPTION
224      WHEN OTHERS THEN
225        IF l_run_id IS NOT NULL THEN
226          PKG_ARCHIVE_LOG.prc_log_error_stack(l_run_id);
227          PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', SQLERRM);
228        END IF;
229        RAISE;
230    END;
231  END PKG_ARCHIVE_RUNNER;
232  /

