 55  PROCEDURE prc_log
 56  (
 57    p_log_id	  IN NUMBER,
 58    p_log_msg	  IN CLOB,
 59    p_log_lvl	  IN VARCHAR2 DEFAULT 'N',
 60    p_mstr_log_id   IN NUMBER DEFAULT NULL,
 61    p_log_categ	  IN VARCHAR2 DEFAULT NULL,
 62    p_mstr_fun	  IN VARCHAR2 DEFAULT NULL,
 63    p_log_sttus	  IN VARCHAR2 DEFAULT NULL,
 64    p_start_date	  IN DATE DEFAULT NULL,
 65    p_end_date	  IN DATE DEFAULT NULL,
 66    p_last_err_code IN VARCHAR2 DEFAULT NULL,
 67    p_last_err_desc IN VARCHAR2 DEFAULT NULL,
 68    p_log_type	  IN VARCHAR2 DEFAULT 'TEXT'
 69  )
 70  IS
 71    PRAGMA autonomous_transaction;
 72    l_curr_schema VARCHAR2(128) := sys_context('USERENV', 'CURRENT_SCHEMA');
 73    l_today	VARCHAR2(10)  := TO_CHAR(SYSDATE, 'YYYYMMDD');
 74    l_log_categ	VARCHAR2(128);
 75    l_msg 	CLOB;
 76    l_msg_json	CLOB;
 77    l_sysdate	VARCHAR2(64);
 78    l_sql 	CLOB;
 79    l_mstr_log_id NUMBER;
 80    l_log_id	NUMBER;
 81  BEGIN
 82    l_sysdate := to_char(SYSDATE, g_date_formt_const, 'nls_date_language = ''' || g_lang_const || '''' );
 83  
 84    --daily log categ
 85    l_log_categ := 'LOG_' || l_curr_schema || '_' || l_today ||'.log';
 86  
 87    l_msg := to_clob(chr(10) || l_sysdate || ' | ' ) || p_log_msg || to_clob(chr(10));
 88  
 89    l_msg_json := fn_generate_json_log(p_log_msg => p_log_msg, p_log_date => l_sysdate, p_log_type => p_log_type);
 90  
 91    IF p_log_lvl = 'N' OR ( p_log_lvl = 'D' AND g_log_lvl = 'D' ) THEN
 92      IF p_log_id IS NOT NULL THEN
 93        l_log_id := 0;
 94  
 95        l_sql := 'MERGE INTO ' || g_log_table_name || q'! a
 96        USING
 97        (
 98  	SELECT
 99  	   nvl(:p_mstr_log_id, :p_log_id)	 AS mstr_log_id
100  	  ,:p_log_id				 AS log_id
101  	  ,:p_log_categ 			 AS log_categ
102  	  ,:p_mstr_fun				 AS mstr_fun
103  	  ,:p_log_sttus 			 AS log_sttus
104  	  ,:p_start_date			 AS start_date
105  	  ,:p_end_date				 AS end_date
106  	  ,:p_log_msg				 AS log_msg
107  	  ,:p_log_json				 AS log_json
108  	  ,:p_last_err_code			 AS last_err_code
109  	  ,:p_last_err_desc			 AS last_err_desc
110  	  ,sys_context('userenv','instance')	 AS inst_id
111  	  ,sys_context('userenv','sid') 	 AS sid
112  	  ,sys_context('userenv','sessionid')	 AS serial#
113  	  ,sys_context('userenv','client_info')  AS client_info
114  	  ,sys_context('userenv','module')	 AS module
115  	FROM dual
116        ) b
117        ON
118        (
119  	a.mstr_log_id = b.mstr_log_id
120  	AND a.log_id = b.log_id
121        )
122        WHEN MATCHED THEN
123  	UPDATE
124  	SET
125  	  a.log_categ	  = nvl(b.log_categ, a.log_categ),
126  	  a.mstr_fun	  = nvl(b.mstr_fun, a.mstr_fun),
127  	  a.log_sttus	  = nvl(b.log_sttus, a.log_sttus),
128  	  a.start_date	  = nvl(b.start_date, a.start_date),
129  	  a.end_date	  = nvl(b.end_date, a.end_date),
130  	  a.log_msg	  = a.log_msg || b.log_msg,
131  	  a.log_json	  = rtrim(a.log_json,']') || to_clob(',') || b.log_json ||to_clob(']'),
132  	  a.last_err_code = nvl(b.last_err_code, a.last_err_code),
133  	  a.last_err_desc = nvl(b.last_err_desc, a.last_err_desc),
134  	  a.last_updt_dt  = SYSDATE,
135  	  a.last_updt_by  = sys_context('USERENV','SESSION_USER')
136        WHEN NOT MATCHED THEN
137  	INSERT
138  	(
139  	   mstr_log_id
140  	  ,log_id
141  	  ,log_categ
142  	  ,mstr_fun
143  	  ,log_sttus
144  	  ,start_date
145  	  ,end_date
146  	  ,log_msg
147  	  ,log_json
148  	  ,last_err_code
149  	  ,last_err_desc
150  	  ,inst_id
151  	  ,sid
152  	  ,serial#
153  	  ,client_info
154  	  ,module
155  	  ,crtn_dt
156  	  ,crtn_by
157  	  ,last_updt_dt
158  	  ,last_updt_by
159  	)
160  	VALUES
161  	(
162  	   b.mstr_log_id
163  	  ,b.log_id
164  	  ,b.log_categ
165  	  ,b.mstr_fun
166  	  ,nvl(b.log_sttus, :g_sttus_undefined_const)
167  	  ,nvl(b.start_date, SYSDATE)
168  	  ,b.end_date
169  	  ,b.log_msg
170  	  ,to_clob('[')||b.log_json||to_clob(']')
171  	  ,b.last_err_code
172  	  ,b.last_err_desc
173  	  ,b.inst_id
174  	  ,b.sid
175  	  ,b.serial#
176  	  ,b.client_info
177  	  ,b.module
178  	  ,SYSDATE
179  	  ,sys_context('USERENV','SESSION_USER')
180  	  ,SYSDATE
181  	  ,sys_context('USERENV','SESSION_USER')
182  	)!';
183  
184        BEGIN
185  	EXECUTE IMMEDIATE l_sql
186  	USING
187  	   p_mstr_log_id
188  	  ,p_log_id
189  	  ,p_log_id
190  	  ,p_log_categ
191  	  ,p_mstr_fun
192  	  ,p_log_sttus
193  	  ,p_start_date
194  	  ,p_end_date
195  	  ,l_msg
196  	  ,l_msg_json
197  	  ,p_last_err_code
198  	  ,p_last_err_desc
199  	  ,pkg_tl_logging.g_sttus_undefined_const;
200  
201  	COMMIT;
202        EXCEPTION
