171    PROCEDURE prc_log_summary
172    (
173      p_run_id        IN NUMBER,
174      p_process_name  IN VARCHAR2,
175      p_columns       IN VARCHAR2,
176      p_rows          IN CLOB,
177      p_max_col_width IN NUMBER DEFAULT 120
178    )
179    IS
180      l_msg CLOB;
181    BEGIN
182      IF p_rows IS NULL THEN
183        RETURN;
184      END IF;
185  
186      l_msg := 'SUMMARY:' || CHR(10) ||
187               'Process : ' || NVL(p_process_name, '-') || CHR(10) || CHR(10) ||
188               PKG_SQL.fn_format_table
189               (
190                 p_columns       => p_columns,
191                 p_rows          => p_rows,
192                 p_null_text     => '-',
193                 p_max_col_width => p_max_col_width,
194                 p_box_style     => 'SIMPLE'
195               );
196  
197      prc_log_message
198      (
199        p_run_id   => p_run_id,
200        p_log_msg  => l_msg,
201        p_log_type => 'SUMMARY'
202      );
203    END prc_log_summary;
204  
205    PROCEDURE prc_finish_run
206    (
207      p_run_id        IN NUMBER,
208      p_status        IN VARCHAR2,
209      p_error_message IN VARCHAR2 DEFAULT NULL
210    )
211    IS
212      l_log_id   NUMBER;
213      l_run_type TW_ARCHIVE_RUNS.RUN_TYPE%TYPE;
214    BEGIN
215      SELECT MSTR_LOG_ID, RUN_TYPE
216        INTO l_log_id, l_run_type
217        FROM TW_ARCHIVE_RUNS
218       WHERE RUN_ID = p_run_id;
219  
220      UPDATE TW_ARCHIVE_RUNS
221         SET RUN_STATUS = p_status,
222             ENDED_AT = SYSTIMESTAMP,
223             ERROR_MESSAGE = SUBSTR(p_error_message, 1, 4000),
224             UPDATED_AT = SYSTIMESTAMP
225       WHERE RUN_ID = p_run_id;
226  
227      PKG_TL_LOGGING.prc_log
228      (
229        p_log_id          => l_log_id,
230        p_mstr_log_id     => l_log_id,
231        p_log_categ       => l_run_type,
232        p_mstr_fun        => 'PKG_ARCHIVE_' || l_run_type,
233        p_log_sttus       => p_status,
234        p_end_date        => SYSDATE,
235        p_last_err_code   => CASE WHEN p_status = 'ERROR' THEN TO_CHAR(SQLCODE) END,
236        p_last_err_desc   => CASE WHEN p_status = 'ERROR' THEN SUBSTR(p_error_message, 1, 256) END,
237        p_log_type        => CASE WHEN p_status = 'ERROR' THEN 'ERROR' ELSE 'TEXT' END,
238        p_log_msg         => 'Finished ' || l_run_type || ' with status ' || p_status ||
239                             CASE WHEN p_error_message IS NOT NULL THEN ': ' || SUBSTR(p_error_message, 1, 3000) END
240      );
241    END prc_finish_run;
242  END PKG_ARCHIVE_LOG;
243  /

