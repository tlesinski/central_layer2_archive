SQL> @layer2_core/functions/fn_validate_preserve_rule.sql
SQL> CREATE OR REPLACE FUNCTION FN_VALIDATE_PRESERVE_RULE
  2  (
  3    p_preserve_rule IN VARCHAR2
  4  )
  5  RETURN SYS.ODCIDATELIST PIPELINED
  6  AS
  7    l_cursor SYS_REFCURSOR;
  8    l_date   DATE;
  9  BEGIN
 10    IF p_preserve_rule IS NULL THEN
 11      RETURN;
 12    END IF;
 13  
 14    OPEN l_cursor FOR p_preserve_rule;
 15  
 16    LOOP
 17      FETCH l_cursor INTO l_date;
 18      EXIT WHEN l_cursor%NOTFOUND;
 19      PIPE ROW (l_date);
 20    END LOOP;
 21  
 22    CLOSE l_cursor;
 23    RETURN;
 24  EXCEPTION
 25    WHEN OTHERS THEN
 26      IF l_cursor%ISOPEN THEN
 27        CLOSE l_cursor;
 28      END IF;
 29  
 30      PIPE ROW (NULL);
 31      RETURN;
 32  END;
 33  /

