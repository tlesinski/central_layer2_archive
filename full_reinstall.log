357  
358    PROCEDURE prc_cleanup_orphan_staging
359    (
360      p_retention_days IN NUMBER DEFAULT 30,
361      p_execute        IN VARCHAR2 DEFAULT 'N',
362      p_log_id         IN NUMBER DEFAULT NULL
363    )
364    IS
365      l_execute_flag VARCHAR2(1);
366    BEGIN
367      l_execute_flag := fn_normalize_execute(p_execute);
368  
369      DBMS_OUTPUT.PUT_LINE('CLEANUP orphan staging tables older than ' || p_retention_days || ' days');
370  
371      FOR r IN (
372        SELECT o.object_name AS table_name, o.created
373          FROM all_objects o
374         WHERE o.owner = SYS_CONTEXT('USERENV', 'CURRENT_SCHEMA')
375           AND o.object_type = 'TABLE'
376           AND o.object_name LIKE 'STG\_TMP\_ARCH\_%' ESCAPE '\'
377           AND o.created < SYSDATE - NVL(p_retention_days, 30)
378         ORDER BY o.object_name
379      ) LOOP
380        DBMS_OUTPUT.PUT_LINE('[CLEANUP] Candidate: ' || r.table_name ||
381                             ' (created: ' || TO_CHAR(r.created, 'YYYY-MM-DD HH24:MI:SS') || ')');
382  
383        IF l_execute_flag = 'Y' THEN
384          prc_drop_staging(
385            p_staging_owner      => SYS_CONTEXT('USERENV', 'CURRENT_SCHEMA'),
386            p_staging_table_name => r.table_name,
387            p_execute            => 'Y',
388            p_log_id             => p_log_id
389          );
390          DBMS_OUTPUT.PUT_LINE('[CLEANUP] Dropped: ' || r.table_name);
391        END IF;
392      END LOOP;
393  
394      IF l_execute_flag = 'N' THEN
395        DBMS_OUTPUT.PUT_LINE('[CLEANUP] Preview mode - no tables dropped');
396      END IF;
397    END prc_cleanup_orphan_staging;
398  END PKG_ARCHIVE_PARTITION;
