 73      l_target_table := fn_normalize_name(p_target_table_name);
 74      l_run_id := PKG_ARCHIVE_LOG.fn_create_run('QUALITY', NULL, NULL, NULL, l_execute_flag);
 75      l_log_id := PKG_ARCHIVE_LOG.fn_get_log_id(l_run_id);
 76  
 77      PKG_ARCHIVE_LOG.prc_log_message
 78      (
 79        p_run_id  => l_run_id,
 80        p_log_msg => 'Started QUALITY with parameters:' || CHR(10) ||
 81                     '  p_execute           => ' || l_execute_flag || CHR(10) ||
 82                     '  p_target_owner      => ' || NVL(l_target_owner, '<ALL>') || CHR(10) ||
 83                     '  p_target_table_name => ' || NVL(l_target_table, '<ALL>')
 84      );
 85  
 86      l_sql :=
 87        'SELECT COUNT(*) ' ||
 88        '  FROM TW_ARCHIVE_QUALITY_PARTITIONS_VW ' ||
 89        ' WHERE (:1 IS NULL OR target_owner = :1) ' ||
 90        '   AND (:2 IS NULL OR target_table_name = :2)';
 91  
 92      l_rows_available := PKG_SQL.fn_run_into_sql_in_bind
 93      (
 94        p_log_id     => l_log_id,
 95        p_sql        => l_sql,
 96        p_array_bind => SYS.ODCIVARCHAR2LIST(l_target_owner, l_target_table),
 97        p_execute    => 'Y'
 98      );
 99  
100      FOR t IN (
101        SELECT DISTINCT source_db_link,
102               source_agent_schema,
103               source_owner,
104               source_table_name,
105               target_owner,
106               target_table_name
107          FROM TW_ARCHIVE_QUALITY_PARTITIONS_VW
108         WHERE (l_target_owner IS NULL OR target_owner = l_target_owner)
109           AND (l_target_table IS NULL OR target_table_name = l_target_table)
110         ORDER BY source_db_link, source_owner, source_table_name
111      ) LOOP
112        l_tables := l_tables + 1;
113        l_table_summary := NULL;
114        l_agent_function := fn_qualified_agent_function(t.source_agent_schema, t.source_db_link);
115        l_sql := 'SELECT ' || l_agent_function || '(:1, :2, :3, :4) FROM dual';
116  
117        FOR r IN (
118          SELECT p.*
119            FROM TW_ARCHIVE_QUALITY_PARTITIONS_VW p
120           WHERE p.source_db_link = t.source_db_link
121             AND p.source_owner = t.source_owner
122             AND p.source_table_name = t.source_table_name
123             AND p.target_owner = t.target_owner
124             AND p.target_table_name = t.target_table_name
125            ORDER BY p.partition_high_value, p.subpartition_high_value
126        ) LOOP
127          l_units := l_units + 1;
128  
129          l_source_rows := PKG_SQL.fn_run_into_sql_in_bind
130          (
131            p_log_id     => l_log_id,
132            p_sql        => l_sql,
133            p_array_bind => SYS.ODCIVARCHAR2LIST
134                            (
135                              r.SOURCE_OWNER,
136                              r.SOURCE_TABLE_NAME,
137                              r.SOURCE_PARTITION_NAME,
138                              CASE WHEN r.SOURCE_SUBPARTITION_NAME = '#' THEN NULL ELSE r.SOURCE_SUBPARTITION_NAME END
139                            ),
140            p_execute    => 'Y'
141          );
142  
143          IF l_source_rows = r.TARGET_ROW_COUNT THEN
144            l_quality_status := 'Y';
145            l_ok := l_ok + 1;
146          ELSE
147            l_quality_status := 'N';
148            l_failed := l_failed + 1;
149          END IF;
150  
151          DBMS_OUTPUT.PUT_LINE('QUALITY ' || r.SOURCE_DB_LINK || '.' || r.SOURCE_OWNER || '.' ||
152                               r.SOURCE_TABLE_NAME || ' source_name=' || r.SOURCE_PARTITION_NAME ||
153                               CASE WHEN r.SOURCE_SUBPARTITION_NAME <> '#' THEN '.' || r.SOURCE_SUBPARTITION_NAME ELSE NULL END ||
154                               ' target_name=' || r.PARTITION_NAME ||
155                               CASE WHEN r.SUBPARTITION_NAME <> '#' THEN '.' || r.SUBPARTITION_NAME ELSE NULL END ||
156                               ' source_rows=' || NVL(TO_CHAR(l_source_rows), 'NULL') ||
157                               ' target_rows=' || NVL(TO_CHAR(r.TARGET_ROW_COUNT), 'NULL') ||
158                               ' status=' || l_quality_status || ' execute=' || l_execute_flag);
159  
160          IF l_execute_flag = 'Y' THEN
161            UPDATE TW_ARCHIVE_PARTITIONS
162               SET SOURCE_ROW_COUNT = l_source_rows,
163                   QUALITY_STATUS = l_quality_status,
164                   LAST_RUN_ID = l_run_id,
165                   ERROR_MESSAGE = CASE
166                                     WHEN l_quality_status = 'Y' THEN NULL
167                                     ELSE 'Source row count does not match target row count'
168                                   END,
169                   UPDATED_AT = SYSTIMESTAMP
170             WHERE SOURCE_DB_LINK = r.SOURCE_DB_LINK
171               AND SOURCE_OWNER = r.SOURCE_OWNER
172               AND SOURCE_TABLE_NAME = r.SOURCE_TABLE_NAME
173               AND PARTITION_HIGH_VALUE = r.PARTITION_HIGH_VALUE
174               AND SUBPARTITION_HIGH_VALUE = r.SUBPARTITION_HIGH_VALUE;
175  
176            COMMIT;
177          END IF;
178  
179          l_table_summary := l_table_summary ||
180            TO_CLOB(PKG_ARCHIVE_LOG.fn_summary_cell(CASE WHEN l_quality_status = 'Y' THEN 'OK' ELSE 'MISMATCH' END)) || '|' ||
181            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_partition_name) || '|' ||
182            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_subpartition_name) || '|' ||
183            PKG_ARCHIVE_LOG.fn_summary_cell(r.partition_name) || '|' ||
184            PKG_ARCHIVE_LOG.fn_summary_cell(r.subpartition_name) || '|' ||
185            PKG_ARCHIVE_LOG.fn_summary_cell(r.partition_high_value) || '|' ||
186            PKG_ARCHIVE_LOG.fn_summary_cell(r.subpartition_high_value) || '|' ||
187            PKG_ARCHIVE_LOG.fn_summary_cell(r.archive_status) || '|' ||
188            PKG_ARCHIVE_LOG.fn_summary_cell(l_quality_status) || '|' ||
189            PKG_ARCHIVE_LOG.fn_summary_cell(r.truncate_status) || '|' ||
190            PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(l_source_rows)) || '|' ||
191            PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(r.target_row_count)) || CHR(10);
192        END LOOP; -- FOR r
193  
194        IF l_table_summary IS NOT NULL THEN
195          l_summary := l_summary ||
196            '=== TABLE: ' || t.source_db_link || '.' || t.source_owner || '.' || t.source_table_name || ' ===' || CHR(10) || CHR(10) ||
197            PKG_SQL.fn_format_table(
198              p_columns => 'SOURCE_DB_LINK|TABLE_OWNER|TABLE_NAME|EXECUTE',
199              p_rows    => PKG_ARCHIVE_LOG.fn_summary_cell(t.source_db_link) || '|' ||
200                           PKG_ARCHIVE_LOG.fn_summary_cell(t.source_owner) || '|' ||
201                           PKG_ARCHIVE_LOG.fn_summary_cell(t.source_table_name) || '|' ||
202                           PKG_ARCHIVE_LOG.fn_summary_cell(l_execute_flag) || CHR(10)
203            ) || CHR(10) ||
204            PKG_SQL.fn_format_table(
205              p_columns    => l_partition_columns,
206              p_rows       => l_table_summary
207            ) || CHR(10);
208        END IF;
209      END LOOP; -- FOR t
210  
211      DBMS_OUTPUT.PUT_LINE(
212        'QUALITY tables=' || l_tables ||
213        ' units=' || l_units ||
214        ' found=' || l_rows_available ||
215        ' ok=' || l_ok ||
216        ' failed=' || l_failed ||
217        ' target_owner=' || NVL(l_target_owner, '<ALL>') ||
218        ' target_table=' || NVL(l_target_table, '<ALL>') ||
219        ' execute=' || l_execute_flag
220      );
221  
222      IF l_summary IS NOT NULL THEN
223        PKG_ARCHIVE_LOG.prc_log_message(l_run_id, l_summary, 'SUMMARY');
224      END IF;
225  
226      PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, CASE WHEN l_failed > 0 THEN 'WARNING' ELSE 'SUCCESS' END);
227    EXCEPTION
228      WHEN OTHERS THEN
229        IF l_run_id IS NOT NULL THEN
230          PKG_ARCHIVE_LOG.prc_log_error_stack(l_run_id);
231          PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', SQLERRM);
232        END IF;
233        RAISE;
234    END prc_quality;
235  END PKG_ARCHIVE_QUALITY;
236  /

