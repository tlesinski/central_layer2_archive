SQL> CREATE OR REPLACE PACKAGE BODY PKG_ARCHIVE_IMPORT
  2  AS
  3    /*
  4      Package      : PKG_ARCHIVE_IMPORT
  5      Developer    : Tomasz Lesinski
  6      Date         : 2026-05-28
  7      Purpose      : Import source partitions into target archive via EXCHANGE
  8  
  9      Prerequisite : PKG_SQL, PKG_ARCHIVE_LOG, PKG_ARCHIVE_PARTITION,
 10                     TW_ARCHIVE_IMPORT_PARTITIONS_VW
 11  
 12      Change History:
 13      ------------------------------------------------------------------------------
 14      Version    Date         Programmer         Description
 15      ------------------------------------------------------------------------------
 16      1.0        2026-05-28   Tomasz Lesinski    Initial version
 17      1.1        2026-05-28   Tomasz Lesinski    Add PARALLEL_DEGREE support,
 18                                                 ALTER SESSION ENABLE PARALLEL DML,
 19                                                 process summary logging
 20    */
 21    FUNCTION fn_normalize_execute(p_execute IN VARCHAR2) RETURN VARCHAR2 IS
 22    BEGIN
 23      RETURN CASE WHEN UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN 'Y' ELSE 'N' END;
 24    END;
 25  
 26    FUNCTION fn_normalize_name(p_name IN VARCHAR2) RETURN VARCHAR2 IS
 27    BEGIN
 28      IF p_name IS NULL OR TRIM(p_name) IS NULL THEN
 29        RETURN NULL;
 30      END IF;
 31  
 32      RETURN PKG_SQL.fn_assert_simple_name(p_name);
 33    END;
 34  
 35    PROCEDURE prc_mark_partition
 36    (
 37      p_source_db_link          IN VARCHAR2,
 38      p_source_owner            IN VARCHAR2,
 39      p_source_table_name       IN VARCHAR2,
 40      p_partition_high_value    IN VARCHAR2,
 41      p_subpartition_high_value IN VARCHAR2,
 42      p_archive_status   IN VARCHAR2,
 43      p_run_id           IN NUMBER,
 44      p_target_row_count IN NUMBER DEFAULT NULL,
 45      p_error_message    IN VARCHAR2 DEFAULT NULL
 46    )
 47    IS
 48    BEGIN
 49      UPDATE TW_ARCHIVE_PARTITIONS
 50         SET ARCHIVE_STATUS = p_archive_status,
 51             QUALITY_STATUS = CASE WHEN p_archive_status = 'Y' THEN 'N' ELSE QUALITY_STATUS END,
 52             TARGET_ROW_COUNT = COALESCE(p_target_row_count, TARGET_ROW_COUNT),
 53             LAST_RUN_ID = p_run_id,
 54             ERROR_MESSAGE = p_error_message,
 55             UPDATED_AT = SYSTIMESTAMP
 56       WHERE SOURCE_DB_LINK = p_source_db_link
 57         AND SOURCE_OWNER = p_source_owner
 58         AND SOURCE_TABLE_NAME = p_source_table_name
 59         AND PARTITION_HIGH_VALUE = p_partition_high_value
 60         AND SUBPARTITION_HIGH_VALUE = p_subpartition_high_value;
 61    END prc_mark_partition;
 62  
 63    PROCEDURE prc_import
 64    (
 65      p_execute           IN VARCHAR2 DEFAULT 'N',
 66      p_target_owner      IN VARCHAR2 DEFAULT NULL,
 67      p_target_table_name IN VARCHAR2 DEFAULT NULL
 68    )
 69    IS
 70      l_run_id          NUMBER;
 71      l_log_id          NUMBER;
 72      l_execute_flag    VARCHAR2(1);
 73      l_target_owner    VARCHAR2(128);
 74      l_target_table    VARCHAR2(128);
 75      l_sql             CLOB;
 76      l_rows_available  NUMBER := 0;
 77      l_rows_loaded     NUMBER;
 78      l_units           NUMBER := 0;
 79      l_imported        NUMBER := 0;
 80      l_tables          NUMBER := 0;
 81      l_staging_table   VARCHAR2(128);
 82      l_parallel_degree NUMBER;
 83      l_tablespace_name VARCHAR2(128);
 84      l_summary         CLOB := NULL;
 85      l_summary_columns VARCHAR2(1000) :=
 86        'SOURCE_DB_LINK|TABLE_OWNER|TABLE_NAME|SOURCE_PARTITION_NAME|SOURCE_SUBPARTITION_NAME|PARTITION_HIGH_VALUE|SUBPARTITION_HIGH_VALUE|ARCHIVE_STATUS|QUALITY_STATUS|TRUNCATE_STATUS|SOURCE_ROW_COUNT|TARGET_ROW_COUNT|NOTE';
 87    BEGIN
 88      l_execute_flag := fn_normalize_execute(p_execute);
 89      l_target_owner := fn_normalize_name(p_target_owner);
 90      l_target_table := fn_normalize_name(p_target_table_name);
 91      l_run_id := PKG_ARCHIVE_LOG.fn_create_run('ARCHIVE', NULL, NULL, NULL, l_execute_flag);
 92      l_log_id := PKG_ARCHIVE_LOG.fn_get_log_id(l_run_id);
 93  
 94      PKG_ARCHIVE_LOG.prc_log_message
 95      (
 96        p_run_id  => l_run_id,
 97        p_log_msg => 'Started ARCHIVE with parameters:' || CHR(10) ||
 98                     '  p_execute           => ' || l_execute_flag || CHR(10) ||
 99                     '  p_target_owner      => ' || NVL(l_target_owner, '<ALL>') || CHR(10) ||
100                     '  p_target_table_name => ' || NVL(l_target_table, '<ALL>')
101      );
102  
103      IF l_execute_flag = 'Y' THEN
104        COMMIT;
105        EXECUTE IMMEDIATE 'ALTER SESSION ENABLE PARALLEL DML';
106      END IF;
107  
108      l_sql :=
109        'SELECT COUNT(*) ' ||
110        '  FROM TW_ARCHIVE_IMPORT_PARTITIONS_VW ' ||
111        ' WHERE (:1 IS NULL OR target_owner = :1) ' ||
112        '   AND (:2 IS NULL OR target_table_name = :2)';
113  
114      l_rows_available := PKG_SQL.fn_run_into_sql_in_bind
115      (
116        p_log_id     => l_log_id,
117        p_sql        => l_sql,
118        p_array_bind => SYS.ODCIVARCHAR2LIST(l_target_owner, l_target_table),
119        p_execute    => 'Y'
120      );
121  
122      FOR t IN (
123        SELECT DISTINCT source_db_link,
124               source_owner,
125               source_table_name,
126               target_owner,
127               target_table_name
128          FROM TW_ARCHIVE_IMPORT_PARTITIONS_VW
129         WHERE (l_target_owner IS NULL OR target_owner = l_target_owner)
130           AND (l_target_table IS NULL OR target_table_name = l_target_table)
131         ORDER BY source_db_link, source_owner, source_table_name
132      ) LOOP
133        l_tables := l_tables + 1;
134  
135        SELECT NVL(PARALLEL_DEGREE, 4),
136               TABLESPACE_NAME
137          INTO l_parallel_degree,
138               l_tablespace_name
139          FROM TW_ARCHIVE_TABLES
140         WHERE SOURCE_DB_LINK = t.source_db_link
141           AND SOURCE_OWNER = t.source_owner
142           AND SOURCE_TABLE_NAME = t.source_table_name;
143  
144        FOR r IN (
145          SELECT p.*
146            FROM TW_ARCHIVE_IMPORT_PARTITIONS_VW p
147           WHERE p.source_db_link = t.source_db_link
148             AND p.source_owner = t.source_owner
149             AND p.source_table_name = t.source_table_name
150             AND p.target_owner = t.target_owner
151             AND p.target_table_name = t.target_table_name
152           ORDER BY p.partition_position, p.subpartition_position
153        ) LOOP
154          l_units := l_units + 1;
155          l_rows_loaded := NULL;
156  
157          IF l_execute_flag = 'Y' THEN
158            prc_mark_partition(
159              r.SOURCE_DB_LINK,
160              r.SOURCE_OWNER,
161              r.SOURCE_TABLE_NAME,
162              r.PARTITION_HIGH_VALUE,
163              r.SUBPARTITION_HIGH_VALUE,
164              'N',
165              l_run_id
166            );
167          END IF;
168  
169          PKG_ARCHIVE_PARTITION.prc_create_exchange_staging
170          (
171            p_target_owner       => r.TARGET_OWNER,
172            p_target_table       => r.TARGET_TABLE_NAME,
173            p_partition_name     => r.PARTITION_NAME,
174            p_staging_table_name => l_staging_table,
175            p_execute            => l_execute_flag,
176            p_log_id             => l_log_id,
177            p_tablespace_name    => l_tablespace_name
178          );
179  
180          IF r.ARCHIVE_UNIT_TYPE = 'SUBPARTITION' THEN
181            PKG_ARCHIVE_PARTITION.prc_load_exchange_staging_subpartition
182            (
183              p_source_db_link             => r.SOURCE_DB_LINK,
184              p_source_owner               => r.SOURCE_OWNER,
185              p_source_table               => r.SOURCE_TABLE_NAME,
186              p_target_owner               => r.TARGET_OWNER,
187              p_target_table               => r.TARGET_TABLE_NAME,
188              p_staging_table_name         => l_staging_table,
189              p_partition_high_value       => r.PARTITION_HIGH_VALUE,
190              p_prev_partition_high_value  => r.PREV_PARTITION_HIGH_VALUE,
191              p_subpartition_high_value    => r.SUBPARTITION_HIGH_VALUE,
192              p_execute                    => l_execute_flag,
193              p_log_id                     => l_log_id,
194              p_parallel_degree            => l_parallel_degree,
195              p_rows_loaded                => l_rows_loaded
196            );
197          ELSE
198            PKG_ARCHIVE_PARTITION.prc_load_exchange_staging
199            (
200              p_source_db_link     => r.SOURCE_DB_LINK,
201              p_source_owner       => r.SOURCE_OWNER,
202              p_source_table       => r.SOURCE_TABLE_NAME,
203              p_target_owner       => r.TARGET_OWNER,
204              p_target_table       => r.TARGET_TABLE_NAME,
205              p_staging_table_name => l_staging_table,
206              p_high_value         => r.PARTITION_HIGH_VALUE,
207              p_prev_high_value    => r.PREV_PARTITION_HIGH_VALUE,
208              p_execute            => l_execute_flag,
209              p_log_id             => l_log_id,
210              p_parallel_degree    => l_parallel_degree,
211              p_rows_loaded        => l_rows_loaded
212            );
213          END IF;
214  
215          PKG_ARCHIVE_LOG.prc_log_message
216          (
217            p_run_id   => l_run_id,
218            p_log_type => 'ARCHIVE_LOAD',
219            p_log_msg  => 'ARCHIVE_LOAD ' ||
220                          'source=' || r.source_db_link || '.' || r.source_owner || '.' || r.source_table_name ||
221                          ' ' || r.source_partition_name ||
222                          CASE
223                            WHEN r.archive_unit_type = 'SUBPARTITION'
224                              THEN '.' || r.source_subpartition_name
225                          END ||
226                          ', target=' || r.target_owner || '.' || r.target_table_name ||
227                          ' ' || r.partition_name ||
228                          CASE
229                            WHEN r.archive_unit_type = 'SUBPARTITION'
230                              THEN '.' || r.subpartition_name
231                          END ||
232                          ', staging=' || r.target_owner || '.' || l_staging_table ||
233                          ', rows_loaded=' || NVL(TO_CHAR(l_rows_loaded), '<DRY_RUN>') ||
234                          ', execute=' || l_execute_flag
235          );
236  
237          PKG_ARCHIVE_PARTITION.prc_build_staging_indexes
238          (
239            p_target_owner       => r.TARGET_OWNER,
240            p_target_table       => r.TARGET_TABLE_NAME,
241            p_staging_table_name => l_staging_table,
242            p_execute            => l_execute_flag,
243            p_log_id             => l_log_id,
244            p_parallel_degree    => l_parallel_degree,
245            p_tablespace_name    => l_tablespace_name
246          );
247  
248          IF r.ARCHIVE_UNIT_TYPE = 'SUBPARTITION' THEN
249            PKG_ARCHIVE_PARTITION.prc_exchange_subpartition
250            (
251              p_target_owner       => r.TARGET_OWNER,
252              p_target_table       => r.TARGET_TABLE_NAME,
253              p_subpartition_name  => r.SUBPARTITION_NAME,
254              p_staging_table_name => l_staging_table,
255              p_execute            => l_execute_flag,
256              p_log_id             => l_log_id
257            );
258          ELSE
259            PKG_ARCHIVE_PARTITION.prc_exchange_partition
260            (
261              p_target_owner       => r.TARGET_OWNER,
262              p_target_table       => r.TARGET_TABLE_NAME,
263              p_partition_name     => r.PARTITION_NAME,
264              p_staging_table_name => l_staging_table,
265              p_execute            => l_execute_flag,
266              p_log_id             => l_log_id
267            );
268          END IF;
269  
270          PKG_ARCHIVE_PARTITION.prc_drop_staging
271          (
272            p_staging_owner      => r.TARGET_OWNER,
273            p_staging_table_name => l_staging_table,
274            p_execute            => l_execute_flag,
275            p_log_id             => l_log_id
276          );
277  
278          IF l_execute_flag = 'Y' THEN
279            prc_mark_partition(
280              r.SOURCE_DB_LINK,
281              r.SOURCE_OWNER,
282              r.SOURCE_TABLE_NAME,
283              r.PARTITION_HIGH_VALUE,
284              r.SUBPARTITION_HIGH_VALUE,
285              'Y',
286              l_run_id,
287              l_rows_loaded
288            );
289  
290            l_imported := l_imported + 1;
291            COMMIT;
292          END IF;
293  
294          DBMS_OUTPUT.PUT_LINE('IMPORT_DONE EXCHANGE ' ||
295                               r.SOURCE_DB_LINK || '.' || r.SOURCE_OWNER || '.' ||
296                               r.SOURCE_TABLE_NAME || ' ' || r.PARTITION_NAME ||
297                               CASE WHEN r.ARCHIVE_UNIT_TYPE = 'SUBPARTITION' THEN '.' || r.SUBPARTITION_NAME END ||
298                               ' loaded=' || NVL(TO_CHAR(l_rows_loaded), '<DRY_RUN>') ||
299                               ' target_rows=' || NVL(TO_CHAR(l_rows_loaded), '<DRY_RUN>'));
300  
301          IF l_execute_flag = 'Y' THEN
302            l_summary := l_summary ||
303              PKG_ARCHIVE_LOG.fn_summary_row
304              (
305                p_source_db_link          => r.source_db_link,
306                p_table_owner             => r.source_owner,
307                p_table_name              => r.source_table_name,
308                p_partition_name          => r.source_partition_name,
309                p_subpartition_name       => r.source_subpartition_name,
310                p_partition_high_value    => r.partition_high_value,
311                p_subpartition_high_value => r.subpartition_high_value,
312                p_archive_status          => 'Y',
313                p_quality_status          => 'N',
314                p_truncate_status         => r.truncate_status,
315                p_source_row_count        => r.source_row_count,
316                p_target_row_count        => l_rows_loaded,
317                p_note                    => 'target=' || r.target_owner || '.' || r.target_table_name ||
318                                             ' ' || r.partition_name ||
319                                             CASE WHEN r.archive_unit_type = 'SUBPARTITION' THEN '.' || r.subpartition_name END ||
320                                             ', execute=' || l_execute_flag
321              );
322          END IF;
323        END LOOP;
324      END LOOP;
325  
326      IF l_summary IS NOT NULL THEN
327        PKG_ARCHIVE_LOG.prc_log_summary
328        (
329          p_run_id       => l_run_id,
330          p_process_name => 'ARCHIVE',
331          p_columns      => l_summary_columns,
332          p_rows         => l_summary
333        );
334      END IF;
335  
336      DBMS_OUTPUT.PUT_LINE(
337        'IMPORT tables=' || l_tables ||
338        ' units=' || l_units ||
339        ' found=' || l_rows_available ||
340        ' imported=' || l_imported ||
341        ' target_owner=' || NVL(l_target_owner, '<ALL>') ||
342        ' target_table=' || NVL(l_target_table, '<ALL>') ||
343        ' execute=' || l_execute_flag
344      );
345  
346      PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
347    EXCEPTION
348      WHEN OTHERS THEN
349        IF l_run_id IS NOT NULL THEN
350          PKG_ARCHIVE_LOG.prc_log_error_stack(l_run_id);
351          PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', SQLERRM);
352        END IF;
353        RAISE;
354    END prc_import;
355  END PKG_ARCHIVE_IMPORT;
356  /

