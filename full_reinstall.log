337    FUNCTION fn_col_count
338    (
339      p_line IN VARCHAR2,
340      p_sep  IN VARCHAR2 DEFAULT '|'
341    )
342    RETURN PLS_INTEGER
343    IS
344      l_count PLS_INTEGER := 1;
345      l_pos   PLS_INTEGER := 0;
346    BEGIN
347      IF p_line IS NULL THEN
348        RETURN 0;
349      END IF;
350  
351      LOOP
352        l_pos := INSTR(p_line, p_sep, l_pos + 1);
353        EXIT WHEN l_pos = 0;
354        l_count := l_count + 1;
355      END LOOP;
356  
357      RETURN l_count;
358    END fn_col_count;
359  
360    FUNCTION fn_col_value
361    (
362      p_line   IN VARCHAR2,
363      p_col_no IN PLS_INTEGER,
364      p_sep    IN VARCHAR2 DEFAULT '|'
365    )
366    RETURN VARCHAR2
367    IS
368      l_text      VARCHAR2(32767) := p_line;
369      l_start_pos PLS_INTEGER := 1;
370      l_end_pos   PLS_INTEGER;
371    BEGIN
372      FOR i IN 1 .. p_col_no LOOP
373        l_end_pos := INSTR(l_text, p_sep, l_start_pos);
374  
375        IF i = p_col_no THEN
376          IF l_end_pos = 0 THEN
377            RETURN SUBSTR(l_text, l_start_pos);
378          ELSE
379            RETURN SUBSTR(l_text, l_start_pos, l_end_pos - l_start_pos);
380          END IF;
381        END IF;
382  
383        IF l_end_pos = 0 THEN
384          RETURN NULL;
385        END IF;
386  
387        l_start_pos := l_end_pos + 1;
388      END LOOP;
389  
390      RETURN NULL;
391    END fn_col_value;
392  
393    FUNCTION fn_next_line
394    (
395      p_clob IN CLOB,
396      p_pos  IN OUT PLS_INTEGER
397    )
398    RETURN VARCHAR2
399    IS
400      l_end_pos PLS_INTEGER;
401      l_line    VARCHAR2(32767);
402    BEGIN
403      IF p_clob IS NULL OR p_pos > DBMS_LOB.GETLENGTH(p_clob) THEN
404        RETURN NULL;
405      END IF;
406  
407      l_end_pos := DBMS_LOB.INSTR(p_clob, CHR(10), p_pos);
408  
409      IF l_end_pos = 0 THEN
410        l_line := DBMS_LOB.SUBSTR(p_clob, 32767, p_pos);
411        p_pos := DBMS_LOB.GETLENGTH(p_clob) + 1;
412      ELSE
413        l_line := DBMS_LOB.SUBSTR(p_clob, l_end_pos - p_pos, p_pos);
414        p_pos := l_end_pos + 1;
415      END IF;
416  
417      RETURN l_line;
418    END fn_next_line;
419  
420    FUNCTION fn_sanitize
421    (
422      p_value    IN VARCHAR2,
423      p_null_text IN VARCHAR2 DEFAULT '-',
424      p_sep      IN VARCHAR2 DEFAULT '|'
425    )
426    RETURN VARCHAR2
427    IS
428    BEGIN
429      IF p_value IS NULL OR TRIM(p_value) IS NULL THEN
430        RETURN p_null_text;
431      END IF;
432  
433      RETURN REPLACE(REPLACE(REPLACE(TRIM(p_value), CHR(13), ' '), CHR(10), ' '), p_sep, ' ');
434    END fn_sanitize;
435  
436    FUNCTION fn_format_table
437    (
438      p_columns       IN VARCHAR2,
439      p_rows          IN CLOB,
440      p_col_align     IN VARCHAR2 DEFAULT NULL,
441      p_separator     IN VARCHAR2 DEFAULT '|',
442      p_null_text     IN VARCHAR2 DEFAULT '-',
443      p_max_col_width IN NUMBER   DEFAULT 120,
444      p_box_style     IN VARCHAR2 DEFAULT 'SIMPLE'
445    )
446    RETURN CLOB
447    IS
448      TYPE t_widths IS TABLE OF PLS_INTEGER INDEX BY PLS_INTEGER;
449  
450      l_widths       t_widths;
451      l_col_count    PLS_INTEGER;
452      l_max_width    PLS_INTEGER := LEAST(GREATEST(NVL(p_max_col_width, 120), 8), 300);
453      l_pos          PLS_INTEGER;
454      l_line         VARCHAR2(32767);
455      l_value        VARCHAR2(32767);
456      l_sanitized    VARCHAR2(32767);
457      l_result       CLOB;
458      l_rows_count   NUMBER := 0;
459      l_box          VARCHAR2(20);
460      l_is_right     BOOLEAN;
461    BEGIN
462      l_box := UPPER(NVL(TRIM(p_box_style), 'SIMPLE'));
463  
464      IF l_box NOT IN ('NONE', 'SIMPLE') THEN
465        l_box := 'SIMPLE';
466      END IF;
467  
468      l_col_count := fn_col_count(p_columns, p_separator);
469  
470      IF l_col_count = 0 THEN
471        RETURN 'FORMAT_TABLE: no columns' || CHR(10);
472      END IF;
473  
474      -- pass 1: measure max widths per column
475      FOR i IN 1 .. l_col_count LOOP
476        l_value := fn_col_value(p_columns, i, p_separator);
477        l_widths(i) := LEAST(GREATEST(LENGTH(NVL(l_value, '-')), 1), l_max_width);
478      END LOOP;
479  
480      l_pos := 1;
481  
482      LOOP
483        l_line := fn_next_line(p_rows, l_pos);
484        EXIT WHEN l_line IS NULL;
485        CONTINUE WHEN TRIM(l_line) IS NULL;
486  
487        l_rows_count := l_rows_count + 1;
488  
489        FOR i IN 1 .. l_col_count LOOP
490          l_value := fn_col_value(l_line, i, p_separator);
491          l_sanitized := fn_sanitize(l_value, p_null_text, p_separator);
492          l_widths(i) := LEAST(GREATEST(l_widths(i), LENGTH(l_sanitized)), l_max_width);
493        END LOOP;
494      END LOOP;
495  
496      -- pass 2: build output
497      l_result := 'FORMAT_TABLE:' || CHR(10);
498      l_result := l_result || 'Columns : ' || l_col_count || CHR(10);
499      l_result := l_result || 'Rows    : ' || l_rows_count || CHR(10) || CHR(10);
500  
501      -- header + top border
502      IF l_box = 'SIMPLE' THEN
503        l_result := l_result || '+';
504        FOR i IN 1 .. l_col_count LOOP
505          l_result := l_result || RPAD('-', l_widths(i) + 2, '-') || '+';
506        END LOOP;
507        l_result := l_result || CHR(10) || '|';
508  
509        FOR i IN 1 .. l_col_count LOOP
510          l_value := fn_col_value(p_columns, i, p_separator);
511          l_result := l_result || ' ' || RPAD(NVL(l_value, '-'), l_widths(i)) || ' |';
512        END LOOP;
513  
514        l_result := l_result || CHR(10) || '+';
515        FOR i IN 1 .. l_col_count LOOP
516          l_result := l_result || RPAD('-', l_widths(i) + 2, '-') || '+';
517        END LOOP;
518        l_result := l_result || CHR(10);
519      ELSE
520        FOR i IN 1 .. l_col_count LOOP
521          l_value := fn_col_value(p_columns, i, p_separator);
522          l_result := l_result || RPAD(NVL(l_value, '-'), l_widths(i));
523          l_result := l_result || CASE WHEN i < l_col_count THEN '  ' END;
524        END LOOP;
525  
526        l_result := l_result || CHR(10);
527  
528        FOR i IN 1 .. l_col_count LOOP
529          l_result := l_result || RPAD('-', l_widths(i), '-');
530          l_result := l_result || CASE WHEN i < l_col_count THEN '  ' END;
531        END LOOP;
532  
533        l_result := l_result || CHR(10);
534      END IF;
535  
536      -- data rows
537      l_pos := 1;
538  
539      LOOP
540        l_line := fn_next_line(p_rows, l_pos);
541        EXIT WHEN l_line IS NULL;
542        CONTINUE WHEN TRIM(l_line) IS NULL;
543  
544        IF l_box = 'SIMPLE' THEN
545          l_result := l_result || '|';
546        END IF;
547  
548        FOR i IN 1 .. l_col_count LOOP
549          l_value := fn_col_value(l_line, i, p_separator);
550          l_sanitized := fn_sanitize(l_value, p_null_text, p_separator);
551          l_is_right := p_col_align IS NOT NULL AND LENGTH(p_col_align) >= i AND SUBSTR(p_col_align, i, 1) = '>';
552  
553          IF l_box = 'SIMPLE' THEN
554            l_result := l_result || ' ' ||
555              CASE WHEN l_is_right THEN LPAD(l_sanitized, l_widths(i)) ELSE RPAD(l_sanitized, l_widths(i)) END ||
556              ' |';
557          ELSE
558            l_result := l_result ||
559              CASE WHEN l_is_right THEN LPAD(l_sanitized, l_widths(i)) ELSE RPAD(l_sanitized, l_widths(i)) END;
560            l_result := l_result || CASE WHEN i < l_col_count THEN '  ' END;
561          END IF;
562        END LOOP;
563  
564        l_result := l_result || CHR(10);
565      END LOOP;
566  
567      -- bottom border
568      IF l_box = 'SIMPLE' AND l_rows_count > 0 THEN
569        l_result := l_result || '+';
570        FOR i IN 1 .. l_col_count LOOP
571          l_result := l_result || RPAD('-', l_widths(i) + 2, '-') || '+';
572        END LOOP;
573        l_result := l_result || CHR(10);
574      END IF;
575  
576      RETURN l_result;
577    END fn_format_table;
578  END PKG_SQL;
579  /

