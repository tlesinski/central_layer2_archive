228  --Procedure prc_error_stack
229  -- dumps oracle stack if error occures into table MD_PRCSS_LOG
230  
231    PROCEDURE prc_error_stack
232    (
233      p_log_id IN NUMBER,
234      p_mstr_log_id IN NUMBER DEFAULT NULL
235    )
236    IS
237      l_sqlcode NUMBER;
238      l_sqlerrm VARCHAR2(255);
239      l_message CLOB;
240    BEGIN
241      l_sqlcode := sqlcode;
242      l_sqlerrm := substr(SQLERRM, 1, 255);
243  
244      l_message := chr(10) ||
245        '===================================================================' || chr(10) ||
246        ' SQLCODE:	 ' || l_sqlcode 				    || chr(10) ||
247        ' SQLERRM:	 ' || l_sqlerrm 				    || chr(10) ||
248        '===================================================================' || CHR(10) ||
249        ' Call stack:	 ' || dbms_utility.format_call_stack()		    || CHR(10) ||
250        '===================================================================' || chr(10) ||
251        ' Error stack:	 ' || dbms_utility.format_error_stack() 	    || CHR(10) ||
252        '===================================================================' || CHR(10) ||
253        ' Error backtrace: ' || dbms_utility.format_error_backtrace	    || CHR(10) ||
254        '===================================================================';
255  
256      dbms_output.put_line(l_message);
257  
258      prc_log
259      (
260        p_mstr_log_id    => p_mstr_log_id,
261        p_log_id	       => p_log_id,
262        p_log_sttus      => pkg_tl_logging.g_sttus_error_const,
263        p_end_date       => SYSDATE,
264        p_log_msg        => l_message,
265        p_last_err_code  => l_sqlcode,
266        p_last_err_desc  => l_sqlerrm,
267        p_log_type       => 'ERROR'
268      );
269    END prc_error_stack;
270  
271  -- creates local log table md_process_log
272  -- and local log sequence md_process_log_seq
273  
274  PROCEDURE prc_log_create_table
275  IS
276  l_check NUMBER;
277  l_sql CLOB;
278  l_proc_name VARCHAR2(128) := 'prc_log_create_table';
279  BEGIN
280  --------------------------------------------
281  --create local log table g_log_table_name
282  --------------------------------------------
283  SELECT COUNT(*)
284  INTO l_check
285  FROM user_tables
286  WHERE table_name = g_log_table_name;
287  
288  SELECT COUNT(*)
289    INTO l_check
290  FROM (
291    SELECT 1
292      FROM user_tables
293     WHERE table_name = g_log_table_name
294     UNION ALL
295    SELECT 1
296      FROM user_synonyms
297     WHERE synonym_name = g_log_table_name
298  );
299  
300  IF l_check = 0 THEN
301    dbms_output.put_line('Try to create log table ' || g_log_table_name);
302  
303    l_sql := q'!CREATE TABLE "MD_PROCESS_LOG"
304  
305  ( "MSTR_LOG_ID" NUMBER NOT NULL ENABLE,
306  "LOG_ID" NUMBER NOT NULL ENABLE,
307  "LOG_CATEG" VARCHAR2(256 BYTE),
308  "MSTR_FUN" VARCHAR2(128 BYTE),
309  "LOG_STTUS" VARCHAR2(30 BYTE) NOT NULL ENABLE,
310  "START_DATE" DATE,
311  "END_DATE" DATE,
312  "INTERVAL_TIME" INTERVAL DAY (2) TO SECOND (6) GENERATED ALWAYS AS (NUMTODSINTERVAL("END_DATE"-"START_DATE",'DAY')) VIRTUAL ,
313  "LOG_MSG" CLOB NOT NULL ENABLE,
314  "LOG_JSON" CLOB,
315  "LAST_ERR_CODE" VARCHAR2(30 BYTE),
316  "LAST_ERR_DESC" VARCHAR2(256 BYTE),
317  "INST_ID" NUMBER,
318  "SID" NUMBER,
319  "SERIAL#" NUMBER,
320  "CLIENT_INFO" VARCHAR2(128 BYTE),
321  "MODULE" VARCHAR2(128 BYTE),
322  "CRTN_DT" DATE DEFAULT SYSDATE NOT NULL ENABLE,
323  "CRTN_BY" VARCHAR2(128 BYTE) DEFAULT sys_context('USERENV','SESSION_USER') NOT NULL ENABLE,
324  "LAST_UPDT_DT" DATE DEFAULT SYSDATE NOT NULL ENABLE,
325  "LAST_UPDT_BY" VARCHAR2(128 BYTE) DEFAULT sys_context('USERENV','SESSION_USER') NOT NULL ENABLE
326  )
327  PARTITION BY RANGE ("START_DATE") INTERVAL (NUMTOYMINTERVAL(1, 'MONTH'))
328  (PARTITION "P_START" VALUES LESS THAN (TO_DATE(' 2019-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')) )!';
329  
330  EXECUTE IMMEDIATE l_sql;
331  
332  l_sql := 'CREATE INDEX "MD_PROCESS_LOG_IDX1" ON "MD_PROCESS_LOG" ("MSTR_LOG_ID", "LOG_ID") LOCAL';
333  
334    EXECUTE IMMEDIATE l_sql;
335  ELSE
336    dbms_output.put_line('Local log table ' || g_log_table_name || ' or synonym already exists');
337  END IF;
338  
339  --------------------------------------------
340  --create local log sequence g_log_sequence_name
341  --------------------------------------------
342  SELECT COUNT(*)
343    INTO l_check
344  FROM (
345    SELECT 1
346      FROM user_sequences
347     WHERE sequence_name = g_log_sequence_name
348     UNION ALL
349    SELECT 1
350      FROM user_synonyms
351     WHERE synonym_name = g_log_sequence_name
352  );
353  
354  IF l_check = 0 THEN
355    dbms_output.put_line('Try to create log sequence ' || g_log_sequence_name);
356  
357    l_sql := 'CREATE SEQUENCE md_process_log_seq START WITH 1 INCREMENT BY 1';
358  
359    EXECUTE IMMEDIATE l_sql;
360  ELSE
361    dbms_output.put_line('Local log sequence ' || g_log_sequence_name || ' or synonym already exists');
362  END IF;
363  
364  prc_log_cleanup_table;
365  
366  EXCEPTION
367  WHEN OTHERS THEN
368  prc_error_stack(p_log_id=>null);
369  
370    raise_application_error( -20001, 'Creation of local log table ' || g_log_table_name || chr(10) ||
371  				   ' or sequence ' || g_log_sequence_name || chr(10) ||
372  				   ' failed turn on serveroutput to get more info' );
373  
374  END prc_log_create_table;
375  
376  --Procedure prc_init_log
377  -- initializes log in physical file and in md_process_log table
378  
379  PROCEDURE prc_init_log
380  (
381  p_force IN VARCHAR2 DEFAULT 'N'
382  )
383  IS
384  l_check NUMBER;
385  BEGIN
386  dbms_output.put_line('prc_init_log');
387  
388  IF g_curr_schema_name IS NULL OR p_force = 'Y' THEN
389    g_curr_schema_name := sys_context('USERENV', 'CURRENT_SCHEMA');
390  
391    prc_log_create_table;
392  END IF;
393  
394  END prc_init_log;
395  
396  -- cleanup old partitions in table md_process_log
397  
398  PROCEDURE prc_log_cleanup_table
399  IS
400  l_proc_name VARCHAR2(128) := 'prc_log_cleanup_table';
401  l_long VARCHAR2(4000);
402  l_interval_date DATE;
403  l_partition_date DATE;
404  l_sql CLOB;
405  BEGIN
406  dbms_output.put_line
407  (
408  'Calling procedure ' || $$plsql_unit|| '.' || l_proc_name
409  );
410  
411  l_interval_date := (SYSDATE - ABS(g_log_retention_days));
412  
413  dbms_output.put_line
414  (
415    'Drop partitions for table ' || g_log_table_name || chr(10) ||
416    '  older than ' || g_log_retention_days || ' days' || chr(10) ||
417    '  older than ' || to_char( l_interval_date, g_date_formt_const )
418  );
419  
420  FOR i IN ( SELECT table_name, partition_name, high_value
421  	     FROM user_tab_partitions
422  	    WHERE table_name = g_log_table_name
423  	      AND partition_name != 'P_START'
424  	    ORDER BY partition_position )
425  LOOP
426    --convert partition high_value long to date;
427    l_long := i.high_value;
428  
429    EXECUTE IMMEDIATE 'SELECT ' || l_long || ' FROM dual' INTO l_partition_date;
430  
431    IF l_interval_date > l_partition_date THEN
432      l_sql := 'ALTER TABLE ' || i.table_name || ' DROP PARTITION ' || i.partition_name;
433  
434      dbms_output.put_line
435      (
436        'Partition ' || i.partition_name || ' high_value ' || to_char( l_partition_date, g_date_formt_const ) || chr(10) ||
437        ' older than ' || to_char( l_interval_date, g_date_formt_const ) || chr(10) ||
438        ' to drop: ' || l_sql
439      );
440  
441      EXECUTE IMMEDIATE l_sql;
442    END IF;
443  END LOOP;
444  
445  dbms_output.put_line
446  (
447    'Completed procedure ' || $$plsql_unit || '.' || l_proc_name
448  );
449  
450  EXCEPTION
451  WHEN OTHERS THEN
452  dbms_output.put_line('Error cleaning log table ' || SQLCODE || substr(SQLERRM, 1, 200));
453  END prc_log_cleanup_table;
454  BEGIN
455  
456  --calling base procedure to intialize entries in md_process_log table and file with directories
457  
458  prc_init_log;
459  END PKG_TL_LOGGING;
460  /

