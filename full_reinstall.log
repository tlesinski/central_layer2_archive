SQL> CREATE OR REPLACE FORCE VIEW TW_ARCHIVE_TRUNCATE_PARTITIONS_VW
  2  AS
  3  WITH w_preserve_data as 
  4  (
  5    SELECT /*+ materialize */ target_owner, target_table_name, preserve_rule, B.COLUMN_VALUE preserve_date
  6      FROM tw_archive_tables A 
  7      LEFT JOIN LATERAL(SELECT * FROM TABLE(fn_validate_preserve_rule(A.preserve_rule))) B ON(1=1)
  8  ) ,
  9  candidate_partitions AS (
 10  SELECT p.source_db_link,
 11         t.source_agent_schema,
 12         p.source_owner,
 13         p.source_table_name,
 14         p.target_owner,
 15         p.target_table_name,
 16         p.archive_unit_type,
 17         p.source_partition_name,
 18         p.source_subpartition_name,
 19         p.partition_name,
 20         p.subpartition_name,
 21         p.partition_high_value,
 22         p.subpartition_high_value,
 23         p.prev_partition_high_value,
 24         p.archive_status,
 25         p.quality_status,
 26         p.truncate_status,
 27         p.source_row_count,
 28         p.target_row_count,
 29         preserve_rule,
 30         FN_ARCHIVE_HIGH_VALUE_DATE(t.LAST_BUSINESS_DATE) LAST_BUSINESS_DATE_calc,
 31         DAYS_ONLINE,
 32         FN_ARCHIVE_HIGH_VALUE_DATE(t.LAST_BUSINESS_DATE)- DAYS_ONLINE AS cutoff_date,
 33         FN_ARCHIVE_HIGH_VALUE_DATE(p.partition_high_value) AS partition_high_value_date,
 34         FN_ARCHIVE_HIGH_VALUE_DATE(p.prev_partition_high_value) AS prev_partition_high_value_date
 35    FROM tw_archive_partitions p
 36    JOIN tw_archive_tables t
 37      ON t.source_db_link = p.source_db_link
 38     AND t.source_owner = p.source_owner
 39     AND t.source_table_name = p.source_table_name
 40     AND t.enabled_flag = 'Y'
 41     AND t.truncate_mode = 'TRUNCATE'
 42   WHERE p.archive_status = 'Y'
 43     AND p.quality_status = 'Y'
 44     AND p.truncate_status = 'N'
 45  )
 46  SELECT source_db_link,
 47         source_agent_schema,
 48         source_owner,
 49         source_table_name,
 50         target_owner,
 51         target_table_name,
 52         archive_unit_type,
 53         source_partition_name,
 54         source_subpartition_name,
 55         partition_name,
 56         subpartition_name,
 57         partition_high_value,
 58         subpartition_high_value,
 59         prev_partition_high_value,
 60         archive_status,
 61         quality_status,
 62         truncate_status,
 63         source_row_count,
 64         target_row_count,
 65         preserve_rule,
 66         LAST_BUSINESS_DATE_calc,
 67         DAYS_ONLINE,
 68         cutoff_date,
 69         partition_high_value_date,
 70         prev_partition_high_value_date,
 71         (SELECT MAX(preserve_date) 
 72            FROM w_preserve_data P 
 73           WHERE P.target_owner=C.target_owner 
 74             AND P.target_table_name=C.target_table_name 
 75             AND partition_high_value_date > preserve_date 
 76             AND prev_partition_high_value_date <= preserve_date) preserve_date
 77    FROM candidate_partitions c 
 78   WHERE partition_high_value_date <= cutoff_date
 79  /

