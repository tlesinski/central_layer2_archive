 56  
 57    PROCEDURE prc_truncate
 58    (
 59      p_execute           IN VARCHAR2 DEFAULT 'N',
 60      p_target_owner      IN VARCHAR2 DEFAULT NULL,
 61      p_target_table_name IN VARCHAR2 DEFAULT NULL
 62    )
 63    IS
 64      l_run_id          NUMBER;
 65      l_log_id          NUMBER;
 66      l_execute_flag    VARCHAR2(1);
 67      l_target_owner    VARCHAR2(128);
 68      l_target_table    VARCHAR2(128);
 69      l_sql             CLOB;
 70      l_rows_available  NUMBER := 0;
 71      l_agent_procedure VARCHAR2(400);
 72      l_units           NUMBER := 0;
 73      l_truncated       NUMBER := 0;
 74      l_tables          NUMBER := 0;
 75      l_sql_rows        NUMBER;
 76      l_summary         CLOB := NULL;
 77      l_summary_columns VARCHAR2(1000) :=
 78        'SOURCE_DB_LINK|TABLE_OWNER|TABLE_NAME|SOURCE_PARTITION_NAME|SOURCE_SUBPARTITION_NAME|PARTITION_NAME|SUBPARTITION_NAME|PARTITION_HIGH_VALUE|SUBPARTITION_HIGH_VALUE|ARCHIVE_STATUS|QUALITY_STATUS|TRUNCATE_STATUS|SOURCE_ROW_COUNT|TARGET_ROW_COUNT|NOTE';
 79    BEGIN
 80      l_execute_flag := fn_normalize_execute(p_execute);
 81      l_target_owner := fn_normalize_name(p_target_owner);
 82      l_target_table := fn_normalize_name(p_target_table_name);
 83      l_run_id := PKG_ARCHIVE_LOG.fn_create_run('TRUNCATE', NULL, NULL, NULL, l_execute_flag);
 84      l_log_id := PKG_ARCHIVE_LOG.fn_get_log_id(l_run_id);
 85  
 86      PKG_ARCHIVE_LOG.prc_log_message
 87      (
 88        p_run_id  => l_run_id,
 89        p_log_msg => 'Started TRUNCATE with parameters:' || CHR(10) ||
 90                     '  p_execute           => ' || l_execute_flag || CHR(10) ||
 91                     '  p_target_owner      => ' || NVL(l_target_owner, '<ALL>') || CHR(10) ||
 92                     '  p_target_table_name => ' || NVL(l_target_table, '<ALL>')
 93      );
 94  
 95      l_sql :=
 96        'SELECT COUNT(*) ' ||
 97        '  FROM TW_ARCHIVE_TRUNCATE_PARTITIONS_VW ' ||
 98        ' WHERE (:1 IS NULL OR target_owner = :1) ' ||
 99        '   AND (:2 IS NULL OR target_table_name = :2)';
100  
101      l_rows_available := PKG_SQL.fn_run_into_sql_in_bind
102      (
103        p_log_id     => l_log_id,
104        p_sql        => l_sql,
105        p_array_bind => SYS.ODCIVARCHAR2LIST(l_target_owner, l_target_table),
106        p_execute    => 'Y'
107      );
108  
109      FOR t IN (
110        SELECT DISTINCT source_db_link,
111               source_agent_schema,
112               source_owner,
113               source_table_name,
114               target_owner,
115               target_table_name
116          FROM TW_ARCHIVE_TRUNCATE_PARTITIONS_VW
117         WHERE (l_target_owner IS NULL OR target_owner = l_target_owner)
118           AND (l_target_table IS NULL OR target_table_name = l_target_table)
119         ORDER BY source_db_link, source_owner, source_table_name
120      ) LOOP
121        l_tables := l_tables + 1;
122        l_agent_procedure := fn_qualified_agent_procedure(t.source_agent_schema, t.source_db_link);
123        l_sql := 'BEGIN ' || l_agent_procedure || '(:1, :2, :3, :4, :5, :6); END;';
124  
125        FOR r IN (
126          SELECT p.*
127            FROM TW_ARCHIVE_TRUNCATE_PARTITIONS_VW p
128           WHERE p.source_db_link = t.source_db_link
129             AND p.source_owner = t.source_owner
130             AND p.source_table_name = t.source_table_name
131             AND p.target_owner = t.target_owner
132             AND p.target_table_name = t.target_table_name
133           ORDER BY p.partition_position, p.subpartition_position
134        ) LOOP
135          l_units := l_units + 1;
136          DBMS_OUTPUT.PUT_LINE('TRUNCATE ' || r.SOURCE_DB_LINK || '.' || r.SOURCE_OWNER || '.' ||
137                               r.SOURCE_TABLE_NAME || ' source=' || r.SOURCE_PARTITION_NAME ||
138                               CASE WHEN r.SOURCE_SUBPARTITION_NAME <> '#' THEN '.' || r.SOURCE_SUBPARTITION_NAME ELSE NULL END ||
139                               ' target=' || r.PARTITION_NAME ||
140                               CASE WHEN r.SUBPARTITION_NAME <> '#' THEN '.' || r.SUBPARTITION_NAME ELSE NULL END ||
141                               ' cutoff=' || TO_CHAR(r.CUTOFF_DATE, 'YYYY-MM-DD') ||
142                               ' execute=' || l_execute_flag);
143  
144          l_sql_rows := PKG_SQL.fn_run_sql_in_bind
145          (
146            p_log_id     => l_log_id,
147            p_sql        => l_sql,
148            p_array_bind => SYS.ODCIVARCHAR2LIST
149                            (
150                              r.SOURCE_OWNER,
151                              r.SOURCE_TABLE_NAME,
152                              r.SOURCE_PARTITION_NAME,
153                              CASE WHEN r.SOURCE_SUBPARTITION_NAME = '#' THEN NULL ELSE r.SOURCE_SUBPARTITION_NAME END,
154                              'TRUNCATE',
155                              l_execute_flag
156                            ),
157            p_execute    => l_execute_flag
158          );
159  
160          IF l_execute_flag = 'Y' THEN
161            UPDATE TW_ARCHIVE_PARTITIONS
162               SET TRUNCATE_STATUS = 'Y',
163                   LAST_RUN_ID = l_run_id,
164                   ERROR_MESSAGE = NULL,
165                   UPDATED_AT = SYSTIMESTAMP
166             WHERE SOURCE_DB_LINK = r.SOURCE_DB_LINK
167               AND SOURCE_OWNER = r.SOURCE_OWNER
168               AND SOURCE_TABLE_NAME = r.SOURCE_TABLE_NAME
169               AND PARTITION_HIGH_VALUE = r.PARTITION_HIGH_VALUE
170               AND SUBPARTITION_HIGH_VALUE = r.SUBPARTITION_HIGH_VALUE;
171  
172            l_truncated := l_truncated + SQL%ROWCOUNT;
173            COMMIT;
174          END IF;
175  
176          l_summary := l_summary ||
177            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_db_link) || '|' ||
178            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_owner) || '|' ||
179            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_table_name) || '|' ||
180            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_partition_name) || '|' ||
181            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_subpartition_name) || '|' ||
182            PKG_ARCHIVE_LOG.fn_summary_cell(r.partition_name) || '|' ||
183            PKG_ARCHIVE_LOG.fn_summary_cell(r.subpartition_name) || '|' ||
184            PKG_ARCHIVE_LOG.fn_summary_cell(r.partition_high_value) || '|' ||
185            PKG_ARCHIVE_LOG.fn_summary_cell(r.subpartition_high_value) || '|' ||
186            PKG_ARCHIVE_LOG.fn_summary_cell(r.archive_status) || '|' ||
187            PKG_ARCHIVE_LOG.fn_summary_cell(r.quality_status) || '|' ||
188            PKG_ARCHIVE_LOG.fn_summary_cell(CASE WHEN l_execute_flag = 'Y' THEN 'Y' ELSE 'N' END) || '|' ||
189            PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(r.source_row_count)) || '|' ||
190            PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(r.target_row_count)) || '|' ||
191            PKG_ARCHIVE_LOG.fn_summary_cell('source=' || r.source_owner || '.' || r.source_table_name ||
192                                            ' ' || r.source_partition_name ||
193                                            CASE WHEN r.archive_unit_type = 'SUBPARTITION' THEN '.' || r.source_subpartition_name END ||
194                                            ', mode=TRUNCATE, execute=' || l_execute_flag ||
195                                            ', cutoff=' || TO_CHAR(r.cutoff_date, 'YYYY-MM-DD')) ||
196            CHR(10);
197        END LOOP;
198      END LOOP;
199  
200      DBMS_OUTPUT.PUT_LINE(
201        'TRUNCATE tables=' || l_tables ||
202        ' units=' || l_units ||
203        ' found=' || l_rows_available ||
204        ' truncated=' || l_truncated ||
205        ' target_owner=' || NVL(l_target_owner, '<ALL>') ||
206        ' target_table=' || NVL(l_target_table, '<ALL>') ||
207        ' execute=' || l_execute_flag
208      );
209  
210      IF l_summary IS NOT NULL THEN
211        PKG_ARCHIVE_LOG.prc_log_summary
212        (
213          p_run_id       => l_run_id,
214          p_process_name => 'TRUNCATE',
215          p_columns      => l_summary_columns,
216          p_rows         => l_summary
217        );
218      END IF;
219  
220      PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
221    EXCEPTION
222      WHEN OTHERS THEN
223        IF l_run_id IS NOT NULL THEN
224          PKG_ARCHIVE_LOG.prc_log_error_stack(l_run_id);
225          PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', SQLERRM);
226        END IF;
227        RAISE;
228    END prc_truncate;
229  END PKG_ARCHIVE_TRUNCATE;
230  /

