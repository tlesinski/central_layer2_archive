 66    PROCEDURE prc_log_sql
 67    (
 68      p_log_id  IN NUMBER,
 69      p_sql     IN CLOB,
 70      p_execute IN VARCHAR2
 71    )
 72    IS
 73      l_log_sql CLOB;
