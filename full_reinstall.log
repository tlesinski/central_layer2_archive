 67    PROCEDURE prc_log_sql
 68    (
 69      p_log_id  IN NUMBER,
 70      p_sql     IN CLOB,
 71      p_execute IN VARCHAR2
 72    )
 73    IS
 74      l_log_sql CLOB;
 75    BEGIN
 76      IF p_log_id IS NOT NULL THEN
 77        l_log_sql := fn_format_sql_for_log(p_sql);
 78  
 79        PKG_TL_LOGGING.prc_log
 80        (
 81          p_log_id    => p_log_id,
 82          p_log_msg   => CASE fn_normalize_execute(p_execute)
 83                           WHEN 'Y' THEN TO_CLOB('Executing SQL:') || CHR(10)
 84                           ELSE TO_CLOB('Preview SQL:') || CHR(10)
 85                         END || l_log_sql,
 86          p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
 87          p_log_type  => 'SQL'
 88        );
 89      END IF;
 90    END prc_log_sql;
