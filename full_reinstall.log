SQL> @layer2_core/views/tw_archive_source_partitions_vw.sql
SQL> CREATE OR REPLACE VIEW TW_ARCHIVE_SOURCE_PARTITIONS_VW
  2  AS
  3  WITH cfg AS (
  4    SELECT source_db_link,
  5           source_agent_schema,
  6           source_owner,
  7           source_table_name,
  8           target_owner,
  9           target_table_name
 10      FROM tw_archive_tables
 11     WHERE enabled_flag = 'Y'
 12  ),
 13  src AS (
 14    SELECT c.source_db_link,
 15           c.source_agent_schema,
 16           c.source_owner,
 17           c.source_table_name,
 18           c.target_owner,
 19           c.target_table_name,
 20           CASE
 21             WHEN x.subpartition_name IS NULL THEN 'PARTITION'
 22             ELSE 'SUBPARTITION'
 23           END AS archive_unit_type,
 24           x.partition_name AS source_partition_name,
 25           NVL(x.subpartition_name, '#') AS source_subpartition_name,
 26           x.partition_name AS partition_name,
 27           NVL(x.subpartition_name, '#') AS subpartition_name,
 28           x.partition_high_value,
 29            NVL(x.subpartition_high_value, '#') AS subpartition_high_value,
 30            x.prev_partition_high_value,
 31            x.partition_position,
 32           NVL(x.subpartition_position, 0) AS subpartition_position
 33      FROM cfg c,
 34           XMLTABLE(
 35             '/ROWSET/ROW'
 36             PASSING DBMS_XMLGEN.GETXMLTYPE(
 37               'SELECT * FROM ' ||
 38               DBMS_ASSERT.SIMPLE_SQL_NAME(c.source_agent_schema) ||
 39               '.ARCHIVE_PARTITION_INFO_VW' ||
 40               CASE
 41                 WHEN c.source_db_link IS NOT NULL
 42                      AND UPPER(TRIM(c.source_db_link)) NOT IN ('LOCAL', 'NONE')
 43                   THEN '@' || DBMS_ASSERT.SIMPLE_SQL_NAME(c.source_db_link)
 44               END ||
 45               ' WHERE schema_name = ''' || REPLACE(UPPER(c.source_owner), '''', '''''') || '''' ||
 46               ' AND table_name = ''' || REPLACE(UPPER(c.source_table_name), '''', '''''') || ''''
 47             )
 48             COLUMNS
 49               schema_name              VARCHAR2(128)  PATH 'SCHEMA_NAME',
 50               table_name               VARCHAR2(128)  PATH 'TABLE_NAME',
 51               partition_name           VARCHAR2(128)  PATH 'PARTITION_NAME',
 52               subpartition_name        VARCHAR2(128)  PATH 'SUBPARTITION_NAME',
 53                partition_high_value     VARCHAR2(4000) PATH 'PARTITION_HIGH_VALUE',
 54                subpartition_high_value  VARCHAR2(4000) PATH 'SUBPARTITION_HIGH_VALUE',
 55                prev_partition_high_value VARCHAR2(4000) PATH 'PREV_PARTITION_HIGH_VALUE',
 56                partition_position       NUMBER         PATH 'PARTITION_POSITION',
 57                subpartition_position    NUMBER         PATH 'SUBPARTITION_POSITION'
 58            ) x
 59      WHERE UPPER(TRIM(x.partition_high_value)) <> 'MAXVALUE'
 60  )
 61  SELECT source_db_link,
 62         source_agent_schema,
 63         source_owner,
 64         source_table_name,
 65         target_owner,
 66         target_table_name,
 67         archive_unit_type,
 68         source_partition_name,
 69         source_subpartition_name,
 70         partition_name,
 71         subpartition_name,
 72         partition_high_value,
 73         subpartition_high_value,
 74         prev_partition_high_value,
 75         partition_position,
 76         subpartition_position
 77    FROM src;

