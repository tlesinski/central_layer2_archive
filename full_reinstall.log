170    PROCEDURE prc_log_summary
171    (
172      p_run_id        IN NUMBER,
173      p_process_name  IN VARCHAR2,
174      p_columns       IN VARCHAR2,
175      p_rows          IN CLOB,
176      p_max_col_width IN NUMBER DEFAULT 120
177    )
178    IS
179      l_msg CLOB;
180    BEGIN
181      IF p_rows IS NULL THEN
182        RETURN;
183      END IF;
184  
185      l_msg := 'SUMMARY:' || CHR(10) ||
186               'Process : ' || NVL(p_process_name, '-') || CHR(10) || CHR(10) ||
187               PKG_SQL.fn_format_table
188               (
189                 p_columns       => p_columns,
190                 p_rows          => p_rows,
191                 p_null_text     => '-',
192                 p_max_col_width => p_max_col_width,
193                 p_box_style     => 'SIMPLE'
194               );
195  
196      prc_log_message
197      (
198        p_run_id   => p_run_id,
199        p_log_msg  => l_msg,
200        p_log_type => 'SUMMARY'
201      );
202    END prc_log_summary;
203  
204    PROCEDURE prc_finish_run
205    (
206      p_run_id        IN NUMBER,
207      p_status        IN VARCHAR2,
208      p_error_message IN VARCHAR2 DEFAULT NULL
209    )
210    IS
211      l_log_id   NUMBER;
212      l_run_type TW_ARCHIVE_RUNS.RUN_TYPE%TYPE;
213    BEGIN
214      SELECT MSTR_LOG_ID, RUN_TYPE
215        INTO l_log_id, l_run_type
216        FROM TW_ARCHIVE_RUNS
217       WHERE RUN_ID = p_run_id;
218  
219      UPDATE TW_ARCHIVE_RUNS
220         SET RUN_STATUS = p_status,
221             ENDED_AT = SYSTIMESTAMP,
222             ERROR_MESSAGE = SUBSTR(p_error_message, 1, 4000),
223             UPDATED_AT = SYSTIMESTAMP
224       WHERE RUN_ID = p_run_id;
225  
226      PKG_TL_LOGGING.prc_log
227      (
228        p_log_id          => l_log_id,
229        p_mstr_log_id     => l_log_id,
230        p_log_categ       => l_run_type,
231        p_mstr_fun        => 'PKG_ARCHIVE_' || l_run_type,
232        p_log_sttus       => p_status,
233        p_end_date        => SYSDATE,
234        p_last_err_code   => CASE WHEN p_status = 'ERROR' THEN TO_CHAR(SQLCODE) END,
235        p_last_err_desc   => CASE WHEN p_status = 'ERROR' THEN SUBSTR(p_error_message, 1, 256) END,
236        p_log_type        => CASE WHEN p_status = 'ERROR' THEN 'ERROR' ELSE 'TEXT' END,
237        p_log_msg         => 'Finished ' || l_run_type || ' with status ' || p_status ||
238                             CASE WHEN p_error_message IS NOT NULL THEN ': ' || SUBSTR(p_error_message, 1, 3000) END
239      );
240    END prc_finish_run;
241  END PKG_ARCHIVE_LOG;
242  /

