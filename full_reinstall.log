SQL> @layer2_core/triggers/trg_archive_tables_preserve_calc.sql
SQL> CREATE OR REPLACE TRIGGER TRG_ARCHIVE_TABLES_PRESERVE_CALC
  2    BEFORE INSERT OR UPDATE OF PRESERVE_RULE ON TW_ARCHIVE_TABLES
  3    FOR EACH ROW
  4  DECLARE
  5    l_date DATE;
  6  BEGIN
  7    IF :NEW.PRESERVE_RULE IS NULL THEN
  8      :NEW.PRESERVE_CALC := NULL;
  9      :NEW.UPDATED_AT := SYSDATE;
 10      RETURN;
 11    END IF;
 12  
 13    BEGIN
 14      SELECT COLUMN_VALUE INTO l_date
 15        FROM TABLE(FN_VALIDATE_PRESERVE_RULE(:NEW.PRESERVE_RULE))
 16       WHERE ROWNUM = 1;
 17  
 18      IF l_date IS NULL THEN
 19        :NEW.PRESERVE_CALC := 'ERROR: execute failed';
 20      ELSE
 21        :NEW.PRESERVE_CALC := 'CORRECT';
 22      END IF;
 23    EXCEPTION
 24      WHEN NO_DATA_FOUND THEN
 25        :NEW.PRESERVE_CALC := 'CORRECT';
 26      WHEN OTHERS THEN
 27        :NEW.PRESERVE_CALC := 'ERROR: ' || SQLERRM;
 28    END;
 29  
 30    :NEW.UPDATED_AT := SYSDATE;
 31  END;
