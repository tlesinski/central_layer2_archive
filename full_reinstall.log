SQL> @layer2_core/functions/fn_calculate_retention_rule.sql
SQL> CREATE OR REPLACE FUNCTION FN_CALCULATE_RETENTION_RULE
  2  (
  3    p_retention_rule IN VARCHAR2
  4  )
  5  RETURN SYS.ODCIDATELIST PIPELINED 
  6  AS
  7    l_cursor       SYS_REFCURSOR;
  8    l_first_date   DATE;
  9    l_second_date  DATE;
 10  BEGIN
 11    BEGIN
 12      OPEN l_cursor FOR p_retention_rule;
 13    EXCEPTION
 14      WHEN OTHERS THEN
 15        PIPE ROW (NULL);
 16        RETURN;
 17    END;
 18  
 19    FETCH l_cursor INTO l_first_date;
 20  
 21    IF l_cursor%NOTFOUND THEN
 22      PIPE ROW (NULL);
 23    ELSE
 24      FETCH l_cursor INTO l_second_date;
 25  
 26      IF l_cursor%FOUND THEN
 27        PIPE ROW (NULL);
 28      ELSE
 29        PIPE ROW (l_first_date);
 30      END IF;
 31    END IF;
 32  
 33    CLOSE l_cursor;
 34    RETURN;
 35  EXCEPTION  
 36    WHEN OTHERS THEN
 37      IF l_cursor%ISOPEN THEN
 38        CLOSE l_cursor;
 39      END IF;
 40  
 41      PIPE ROW (NULL);
 42  
 43      RETURN;
 44  END;
 45  /

