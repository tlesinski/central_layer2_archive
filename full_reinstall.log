 18    */
 19    FUNCTION fn_normalize_execute(p_execute IN VARCHAR2) RETURN VARCHAR2 IS
 20    BEGIN
 21      RETURN CASE WHEN UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN 'Y' ELSE 'N' END;
 22    END;
 23  
 24    FUNCTION fn_create_run
 25    (
 26      p_run_type       IN VARCHAR2,
 27      p_source_db_link IN VARCHAR2,
 28      p_source_owner   IN VARCHAR2,
 29      p_source_table   IN VARCHAR2,
 30      p_execute        IN VARCHAR2
 31    )
 32    RETURN NUMBER
 33    IS
 34      l_run_id       NUMBER;
 35      l_log_id       NUMBER;
 36      l_run_type     VARCHAR2(30);
 37      l_execute_flag VARCHAR2(1);
 38    BEGIN
 39      l_run_type := UPPER(TRIM(p_run_type));
 40      l_execute_flag := fn_normalize_execute(p_execute);
 41      l_log_id := MD_PROCESS_LOG_SEQ.NEXTVAL;
 42  
 43      INSERT INTO TW_ARCHIVE_RUNS
 44        (RUN_TYPE, RUN_STATUS, SOURCE_DB_LINK, SOURCE_OWNER, SOURCE_TABLE_NAME, MSTR_LOG_ID, EXECUTE_FLAG)
 45      VALUES
 46        (l_run_type, 'RUNNING', UPPER(p_source_db_link), UPPER(p_source_owner), UPPER(p_source_table), l_log_id, l_execute_flag)
 47      RETURNING RUN_ID INTO l_run_id;
 48  
 49      RETURN l_run_id;
 50    END fn_create_run;
 51  
 52    FUNCTION fn_get_log_id
 53    (
 54      p_run_id IN NUMBER
 55    )
 56    RETURN NUMBER
 57    IS
 58      l_log_id NUMBER;
 59    BEGIN
