 19    FUNCTION fn_normalize_execute
 20    (
 21      p_execute IN VARCHAR2
 22    )
 23    RETURN VARCHAR2
 24    IS
 25    BEGIN
 26      IF UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN
 27        RETURN 'Y';
 28      END IF;
 29  
 30      RETURN 'N';
 31    END fn_normalize_execute;
