 82                           WHEN 'Y' THEN TO_CLOB('Executing SQL:') || CHR(10)
 83                           ELSE TO_CLOB('Preview SQL:') || CHR(10)
 84                         END || l_log_sql,
 85          p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
 86          p_log_type  => 'SQL'
 87        );
 88      END IF;
 89    END prc_log_sql;
