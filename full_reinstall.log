SQL> CREATE OR REPLACE PACKAGE BODY PKG_ARCHIVE_TRUNCATE
  2  AS
  3    /*
  4      Package      : PKG_ARCHIVE_TRUNCATE
  5      Developer    : Tomasz Lesinski
  6      Date         : 2026-05-28
  7      Purpose      : Source truncate - request source truncate through layer 1 agent
  8                     after quality success, respecting RETENTION_RULE
  9  
 10      Prerequisite : PKG_SQL, PKG_ARCHIVE_LOG, PKG_ARCHIVE_AGENT,
 11                     TW_ARCHIVE_TRUNCATE_PARTITIONS_VW
 12  
 13      Change History:
 14      ------------------------------------------------------------------------------
 15      Version    Date         Programmer         Description
 16      ------------------------------------------------------------------------------
 17      1.0        2026-05-28   Tomasz Lesinski    Initial version
 18      1.1        2026-05-28   Tomasz Lesinski    Add process summary logging
 19      1.2        2026-05-29   Tomasz Lesinski    Abort on invalid RETENTION_RULE
 20      1.3        2026-05-29   Tomasz Lesinski    Abort on invalid PRESERVE_RULE
 21       1.4        2026-05-31   Tomasz Lesinski    Skip truncate when preserve_date IS NOT NULL;
 22                                                   log as PRESERVED in summary with MAX_PRESERVE_DATE
 23       1.5        2026-05-31   Tomasz Lesinski    Compact per-table summary, ORA-40478 fix
 24    */
 25    FUNCTION fn_normalize_execute(p_execute IN VARCHAR2) RETURN VARCHAR2 IS
 26    BEGIN
 27      RETURN CASE WHEN UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN 'Y' ELSE 'N' END;
 28    END;
 29  
 30    FUNCTION fn_normalize_name(p_name IN VARCHAR2) RETURN VARCHAR2 IS
 31    BEGIN
 32      IF p_name IS NULL OR TRIM(p_name) IS NULL THEN
 33        RETURN NULL;
 34      END IF;
 35  
 36      RETURN PKG_SQL.fn_assert_simple_name(p_name);
 37    END;
 38  
 39    FUNCTION fn_qualified_agent_procedure(p_agent_schema IN VARCHAR2, p_source_db_link IN VARCHAR2) RETURN VARCHAR2 IS
 40      l_name VARCHAR2(400);
 41    BEGIN
 42      l_name := PKG_SQL.fn_assert_simple_name(p_agent_schema) || '.PKG_ARCHIVE_AGENT.PRC_CLEANUP_UNIT';
 43      IF p_source_db_link IS NOT NULL AND UPPER(TRIM(p_source_db_link)) NOT IN ('LOCAL', 'NONE') THEN
 44        l_name := l_name || '@' || PKG_SQL.fn_assert_simple_name(p_source_db_link);
 45      END IF;
 46      RETURN l_name;
 47    END;
 48  
 49    PROCEDURE prc_truncate
 50    (
 51      p_execute           IN VARCHAR2 DEFAULT 'N',
 52      p_target_owner      IN VARCHAR2 DEFAULT NULL,
 53      p_target_table_name IN VARCHAR2 DEFAULT NULL
 54    )
 55    IS
 56      l_run_id          NUMBER;
 57      l_log_id          NUMBER;
 58      l_execute_flag    VARCHAR2(1);
 59      l_target_owner    VARCHAR2(128);
 60      l_target_table    VARCHAR2(128);
 61      l_sql             CLOB;
 62      l_rows_available  NUMBER := 0;
 63      l_agent_procedure VARCHAR2(400);
 64      l_units           NUMBER := 0;
 65      l_truncated       NUMBER := 0;
 66      l_preserved       NUMBER := 0;
 67      l_tables          NUMBER := 0;
 68      l_sql_rows        NUMBER;
 69      l_summary         CLOB := NULL;
 70      l_table_summary   CLOB;
 71      l_bad_tables      NUMBER := 0;
 72      l_last_business_date_calc VARCHAR2(30);
 73      l_days_online             VARCHAR2(30);
 74      l_cutoff_date             VARCHAR2(30);
 75    BEGIN
 76      l_execute_flag := fn_normalize_execute(p_execute);
 77      l_target_owner := fn_normalize_name(p_target_owner);
 78      l_target_table := fn_normalize_name(p_target_table_name);
 79      l_run_id := PKG_ARCHIVE_LOG.fn_create_run('TRUNCATE', NULL, NULL, NULL, l_execute_flag);
 80      l_log_id := PKG_ARCHIVE_LOG.fn_get_log_id(l_run_id);
 81  
 82      PKG_ARCHIVE_LOG.prc_log_message
 83      (
 84        p_run_id  => l_run_id,
 85        p_log_msg => 'Started TRUNCATE with parameters:' || CHR(10) ||
 86                     '  p_execute           => ' || l_execute_flag || CHR(10) ||
 87                     '  p_target_owner      => ' || NVL(l_target_owner, '<ALL>') || CHR(10) ||
 88                     '  p_target_table_name => ' || NVL(l_target_table, '<ALL>')
 89      );
 90  
 91      -- FOR bad IN (
 92      --   SELECT source_db_link, source_owner, source_table_name, retention_rule, retention_calc
 93      --     FROM tw_archive_tables
 94      --    WHERE retention_calc LIKE 'ERROR:%'
 95      --      AND (l_target_owner IS NULL OR target_owner = l_target_owner)
 96      --      AND (l_target_table IS NULL OR target_table_name = l_target_table)
 97      -- ) LOOP
 98      --   PKG_ARCHIVE_LOG.prc_log_message
 99      --   (
100      --     p_run_id  => l_run_id,
101      --     p_log_msg => 'ERROR: table ' || bad.source_owner || '.' || bad.source_table_name ||
102      --                  ' retention_rule "' || bad.retention_rule || '" - ' || bad.retention_calc
103      --   );
104      --   l_bad_tables := l_bad_tables + 1;
105      -- END LOOP;
106  
107      FOR bad IN (
108        SELECT source_db_link, source_owner, source_table_name, preserve_rule, preserve_calc
109          FROM tw_archive_tables
110         WHERE preserve_calc LIKE 'ERROR:%'
111           AND (l_target_owner IS NULL OR target_owner = l_target_owner)
112           AND (l_target_table IS NULL OR target_table_name = l_target_table)
113      ) LOOP
114        PKG_ARCHIVE_LOG.prc_log_message
115        (
116          p_run_id  => l_run_id,
117          p_log_msg => 'ERROR: table ' || bad.source_owner || '.' || bad.source_table_name ||
118                       ' preserve_rule "' || bad.preserve_rule || '" - ' || bad.preserve_calc
119        );
120        l_bad_tables := l_bad_tables + 1;
121      END LOOP;
122  
123      IF l_bad_tables > 0 THEN
124        PKG_ARCHIVE_LOG.prc_log_message
125        (
126          p_run_id  => l_run_id,
127          p_log_msg => 'ERROR: ' || l_bad_tables || ' table(s) with invalid retention or preserve rule - aborting TRUNCATE'
128        );
129        PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', l_bad_tables || ' table(s) with invalid retention or preserve rule');
130        RAISE_APPLICATION_ERROR(-20001, l_bad_tables || ' table(s) with invalid retention or preserve rule. Fix before retrying.');
131      END IF;
132  
133      l_sql :=
134        'SELECT COUNT(*) ' ||
135        '  FROM TW_ARCHIVE_TRUNCATE_PARTITIONS_VW ' ||
136        ' WHERE (:1 IS NULL OR target_owner = :1) ' ||
137        '   AND (:2 IS NULL OR target_table_name = :2)';
138  
139      l_rows_available := PKG_SQL.fn_run_into_sql_in_bind
140      (
141        p_log_id     => l_log_id,
142        p_sql        => l_sql,
143        p_array_bind => SYS.ODCIVARCHAR2LIST(l_target_owner, l_target_table),
144        p_execute    => 'Y'
145      );
146  
147      FOR t IN (
148        SELECT DISTINCT source_db_link,
149               source_agent_schema,
150               source_owner,
151               source_table_name,
152               target_owner,
153               target_table_name
154          FROM TW_ARCHIVE_TRUNCATE_PARTITIONS_VW
155         WHERE (l_target_owner IS NULL OR target_owner = l_target_owner)
156           AND (l_target_table IS NULL OR target_table_name = l_target_table)
157         ORDER BY source_db_link, source_owner, source_table_name
158      ) LOOP
159        l_tables := l_tables + 1;
160        l_table_summary := NULL;
161        l_agent_procedure := fn_qualified_agent_procedure(t.source_agent_schema, t.source_db_link);
162        l_sql := 'BEGIN ' || l_agent_procedure || '(:1, :2, :3, :4, :5, :6); END;';
163  
164        SELECT TO_CHAR(FN_ARCHIVE_HIGH_VALUE_DATE(a.last_business_date)),
165               TO_CHAR(a.days_online),
166               TO_CHAR(FN_ARCHIVE_HIGH_VALUE_DATE(a.last_business_date) - a.days_online)
167          INTO l_last_business_date_calc, l_days_online, l_cutoff_date
168          FROM tw_archive_tables a
169         WHERE a.source_db_link = t.source_db_link
170           AND a.source_owner = t.source_owner
171           AND a.source_table_name = t.source_table_name;
172  
173        FOR r IN (
174          SELECT p.*
175            FROM TW_ARCHIVE_TRUNCATE_PARTITIONS_VW p
176           WHERE p.source_db_link = t.source_db_link
177             AND p.source_owner = t.source_owner
178             AND p.source_table_name = t.source_table_name
179             AND p.target_owner = t.target_owner
180             AND p.target_table_name = t.target_table_name
181           ORDER BY p.partition_high_value, p.subpartition_high_value
182        ) LOOP
183          l_units := l_units + 1;
184  
185          IF r.preserve_date IS NOT NULL THEN
186            DBMS_OUTPUT.PUT_LINE('PRESERVE ' || r.SOURCE_DB_LINK || '.' || r.SOURCE_OWNER || '.' ||
187                                 r.SOURCE_TABLE_NAME || ' source=' || r.SOURCE_PARTITION_NAME ||
188                                 CASE WHEN r.SOURCE_SUBPARTITION_NAME <> '#' THEN '.' || r.SOURCE_SUBPARTITION_NAME ELSE NULL END ||
189                                 ' target=' || r.PARTITION_NAME ||
190                                 CASE WHEN r.SUBPARTITION_NAME <> '#' THEN '.' || r.SUBPARTITION_NAME ELSE NULL END ||
191                                 ' preserve_date=' || TO_CHAR(r.preserve_date, 'YYYY-MM-DD') ||
192                                 ' execute=' || l_execute_flag);
193            l_preserved := l_preserved + 1;
194          ELSE
195            DBMS_OUTPUT.PUT_LINE('TRUNCATE ' || r.SOURCE_DB_LINK || '.' || r.SOURCE_OWNER || '.' ||
196                                 r.SOURCE_TABLE_NAME || ' source=' || r.SOURCE_PARTITION_NAME ||
197                                 CASE WHEN r.SOURCE_SUBPARTITION_NAME <> '#' THEN '.' || r.SOURCE_SUBPARTITION_NAME ELSE NULL END ||
198                                 ' target=' || r.PARTITION_NAME ||
199                                 CASE WHEN r.SUBPARTITION_NAME <> '#' THEN '.' || r.SUBPARTITION_NAME ELSE NULL END ||
200                                 ' cutoff=' || TO_CHAR(r.CUTOFF_DATE, 'YYYY-MM-DD') ||
201                                 ' execute=' || l_execute_flag);
202  
203            l_sql_rows := PKG_SQL.fn_run_sql_in_bind
204            (
205              p_log_id     => l_log_id,
206              p_sql        => l_sql,
207              p_array_bind => SYS.ODCIVARCHAR2LIST
208                              (
209                                r.SOURCE_OWNER,
210                                r.SOURCE_TABLE_NAME,
211                                r.SOURCE_PARTITION_NAME,
212                                CASE WHEN r.SOURCE_SUBPARTITION_NAME = '#' THEN NULL ELSE r.SOURCE_SUBPARTITION_NAME END,
213                                'TRUNCATE',
214                                l_execute_flag
215                              ),
216              p_execute    => l_execute_flag
217            );
218  
219            IF l_execute_flag = 'Y' THEN
220              UPDATE TW_ARCHIVE_PARTITIONS
221                 SET TRUNCATE_STATUS = 'Y',
222                     LAST_RUN_ID = l_run_id,
223                     ERROR_MESSAGE = NULL,
224                     UPDATED_AT = SYSTIMESTAMP
225               WHERE SOURCE_DB_LINK = r.SOURCE_DB_LINK
226                 AND SOURCE_OWNER = r.SOURCE_OWNER
227                 AND SOURCE_TABLE_NAME = r.SOURCE_TABLE_NAME
228                 AND PARTITION_HIGH_VALUE = r.PARTITION_HIGH_VALUE
229                 AND SUBPARTITION_HIGH_VALUE = r.SUBPARTITION_HIGH_VALUE;
230  
231              l_truncated := l_truncated + SQL%ROWCOUNT;
232              COMMIT;
233            END IF;
234          END IF;
235  
236          l_table_summary := l_table_summary ||
237            TO_CLOB(PKG_ARCHIVE_LOG.fn_summary_cell(CASE WHEN r.preserve_date IS NOT NULL THEN
238              'PRESERVED per MAX_preserve_date=' || TO_CHAR(r.preserve_date, 'YYYY-MM-DD')
239            ELSE
240              CASE WHEN l_execute_flag = 'Y' THEN 'TRUNCATED' ELSE 'SKIP' END
241  END)) || '|' ||
242            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_partition_name) || '|' ||
243            PKG_ARCHIVE_LOG.fn_summary_cell(r.source_subpartition_name) || '|' ||
244            PKG_ARCHIVE_LOG.fn_summary_cell(r.partition_name) || '|' ||
245            PKG_ARCHIVE_LOG.fn_summary_cell(r.subpartition_name) || '|' ||
246            PKG_ARCHIVE_LOG.fn_summary_cell(r.partition_high_value) || '|' ||
247            PKG_ARCHIVE_LOG.fn_summary_cell(r.subpartition_high_value) || '|' ||
248            PKG_ARCHIVE_LOG.fn_summary_cell(r.archive_status) || '|' ||
249            PKG_ARCHIVE_LOG.fn_summary_cell(r.quality_status) || '|' ||
250            PKG_ARCHIVE_LOG.fn_summary_cell(CASE WHEN l_execute_flag = 'Y' THEN 'Y' ELSE 'N' END) || '|' ||
251            PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(r.source_row_count)) || '|' ||
252            PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(r.target_row_count)) || '|' ||
253            PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(r.preserve_date, 'YYYY-MM-DD')) ||
254            CHR(10);
255        END LOOP; -- FOR r
256  
257        IF l_table_summary IS NOT NULL THEN
258          l_summary := l_summary ||
259            '=== TABLE: ' || t.source_db_link || '.' || t.source_owner || '.' || t.source_table_name || ' ===' || CHR(10) || CHR(10) ||
260            PKG_SQL.fn_format_table(
261              p_columns => 'SOURCE_DB_LINK|TABLE_OWNER|TABLE_NAME|EXECUTE|LAST_BUSINESS_DATE|DAYS_ONLINE|CUTOFF_DATE',
262              p_rows    => PKG_ARCHIVE_LOG.fn_summary_cell(t.source_db_link) || '|' ||
263                           PKG_ARCHIVE_LOG.fn_summary_cell(t.source_owner) || '|' ||
264                           PKG_ARCHIVE_LOG.fn_summary_cell(t.source_table_name) || '|' ||
265                           PKG_ARCHIVE_LOG.fn_summary_cell(l_execute_flag) || '|' ||
266                           PKG_ARCHIVE_LOG.fn_summary_cell(l_last_business_date_calc) || '|' ||
267                           PKG_ARCHIVE_LOG.fn_summary_cell(l_days_online) || '|' ||
268                           PKG_ARCHIVE_LOG.fn_summary_cell(l_cutoff_date) || CHR(10)
269            ) || CHR(10) ||
270            PKG_SQL.fn_format_table(
271              p_columns    => 'NOTE|SOURCE_PARTITION_NAME|SOURCE_SUBPARTITION_NAME|PARTITION_NAME|SUBPARTITION_NAME|PARTITION_HIGH_VALUE|SUBPARTITION_HIGH_VALUE|ARCHIVE_STATUS|QUALITY_STATUS|TRUNCATE_STATUS|SOURCE_ROW_COUNT|TARGET_ROW_COUNT|MAX_PRESERVE_DATE',
272              p_rows       => l_table_summary
273            ) || CHR(10);
274        END IF;
275      END LOOP; -- FOR t
276  
277      DBMS_OUTPUT.PUT_LINE(
278        'TRUNCATE tables=' || l_tables ||
279        ' units=' || l_units ||
280        ' found=' || l_rows_available ||
281        ' truncated=' || l_truncated ||
282        ' preserved=' || l_preserved ||
283        ' target_owner=' || NVL(l_target_owner, '<ALL>') ||
284        ' target_table=' || NVL(l_target_table, '<ALL>') ||
285        ' execute=' || l_execute_flag
286      );
287  
288      IF l_summary IS NOT NULL THEN
289        PKG_ARCHIVE_LOG.prc_log_message(l_run_id, l_summary, 'SUMMARY');
290      END IF;
291  
292      PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
293    EXCEPTION
294      WHEN OTHERS THEN
295        IF l_run_id IS NOT NULL THEN
296          PKG_ARCHIVE_LOG.prc_log_error_stack(l_run_id);
297          PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', SQLERRM);
298        END IF;
299        RAISE;
300    END prc_truncate;
301  END PKG_ARCHIVE_TRUNCATE;
