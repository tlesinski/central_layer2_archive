 51      IF p_source_db_link IS NOT NULL AND UPPER(TRIM(p_source_db_link)) NOT IN ('LOCAL', 'NONE') THEN
 52        l_name := l_name || '@' || PKG_SQL.fn_assert_simple_name(p_source_db_link);
 53      END IF;
 54      RETURN l_name;
