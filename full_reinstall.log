 19  
 20  --Procedure prc_init_log just pre declaration
 21  
 22  PROCEDURE prc_init_log
 23  (
 24  p_force IN VARCHAR2 DEFAULT 'N'
 25  );
 26  
 27  PROCEDURE prc_log_cleanup_table;
 28  
 29  FUNCTION fn_generate_json_log
 30  (
 31    p_log_msg	  IN CLOB,
 32    p_log_type	  IN VARCHAR2,
 33    p_log_date	  IN VARCHAR2
 34  )
 35  RETURN CLOB
 36  IS
 37    l_json_entry CLOB;
 38  BEGIN
 39    l_json_entry := JSON_OBJECT(
 40      'type' VALUE p_log_type,
 41      'timestamp' VALUE p_log_date,
 42      'message' VALUE p_log_msg
 43    );
 44  
 45    -- Wrap log entry within "log_entries" array to support multiple entries
 46    RETURN l_json_entry;
 47  END fn_generate_json_log;
 48  
 49  --Procedure prc_log
 50  -- base logging message
 51  
 52  PROCEDURE prc_log
 53  (
 54    p_log_id	  IN NUMBER,
 55    p_log_msg	  IN CLOB,
 56    p_log_lvl	  IN VARCHAR2 DEFAULT 'N',
 57    p_mstr_log_id   IN NUMBER DEFAULT NULL,
 58    p_log_categ	  IN VARCHAR2 DEFAULT NULL,
 59    p_mstr_fun	  IN VARCHAR2 DEFAULT NULL,
 60    p_log_sttus	  IN VARCHAR2 DEFAULT NULL,
 61    p_start_date	  IN DATE DEFAULT NULL,
 62    p_end_date	  IN DATE DEFAULT NULL,
 63    p_last_err_code IN VARCHAR2 DEFAULT NULL,
 64    p_last_err_desc IN VARCHAR2 DEFAULT NULL,
 65    p_log_type	  IN VARCHAR2 DEFAULT 'TEXT'
 66  )
 67  IS
 68    PRAGMA autonomous_transaction;
 69    l_curr_schema VARCHAR2(128) := sys_context('USERENV', 'CURRENT_SCHEMA');
 70    l_today	VARCHAR2(10)  := TO_CHAR(SYSDATE, 'YYYYMMDD');
 71    l_log_categ	VARCHAR2(128);
 72    l_msg 	CLOB;
 73    l_msg_json	CLOB;
 74    l_sysdate	VARCHAR2(64);
 75    l_sql 	CLOB;
 76    l_mstr_log_id NUMBER;
 77    l_log_id	NUMBER;
 78  BEGIN
 79    l_sysdate := to_char(SYSDATE, g_date_formt_const, 'nls_date_language = ''' || g_lang_const || '''' );
 80  
 81    --daily log categ
 82    l_log_categ := 'LOG_' || l_curr_schema || '_' || l_today ||'.log';
 83  
 84    l_msg := to_clob(chr(10) || l_sysdate || ' | ' ) || p_log_msg || to_clob(chr(10));
 85  
 86    l_msg_json := fn_generate_json_log(p_log_msg => p_log_msg, p_log_date => l_sysdate, p_log_type => p_log_type);
 87  
 88    IF p_log_lvl = 'N' OR ( p_log_lvl = 'D' AND g_log_lvl = 'D' ) THEN
 89      IF p_log_id IS NOT NULL THEN
 90        l_log_id := 0;
 91  
 92        l_sql := 'MERGE INTO ' || g_log_table_name || q'! a
 93        USING
 94        (
 95  	SELECT
 96  	   nvl(:p_mstr_log_id, :p_log_id)	 AS mstr_log_id
 97  	  ,:p_log_id				 AS log_id
 98  	  ,:p_log_categ 			 AS log_categ
 99  	  ,:p_mstr_fun				 AS mstr_fun
100  	  ,:p_log_sttus 			 AS log_sttus
101  	  ,:p_start_date			 AS start_date
102  	  ,:p_end_date				 AS end_date
103  	  ,:p_log_msg				 AS log_msg
104  	  ,:p_log_json				 AS log_json
105  	  ,:p_last_err_code			 AS last_err_code
106  	  ,:p_last_err_desc			 AS last_err_desc
107  	  ,sys_context('userenv','instance')	 AS inst_id
108  	  ,sys_context('userenv','sid') 	 AS sid
109  	  ,sys_context('userenv','sessionid')	 AS serial#
110  	  ,sys_context('userenv','client_info')  AS client_info
111  	  ,sys_context('userenv','module')	 AS module
112  	FROM dual
113        ) b
114        ON
115        (
116  	a.mstr_log_id = b.mstr_log_id
117  	AND a.log_id = b.log_id
118        )
119        WHEN MATCHED THEN
120  	UPDATE
121  	SET
122  	  a.log_categ	  = nvl(b.log_categ, a.log_categ),
123  	  a.mstr_fun	  = nvl(b.mstr_fun, a.mstr_fun),
124  	  a.log_sttus	  = nvl(b.log_sttus, a.log_sttus),
125  	  a.start_date	  = nvl(b.start_date, a.start_date),
126  	  a.end_date	  = nvl(b.end_date, a.end_date),
127  	  a.log_msg	  = a.log_msg || b.log_msg,
128  	  a.log_json	  = rtrim(a.log_json,']') || to_clob(',') || b.log_json ||to_clob(']'),
129  	  a.last_err_code = nvl(b.last_err_code, a.last_err_code),
130  	  a.last_err_desc = nvl(b.last_err_desc, a.last_err_desc),
131  	  a.last_updt_dt  = SYSDATE,
132  	  a.last_updt_by  = sys_context('USERENV','SESSION_USER')
133        WHEN NOT MATCHED THEN
134  	INSERT
135  	(
136  	   mstr_log_id
137  	  ,log_id
138  	  ,log_categ
139  	  ,mstr_fun
140  	  ,log_sttus
141  	  ,start_date
142  	  ,end_date
143  	  ,log_msg
144  	  ,log_json
145  	  ,last_err_code
146  	  ,last_err_desc
147  	  ,inst_id
148  	  ,sid
149  	  ,serial#
150  	  ,client_info
151  	  ,module
152  	  ,crtn_dt
153  	  ,crtn_by
154  	  ,last_updt_dt
155  	  ,last_updt_by
156  	)
157  	VALUES
158  	(
159  	   b.mstr_log_id
160  	  ,b.log_id
161  	  ,b.log_categ
162  	  ,b.mstr_fun
163  	  ,nvl(b.log_sttus, :g_sttus_undefined_const)
164  	  ,nvl(b.start_date, SYSDATE)
165  	  ,b.end_date
166  	  ,b.log_msg
167  	  ,to_clob('[')||b.log_json||to_clob(']')
168  	  ,b.last_err_code
169  	  ,b.last_err_desc
170  	  ,b.inst_id
171  	  ,b.sid
172  	  ,b.serial#
173  	  ,b.client_info
174  	  ,b.module
175  	  ,SYSDATE
176  	  ,sys_context('USERENV','SESSION_USER')
177  	  ,SYSDATE
178  	  ,sys_context('USERENV','SESSION_USER')
179  	)!';
180  
181        BEGIN
182  	EXECUTE IMMEDIATE l_sql
183  	USING
184  	   p_mstr_log_id
185  	  ,p_log_id
186  	  ,p_log_id
187  	  ,p_log_categ
188  	  ,p_mstr_fun
189  	  ,p_log_sttus
190  	  ,p_start_date
191  	  ,p_end_date
192  	  ,l_msg
193  	  ,l_msg_json
194  	  ,p_last_err_code
195  	  ,p_last_err_desc
196  	  ,pkg_tl_logging.g_sttus_undefined_const;
197  
198  	COMMIT;
199        EXCEPTION
200  	WHEN OTHERS THEN
201  	  prc_init_log( p_force => 'Y' );
202  
203  	  EXECUTE IMMEDIATE l_sql
204  	  USING
205  	     p_mstr_log_id
206  	    ,p_log_id
207  	    ,p_log_id
208  	    ,p_log_categ
209  	    ,p_mstr_fun
210  	    ,p_log_sttus
211  	    ,p_start_date
212  	    ,p_end_date
213  	    ,l_msg
214  	    ,l_msg_json
215  	    ,p_last_err_code
216  	    ,p_last_err_desc
217  	    ,pkg_tl_logging.g_sttus_undefined_const;
218  
219  	  COMMIT;
220        END;
221      END IF;
222    END IF;
223  END prc_log;
