SQL> @deploy/test_support/dat.body.sql
SQL> CREATE OR REPLACE PACKAGE BODY DAT
  2  AS
  3    /*
  4      Package      : DAT
  5      Developer    : Tomasz Lesinski
  6      Date         : 2026-05-28
  7      Purpose      : Fake business date provider for archive tests.
  8                     This package is intentionally test support, not archiver core.
  9  
 10      Change History:
 11      ------------------------------------------------------------------------------
 12      Version    Date         Programmer         Description
 13      ------------------------------------------------------------------------------
 14      1.0        2026-05-28   Tomasz Lesinski    Initial version
 15    */
 16    FUNCTION fn_eod RETURN DATE
 17    IS
 18    BEGIN
 19      RETURN TRUNC(SYSDATE);
 20    END fn_eod;
 21  
 22    FUNCTION fn_boy RETURN DATE
 23    IS
 24      l_date DATE := TRUNC(SYSDATE, 'YYYY');
 25    BEGIN
 26      WHILE TO_CHAR(l_date, 'DY', 'NLS_DATE_LANGUAGE=AMERICAN') IN ('SAT', 'SUN') LOOP
 27        l_date := l_date + 1;
 28      END LOOP;
 29  
 30      RETURN l_date;
 31    END fn_boy;
 32  
 33    FUNCTION fn_eoy RETURN DATE
 34    IS
 35      l_date DATE := TRUNC(SYSDATE, 'YYYY') - 1;
 36    BEGIN
 37      WHILE TO_CHAR(l_date, 'DY', 'NLS_DATE_LANGUAGE=AMERICAN') IN ('SAT', 'SUN') LOOP
 38        l_date := l_date - 1;
 39      END LOOP;
 40  
 41      RETURN l_date;
 42    END fn_eoy;
 43  END DAT;
 44  /

