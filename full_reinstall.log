SQL> @layer1_agent/packages/pkg_archive_agent.body.sql
SQL> CREATE OR REPLACE PACKAGE BODY PKG_ARCHIVE_AGENT
  2  AS
  3    /*
  4      Package      : PKG_ARCHIVE_AGENT
  5      Developer    : Tomasz Lesinski
  6      Date         : 2026-05-28
  7      Purpose      : Layer 1 archive agent - exposes partition info, row count,
  8                     cleanup unit, and health check operations
  9  
 10      Prerequisite : ARCHIVE_PARTITION_INFO_OBJ, ARCHIVE_PARTITION_INFO_TAB
 11  
 12      Change History:
 13      ------------------------------------------------------------------------------
 14      Version    Date         Programmer         Description
 15      ------------------------------------------------------------------------------
 16      1.0        2026-05-28   Tomasz Lesinski    Initial version
 17    */
 18    FUNCTION fn_normalize_execute
 19    (
 20      p_execute IN VARCHAR2
 21    )
 22    RETURN VARCHAR2
 23    IS
 24    BEGIN
 25      IF UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN
 26        RETURN 'Y';
 27      END IF;
 28  
 29      RETURN 'N';
 30    END fn_normalize_execute;
 31  
 32    FUNCTION fn_assert_simple_name
 33    (
 34      p_name IN VARCHAR2
 35    )
 36    RETURN VARCHAR2
 37    IS
 38    BEGIN
 39      RETURN DBMS_ASSERT.SIMPLE_SQL_NAME(UPPER(TRIM(p_name)));
 40    END fn_assert_simple_name;
 41  
 42    FUNCTION fn_assert_qualified_table
 43    (
 44      p_owner      IN VARCHAR2,
 45      p_table_name IN VARCHAR2
 46    )
 47    RETURN VARCHAR2
 48    IS
 49    BEGIN
 50      RETURN fn_assert_simple_name(p_owner) || '.' || fn_assert_simple_name(p_table_name);
 51    END fn_assert_qualified_table;
 52  
 53    FUNCTION fn_get_partition_info
 54    (
 55      p_owner      IN VARCHAR2,
 56      p_table_name IN VARCHAR2
 57    )
 58    RETURN ARCHIVE_PARTITION_INFO_TAB PIPELINED
 59    IS
 60      l_partition_high_value    LONG;
 61      l_subpartition_high_value LONG;
 62      l_row                     ARCHIVE_PARTITION_INFO_OBJ :=
 63                                  ARCHIVE_PARTITION_INFO_OBJ(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
 64      l_cursor                  SYS_REFCURSOR;
 65      l_sql                     VARCHAR2(32767);
 66      l_owner                   VARCHAR2(128);
 67      l_table_name              VARCHAR2(128);
 68    BEGIN
 69      IF p_owner IS NULL OR p_table_name IS NULL THEN
 70        raise_application_error(-20001, 'Owner and table name are required');
 71      END IF;
 72  
 73      l_owner := fn_assert_simple_name(p_owner);
 74      l_table_name := fn_assert_simple_name(p_table_name);
 75  
 76      l_sql := q'[
 77        SELECT p.table_owner,
 78               p.table_name,
 79               p.partition_name,
 80               s.subpartition_name,
 81               p.high_value,
 82               s.high_value,
 83               p.partition_position,
 84               s.subpartition_position
 85          FROM all_tab_partitions p
 86          LEFT JOIN all_tab_subpartitions s
 87            ON p.table_owner = s.table_owner
 88           AND p.table_name = s.table_name
 89           AND p.partition_name = s.partition_name
 90         WHERE p.table_owner = :owner
 91           AND p.table_name = :table_name
 92         ORDER BY p.partition_position, s.subpartition_position
 93      ]';
 94  
 95      OPEN l_cursor FOR l_sql USING l_owner, l_table_name;
 96  
 97      LOOP
 98        FETCH l_cursor INTO l_row.SCHEMA_NAME,
 99                            l_row.TABLE_NAME,
100                            l_row.PARTITION_NAME,
101                            l_row.SUBPARTITION_NAME,
102                            l_partition_high_value,
103                            l_subpartition_high_value,
104                            l_row.PARTITION_POSITION,
105                            l_row.SUBPARTITION_POSITION;
106        EXIT WHEN l_cursor%NOTFOUND;
107  
108        l_row.PARTITION_HIGH_VALUE := DBMS_LOB.SUBSTR(TO_CLOB(l_partition_high_value), 4000, 1);
109        l_row.SUBPARTITION_HIGH_VALUE := DBMS_LOB.SUBSTR(TO_CLOB(l_subpartition_high_value), 4000, 1);
110  
111        PIPE ROW(l_row);
112      END LOOP;
113  
114      CLOSE l_cursor;
115      RETURN;
116    EXCEPTION
117      WHEN OTHERS THEN
118        IF l_cursor%ISOPEN THEN
119          CLOSE l_cursor;
120        END IF;
121  
122        RAISE;
123    END fn_get_partition_info;
124  
125    FUNCTION fn_get_row_count
126    (
127      p_owner             IN VARCHAR2,
128      p_table_name        IN VARCHAR2,
129      p_partition_name    IN VARCHAR2,
130      p_subpartition_name IN VARCHAR2 DEFAULT NULL
131    )
132    RETURN NUMBER
133    IS
134      l_sql        VARCHAR2(32767);
135      l_row_count  NUMBER;
136      l_table_name VARCHAR2(300);
137    BEGIN
138      IF p_owner IS NULL OR p_table_name IS NULL OR p_partition_name IS NULL THEN
139        raise_application_error(-20002, 'Owner, table name, and partition name are required');
140      END IF;
141  
142      l_table_name := fn_assert_qualified_table(p_owner, p_table_name);
143  
144      IF p_subpartition_name IS NOT NULL THEN
145        l_sql := 'SELECT COUNT(*) FROM ' || l_table_name ||
146                 ' SUBPARTITION (' || fn_assert_simple_name(p_subpartition_name) || ')';
147      ELSE
148        l_sql := 'SELECT COUNT(*) FROM ' || l_table_name ||
149                 ' PARTITION (' || fn_assert_simple_name(p_partition_name) || ')';
150      END IF;
151  
152      EXECUTE IMMEDIATE l_sql INTO l_row_count;
153  
154      RETURN l_row_count;
155    END fn_get_row_count;
156  
157    PROCEDURE prc_cleanup_unit
158    (
159      p_owner             IN VARCHAR2,
160      p_table_name        IN VARCHAR2,
161      p_partition_name    IN VARCHAR2,
162      p_subpartition_name IN VARCHAR2 DEFAULT NULL,
163      p_mode              IN VARCHAR2 DEFAULT 'TRUNCATE',
164      p_execute           IN VARCHAR2 DEFAULT 'N'
165    )
166    IS
167      l_sql        VARCHAR2(32767);
168      l_table_name VARCHAR2(300);
169      l_mode       VARCHAR2(20);
170    BEGIN
171      IF p_owner IS NULL OR p_table_name IS NULL OR p_partition_name IS NULL THEN
172        raise_application_error(-20003, 'Owner, table name, and partition name are required');
173      END IF;
174  
175      l_mode := UPPER(NVL(TRIM(p_mode), 'TRUNCATE'));
176  
177      IF l_mode NOT IN ('TRUNCATE', 'DROP', 'DELETE') THEN
178        raise_application_error(-20004, 'Unsupported cleanup mode: ' || p_mode);
179      END IF;
180  
181      l_table_name := fn_assert_qualified_table(p_owner, p_table_name);
182  
183      IF l_mode = 'DELETE' THEN
184        IF p_subpartition_name IS NOT NULL THEN
185          l_sql := 'DELETE FROM ' || l_table_name ||
186                   ' SUBPARTITION (' || fn_assert_simple_name(p_subpartition_name) || ')';
187        ELSE
188          l_sql := 'DELETE FROM ' || l_table_name ||
189                   ' PARTITION (' || fn_assert_simple_name(p_partition_name) || ')';
190        END IF;
191      ELSIF l_mode = 'TRUNCATE' THEN
192        IF p_subpartition_name IS NOT NULL THEN
193          l_sql := 'ALTER TABLE ' || l_table_name ||
194                   ' TRUNCATE SUBPARTITION ' || fn_assert_simple_name(p_subpartition_name) ||
195                   ' UPDATE GLOBAL INDEXES';
196        ELSE
197          l_sql := 'ALTER TABLE ' || l_table_name ||
198                   ' TRUNCATE PARTITION ' || fn_assert_simple_name(p_partition_name) ||
199                   ' UPDATE GLOBAL INDEXES';
200        END IF;
201      ELSIF p_subpartition_name IS NOT NULL THEN
202        l_sql := 'ALTER TABLE ' || l_table_name || ' ' || l_mode ||
203                 ' SUBPARTITION ' || fn_assert_simple_name(p_subpartition_name) ||
204                 ' UPDATE GLOBAL INDEXES';
205      ELSE
206        l_sql := 'ALTER TABLE ' || l_table_name || ' ' || l_mode ||
207                 ' PARTITION ' || fn_assert_simple_name(p_partition_name) ||
208                 ' UPDATE GLOBAL INDEXES';
209      END IF;
210  
211      DBMS_OUTPUT.PUT_LINE(l_sql);
212  
213      IF fn_normalize_execute(p_execute) = 'Y' THEN
214        EXECUTE IMMEDIATE l_sql;
215      END IF;
216    END prc_cleanup_unit;
217  
218    FUNCTION fn_health_check
219    RETURN VARCHAR2
220    IS
221    BEGIN
222      RETURN 'OK:' || SYS_CONTEXT('USERENV', 'CURRENT_SCHEMA');
223    END fn_health_check;
224  END PKG_ARCHIVE_AGENT;
225  /

