225  --Procedure prc_error_stack
226  -- dumps oracle stack if error occures into table MD_PRCSS_LOG
227  
228    PROCEDURE prc_error_stack
229    (
230      p_log_id IN NUMBER,
231      p_mstr_log_id IN NUMBER DEFAULT NULL
232    )
233    IS
234      l_sqlcode NUMBER;
235      l_sqlerrm VARCHAR2(255);
236      l_message CLOB;
237    BEGIN
238      l_sqlcode := sqlcode;
239      l_sqlerrm := substr(SQLERRM, 1, 255);
240  
241      l_message := chr(10) ||
242        '===================================================================' || chr(10) ||
243        ' SQLCODE:	 ' || l_sqlcode 				    || chr(10) ||
244        ' SQLERRM:	 ' || l_sqlerrm 				    || chr(10) ||
245        '===================================================================' || CHR(10) ||
246        ' Call stack:	 ' || dbms_utility.format_call_stack()		    || CHR(10) ||
247        '===================================================================' || chr(10) ||
248        ' Error stack:	 ' || dbms_utility.format_error_stack() 	    || CHR(10) ||
249        '===================================================================' || CHR(10) ||
250        ' Error backtrace: ' || dbms_utility.format_error_backtrace	    || CHR(10) ||
251        '===================================================================';
252  
253      dbms_output.put_line(l_message);
254  
255      prc_log
256      (
257        p_mstr_log_id    => p_mstr_log_id,
258        p_log_id	       => p_log_id,
259        p_log_sttus      => pkg_tl_logging.g_sttus_error_const,
260        p_end_date       => SYSDATE,
261        p_log_msg        => l_message,
262        p_last_err_code  => l_sqlcode,
263        p_last_err_desc  => l_sqlerrm,
264        p_log_type       => 'ERROR'
265      );
266    END prc_error_stack;
