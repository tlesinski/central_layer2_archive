112    FUNCTION fn_run_into_sql
113    (
114      p_log_id  IN NUMBER,
115      p_sql     IN CLOB,
116      p_execute IN VARCHAR2 DEFAULT 'Y'
117    )
118    RETURN NUMBER
119    IS
120      l_result NUMBER;
121      l_sql    VARCHAR2(32767);
122    BEGIN
123      IF p_sql IS NULL THEN
124        raise_application_error(-20001, 'SQL text is required');
125      END IF;
126  
127      prc_log_sql(p_log_id => p_log_id, p_sql => p_sql, p_execute => p_execute);
128  
129      IF fn_normalize_execute(p_execute) = 'N' THEN
130        RETURN NULL;
131      END IF;
132  
133      l_sql := DBMS_LOB.SUBSTR(p_sql, 32767, 1);
134      EXECUTE IMMEDIATE l_sql INTO l_result;
135  
136      RETURN l_result;
137    END fn_run_into_sql;
138  
139    FUNCTION fn_run_sql
140    (
141      p_log_id  IN NUMBER,
142      p_sql     IN CLOB,
143      p_execute IN VARCHAR2 DEFAULT 'Y'
144    )
145    RETURN NUMBER
146    IS
147      l_sql VARCHAR2(32767);
148    BEGIN
149      IF p_sql IS NULL THEN
150        raise_application_error(-20001, 'SQL text is required');
151      END IF;
152  
153      prc_log_sql(p_log_id => p_log_id, p_sql => p_sql, p_execute => p_execute);
154  
155      IF fn_normalize_execute(p_execute) = 'N' THEN
156        RETURN 0;
157      END IF;
158  
159      l_sql := DBMS_LOB.SUBSTR(p_sql, 32767, 1);
160      EXECUTE IMMEDIATE l_sql;
161  
162      RETURN SQL%ROWCOUNT;
163    END fn_run_sql;
