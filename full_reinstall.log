150      END IF;
151  
152      prc_log_sql(p_log_id => p_log_id, p_sql => p_sql, p_execute => p_execute);
153  
154      IF fn_normalize_execute(p_execute) = 'N' THEN
155        RETURN 0;
156      END IF;
157  
158      l_sql := DBMS_LOB.SUBSTR(p_sql, 32767, 1);
159      EXECUTE IMMEDIATE l_sql;
160  
161      RETURN SQL%ROWCOUNT;
162    END fn_run_sql;
163  
164    FUNCTION fn_run_sql_in_bind
165    (
166      p_log_id     IN NUMBER,
167      p_sql        IN CLOB,
168      p_array_bind IN SYS.ODCIVARCHAR2LIST,
169      p_execute    IN VARCHAR2 DEFAULT 'Y'
170    )
171    RETURN NUMBER
172    IS
173      l_cursor_id INTEGER;
174      l_rows      INTEGER;
175      l_attempt   NUMBER := 0;
176    BEGIN
177      IF p_sql IS NULL THEN
178        raise_application_error(-20001, 'SQL text is required');
179      END IF;
180  
181      prc_log_sql(p_log_id => p_log_id, p_sql => p_sql, p_execute => p_execute);
182  
183      IF p_log_id IS NOT NULL AND p_array_bind IS NOT NULL THEN
184        PKG_TL_LOGGING.prc_log
185        (
186          p_log_id    => p_log_id,
187          p_log_msg   => 'Bind count: ' || p_array_bind.COUNT,
188          p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
189          p_log_type  => 'SQL_BIND'
190        );
191  
192        FOR i IN 1 .. p_array_bind.COUNT LOOP
193          PKG_TL_LOGGING.prc_log
194          (
195            p_log_id    => p_log_id,
196            p_log_msg   => 'Bind ' || i || ': ' || NVL(p_array_bind(i), '<NULL>'),
197            p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
198            p_log_type  => 'SQL_BIND'
199          );
200        END LOOP;
201      END IF;
202  
203      IF fn_normalize_execute(p_execute) = 'N' THEN
204        RETURN 0;
205      END IF;
206  
207      LOOP
208        l_attempt := l_attempt + 1;
209  
210        BEGIN
211          l_cursor_id := DBMS_SQL.OPEN_CURSOR;
212          DBMS_SQL.PARSE(l_cursor_id, p_sql, DBMS_SQL.NATIVE);
213  
214          IF p_array_bind IS NOT NULL THEN
215            FOR i IN 1 .. p_array_bind.COUNT LOOP
216              DBMS_SQL.BIND_VARIABLE(l_cursor_id, ':' || i, p_array_bind(i));
217            END LOOP;
218          END IF;
219  
220          l_rows := DBMS_SQL.EXECUTE(l_cursor_id);
221          DBMS_SQL.CLOSE_CURSOR(l_cursor_id);
222  
223          RETURN l_rows;
224        EXCEPTION
225          WHEN OTHERS THEN
226            IF DBMS_SQL.IS_OPEN(l_cursor_id) THEN
227              DBMS_SQL.CLOSE_CURSOR(l_cursor_id);
228            END IF;
229  
230            IF SQLCODE IN (-4061, -4062, -4068) AND l_attempt = 1 THEN
231              IF p_log_id IS NOT NULL THEN
232                PKG_TL_LOGGING.prc_log
233                (
234                  p_log_id    => p_log_id,
235                  p_log_msg   => 'Retrying SQL after remote package state changed: ' || SQLERRM,
236                  p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
237                  p_log_type  => 'SQL_RETRY'
238                );
239              END IF;
240            ELSE
241              RAISE;
242            END IF;
243        END;
244      END LOOP;
245    END fn_run_sql_in_bind;
246  
247    FUNCTION fn_run_into_sql_in_bind
248    (
249      p_log_id     IN NUMBER,
250      p_sql        IN CLOB,
251      p_array_bind IN SYS.ODCIVARCHAR2LIST,
252      p_execute    IN VARCHAR2 DEFAULT 'Y'
253    )
254    RETURN NUMBER
255    IS
256      l_cursor_id INTEGER;
257      l_rows      INTEGER;
258      l_result    NUMBER;
259      l_attempt   NUMBER := 0;
260    BEGIN
261      IF p_sql IS NULL THEN
262        raise_application_error(-20001, 'SQL text is required');
263      END IF;
264  
265      prc_log_sql(p_log_id => p_log_id, p_sql => p_sql, p_execute => p_execute);
266  
267      IF p_log_id IS NOT NULL AND p_array_bind IS NOT NULL THEN
268        PKG_TL_LOGGING.prc_log
269        (
270          p_log_id    => p_log_id,
271          p_log_msg   => 'Bind count: ' || p_array_bind.COUNT,
272          p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
273          p_log_type  => 'SQL_BIND'
274        );
275  
276        FOR i IN 1 .. p_array_bind.COUNT LOOP
277          PKG_TL_LOGGING.prc_log
278          (
279            p_log_id    => p_log_id,
280            p_log_msg   => 'Bind ' || i || ': ' || NVL(p_array_bind(i), '<NULL>'),
281            p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
282            p_log_type  => 'SQL_BIND'
283          );
284        END LOOP;
285      END IF;
286  
287      IF fn_normalize_execute(p_execute) = 'N' THEN
288        RETURN NULL;
289      END IF;
290  
291      LOOP
292        l_attempt := l_attempt + 1;
293  
294        BEGIN
295          l_cursor_id := DBMS_SQL.OPEN_CURSOR;
296          DBMS_SQL.PARSE(l_cursor_id, p_sql, DBMS_SQL.NATIVE);
297  
298          IF p_array_bind IS NOT NULL THEN
299            FOR i IN 1 .. p_array_bind.COUNT LOOP
300              DBMS_SQL.BIND_VARIABLE(l_cursor_id, ':' || i, p_array_bind(i));
301            END LOOP;
302          END IF;
303  
304          DBMS_SQL.DEFINE_COLUMN(l_cursor_id, 1, l_result);
305          l_rows := DBMS_SQL.EXECUTE(l_cursor_id);
306  
307          IF DBMS_SQL.FETCH_ROWS(l_cursor_id) > 0 THEN
308            DBMS_SQL.COLUMN_VALUE(l_cursor_id, 1, l_result);
309          END IF;
310  
311          DBMS_SQL.CLOSE_CURSOR(l_cursor_id);
312  
313          RETURN l_result;
314        EXCEPTION
315          WHEN OTHERS THEN
316            IF DBMS_SQL.IS_OPEN(l_cursor_id) THEN
317              DBMS_SQL.CLOSE_CURSOR(l_cursor_id);
318            END IF;
319  
320            IF SQLCODE IN (-4061, -4062, -4068) AND l_attempt = 1 THEN
321              IF p_log_id IS NOT NULL THEN
322                PKG_TL_LOGGING.prc_log
323                (
324                  p_log_id    => p_log_id,
325                  p_log_msg   => 'Retrying SQL after remote package state changed: ' || SQLERRM,
326                  p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
327                  p_log_type  => 'SQL_RETRY'
328                );
329              END IF;
330            ELSE
331              RAISE;
332            END IF;
333        END;
334      END LOOP;
335    END fn_run_into_sql_in_bind;
