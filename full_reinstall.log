SQL> CREATE OR REPLACE VIEW ARCHIVE_PARTITION_INFO_VW
  2  AS
  3  SELECT p.table_owner AS schema_name,
  4         p.table_name,
  5         p.partition_name,
  6         s.subpartition_name,
  7         EXTRACTVALUE
  8         (
  9           DBMS_XMLGEN.GETXMLTYPE
 10           (
 11             'select high_value from all_tab_partitions where table_owner = ''' ||
 12             REPLACE(p.table_owner, '''', '''''') ||
 13             ''' and table_name = ''' ||
 14             REPLACE(p.table_name, '''', '''''') ||
 15             ''' and partition_name = ''' ||
 16             REPLACE(p.partition_name, '''', '''''') || ''''
 17           ),
 18           '/ROWSET/ROW/HIGH_VALUE'
 19         ) AS partition_high_value,
 20         EXTRACTVALUE
 21         (
 22           DBMS_XMLGEN.GETXMLTYPE
 23           (
 24             'select high_value from all_tab_partitions where table_owner = ''' ||
 25             p.table_owner ||
 26             ''' and table_name = ''' ||
 27             p.table_name ||
 28             ''' and partition_position = '||(p.partition_position-1)
 29           ),
 30           '/ROWSET/ROW/HIGH_VALUE'
 31         ) AS prev_partition_high_value,
 32         CASE
 33           WHEN s.subpartition_name IS NULL THEN NULL
 34           ELSE EXTRACTVALUE
 35                (
 36                  DBMS_XMLGEN.GETXMLTYPE
 37                  (
 38                    'select high_value from all_tab_subpartitions where table_owner = ''' ||
 39                    REPLACE(s.table_owner, '''', '''''') ||
 40                    ''' and table_name = ''' ||
 41                    REPLACE(s.table_name, '''', '''''') ||
 42                    ''' and partition_name = ''' ||
 43                    REPLACE(s.partition_name, '''', '''''') ||
 44                    ''' and subpartition_name = ''' ||
 45                    REPLACE(s.subpartition_name, '''', '''''') || ''''
 46                  ),
 47                  '/ROWSET/ROW/HIGH_VALUE'
 48                )
 49         END AS subpartition_high_value,
 50         p.partition_position,
 51         s.subpartition_position
 52    FROM all_tab_partitions p
 53    LEFT JOIN all_tab_subpartitions s
 54      ON p.table_owner = s.table_owner
 55     AND p.table_name = s.table_name
 56     AND p.partition_name = s.partition_name;

