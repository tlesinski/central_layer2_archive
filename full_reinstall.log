 30  FUNCTION fn_generate_json_log
 31  (
 32    p_log_msg	  IN CLOB,
 33    p_log_type	  IN VARCHAR2,
 34    p_log_date	  IN VARCHAR2
 35  )
 36  RETURN CLOB
 37  IS
 38    l_json_entry CLOB;
 39  BEGIN
 40    -- JSON_OBJECT does not accept CLOB values larger than 32767.
 41    -- Build JSON manually via CLOB concatenation for safety.
 42    l_json_entry := TO_CLOB('{"type":"') || p_log_type ||
 43                    TO_CLOB('","timestamp":"') || p_log_date ||
 44                    TO_CLOB('","message":"') ||
 45                    REPLACE(REPLACE(REPLACE(p_log_msg, '\', '\\'), '"', '\"'), CHR(10), '\n') ||
 46                    TO_CLOB('"}');
 47  
 48    -- Wrap log entry within "log_entries" array to support multiple entries
 49    RETURN l_json_entry;
 50  END fn_generate_json_log;
