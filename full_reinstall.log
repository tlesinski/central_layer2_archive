 33    FUNCTION fn_format_sql_for_log
 34    (
 35      p_sql IN CLOB
 36    )
 37    RETURN CLOB
 38    IS
 39      l_sql CLOB;
 40    BEGIN
 41      IF p_sql IS NULL THEN
 42        RETURN NULL;
 43      END IF;
 44  
 45      l_sql := REGEXP_REPLACE(p_sql, '[[:space:]]+', ' ');
 46      l_sql := TRIM(l_sql);
 47  
 48      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(SELECT[[:space:]])', CHR(10) || 'SELECT ', 1, 0, 'i');
 49      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(FROM[[:space:]])', CHR(10) || 'FROM ', 1, 0, 'i');
 50      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(WHERE[[:space:]])', CHR(10) || 'WHERE ', 1, 0, 'i');
 51      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(AND[[:space:]])', CHR(10) || '  AND ', 1, 0, 'i');
 52      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(OR[[:space:]])', CHR(10) || '  OR ', 1, 0, 'i');
 53      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(WHEN[[:space:]])', CHR(10) || 'WHEN ', 1, 0, 'i');
 54      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(VALUES[[:space:]])', CHR(10) || 'VALUES ', 1, 0, 'i');
 55      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(PARTITION[[:space:]])', CHR(10) || 'PARTITION ', 1, 0, 'i');
 56      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(SUBPARTITION[[:space:]])', CHR(10) || 'SUBPARTITION ', 1, 0, 'i');
 57      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(FOR[[:space:]]+EXCHANGE[[:space:]])', CHR(10) || 'FOR EXCHANGE ', 1, 0, 'i');
 58      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(WITH[[:space:]]+TABLE[[:space:]])', CHR(10) || 'WITH TABLE ', 1, 0, 'i');
 59      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(INCLUDING[[:space:]]+INDEXES)', CHR(10) || 'INCLUDING INDEXES', 1, 0, 'i');
 60      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(EXCLUDING[[:space:]]+INDEXES)', CHR(10) || 'EXCLUDING INDEXES', 1, 0, 'i');
 61      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(WITHOUT[[:space:]]+VALIDATION)', CHR(10) || 'WITHOUT VALIDATION', 1, 0, 'i');
 62      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(UPDATE[[:space:]]+GLOBAL[[:space:]]+INDEXES)', CHR(10) || 'UPDATE GLOBAL INDEXES', 1, 0, 'i');
 63  
 64      RETURN l_sql;
 65    END fn_format_sql_for_log;
