338    FUNCTION fn_col_count
339    (
340      p_line IN VARCHAR2,
341      p_sep  IN VARCHAR2 DEFAULT '|'
342    )
343    RETURN PLS_INTEGER
344    IS
345      l_count PLS_INTEGER := 1;
346      l_pos   PLS_INTEGER := 0;
347    BEGIN
348      IF p_line IS NULL THEN
349        RETURN 0;
350      END IF;
351  
352      LOOP
353        l_pos := INSTR(p_line, p_sep, l_pos + 1);
354        EXIT WHEN l_pos = 0;
355        l_count := l_count + 1;
356      END LOOP;
357  
358      RETURN l_count;
359    END fn_col_count;
360  
361    FUNCTION fn_col_value
362    (
363      p_line   IN VARCHAR2,
364      p_col_no IN PLS_INTEGER,
365      p_sep    IN VARCHAR2 DEFAULT '|'
366    )
367    RETURN VARCHAR2
368    IS
369      l_text      VARCHAR2(32767) := p_line;
370      l_start_pos PLS_INTEGER := 1;
371      l_end_pos   PLS_INTEGER;
372    BEGIN
373      FOR i IN 1 .. p_col_no LOOP
374        l_end_pos := INSTR(l_text, p_sep, l_start_pos);
375  
376        IF i = p_col_no THEN
377          IF l_end_pos = 0 THEN
378            RETURN SUBSTR(l_text, l_start_pos);
379          ELSE
380            RETURN SUBSTR(l_text, l_start_pos, l_end_pos - l_start_pos);
381          END IF;
382        END IF;
383  
384        IF l_end_pos = 0 THEN
385          RETURN NULL;
386        END IF;
387  
388        l_start_pos := l_end_pos + 1;
389      END LOOP;
390  
391      RETURN NULL;
392    END fn_col_value;
393  
394    FUNCTION fn_next_line
395    (
396      p_clob IN CLOB,
397      p_pos  IN OUT PLS_INTEGER
398    )
399    RETURN VARCHAR2
400    IS
401      l_end_pos PLS_INTEGER;
402      l_line    VARCHAR2(32767);
403    BEGIN
404      IF p_clob IS NULL OR p_pos > DBMS_LOB.GETLENGTH(p_clob) THEN
405        RETURN NULL;
406      END IF;
407  
408      l_end_pos := DBMS_LOB.INSTR(p_clob, CHR(10), p_pos);
409  
410      IF l_end_pos = 0 THEN
411        l_line := DBMS_LOB.SUBSTR(p_clob, 32767, p_pos);
412        p_pos := DBMS_LOB.GETLENGTH(p_clob) + 1;
413      ELSE
414        l_line := DBMS_LOB.SUBSTR(p_clob, l_end_pos - p_pos, p_pos);
415        p_pos := l_end_pos + 1;
416      END IF;
417  
418      RETURN l_line;
419    END fn_next_line;
420  
421    FUNCTION fn_sanitize
422    (
423      p_value    IN VARCHAR2,
424      p_null_text IN VARCHAR2 DEFAULT '-',
425      p_sep      IN VARCHAR2 DEFAULT '|'
426    )
427    RETURN VARCHAR2
428    IS
429    BEGIN
430      IF p_value IS NULL OR TRIM(p_value) IS NULL THEN
431        RETURN p_null_text;
432      END IF;
433  
434      RETURN REPLACE(REPLACE(REPLACE(TRIM(p_value), CHR(13), ' '), CHR(10), ' '), p_sep, ' ');
435    END fn_sanitize;
436  
437    FUNCTION fn_format_table
438    (
439      p_columns       IN VARCHAR2,
440      p_rows          IN CLOB,
441      p_col_align     IN VARCHAR2 DEFAULT NULL,
442      p_separator     IN VARCHAR2 DEFAULT '|',
443      p_null_text     IN VARCHAR2 DEFAULT '-',
444      p_max_col_width IN NUMBER   DEFAULT 120,
445      p_box_style     IN VARCHAR2 DEFAULT 'SIMPLE'
446    )
447    RETURN CLOB
448    IS
449      TYPE t_widths IS TABLE OF PLS_INTEGER INDEX BY PLS_INTEGER;
450  
451      l_widths       t_widths;
452      l_col_count    PLS_INTEGER;
453      l_max_width    PLS_INTEGER := LEAST(GREATEST(NVL(p_max_col_width, 120), 8), 300);
454      l_pos          PLS_INTEGER;
455      l_line         VARCHAR2(32767);
456      l_value        VARCHAR2(32767);
457      l_sanitized    VARCHAR2(32767);
458      l_result       CLOB;
459      l_rows_count   NUMBER := 0;
460      l_box          VARCHAR2(20);
461      l_is_right     BOOLEAN;
462    BEGIN
463      l_box := UPPER(NVL(TRIM(p_box_style), 'SIMPLE'));
464  
465      IF l_box NOT IN ('NONE', 'SIMPLE') THEN
466        l_box := 'SIMPLE';
467      END IF;
468  
469      l_col_count := fn_col_count(p_columns, p_separator);
470  
471      IF l_col_count = 0 THEN
472        RETURN 'FORMAT_TABLE: no columns' || CHR(10);
473      END IF;
474  
475      -- pass 1: measure max widths per column
476      FOR i IN 1 .. l_col_count LOOP
477        l_value := fn_col_value(p_columns, i, p_separator);
478        l_widths(i) := LEAST(GREATEST(LENGTH(NVL(l_value, '-')), 1), l_max_width);
479      END LOOP;
480  
481      l_pos := 1;
482  
483      LOOP
484        l_line := fn_next_line(p_rows, l_pos);
485        EXIT WHEN l_line IS NULL;
486        CONTINUE WHEN TRIM(l_line) IS NULL;
487  
488        l_rows_count := l_rows_count + 1;
489  
490        FOR i IN 1 .. l_col_count LOOP
491          l_value := fn_col_value(l_line, i, p_separator);
492          l_sanitized := fn_sanitize(l_value, p_null_text, p_separator);
493          l_widths(i) := LEAST(GREATEST(l_widths(i), LENGTH(l_sanitized)), l_max_width);
494        END LOOP;
495      END LOOP;
496  
497      -- pass 2: build output
498      l_result := TO_CLOB('FORMAT_TABLE:' || CHR(10));
499      l_result := l_result || 'Columns : ' || l_col_count || CHR(10);
500      l_result := l_result || 'Rows    : ' || l_rows_count || CHR(10) || CHR(10);
501  
502      -- header + top border
503      IF l_box = 'SIMPLE' THEN
504        l_result := l_result || '+';
505        FOR i IN 1 .. l_col_count LOOP
506          l_result := l_result || RPAD('-', l_widths(i) + 2, '-') || '+';
507        END LOOP;
508        l_result := l_result || CHR(10) || '|';
509  
510        FOR i IN 1 .. l_col_count LOOP
511          l_value := fn_col_value(p_columns, i, p_separator);
512          l_result := l_result || ' ' || RPAD(NVL(l_value, '-'), l_widths(i)) || ' |';
513        END LOOP;
514  
515        l_result := l_result || CHR(10) || '+';
516        FOR i IN 1 .. l_col_count LOOP
517          l_result := l_result || RPAD('-', l_widths(i) + 2, '-') || '+';
518        END LOOP;
519        l_result := l_result || CHR(10);
520      ELSE
521        FOR i IN 1 .. l_col_count LOOP
522          l_value := fn_col_value(p_columns, i, p_separator);
523          l_result := l_result || RPAD(NVL(l_value, '-'), l_widths(i));
524          l_result := l_result || CASE WHEN i < l_col_count THEN '  ' END;
525        END LOOP;
526  
527        l_result := l_result || CHR(10);
528  
529        FOR i IN 1 .. l_col_count LOOP
530          l_result := l_result || RPAD('-', l_widths(i), '-');
531          l_result := l_result || CASE WHEN i < l_col_count THEN '  ' END;
532        END LOOP;
533  
534        l_result := l_result || CHR(10);
535      END IF;
536  
537      -- data rows
538      l_pos := 1;
539  
540      LOOP
541        l_line := fn_next_line(p_rows, l_pos);
542        EXIT WHEN l_line IS NULL;
543        CONTINUE WHEN TRIM(l_line) IS NULL;
544  
545        IF l_box = 'SIMPLE' THEN
546          l_result := l_result || '|';
547        END IF;
548  
549        FOR i IN 1 .. l_col_count LOOP
550          l_value := fn_col_value(l_line, i, p_separator);
551          l_sanitized := fn_sanitize(l_value, p_null_text, p_separator);
552          l_is_right := p_col_align IS NOT NULL AND LENGTH(p_col_align) >= i AND SUBSTR(p_col_align, i, 1) = '>';
553  
554          IF l_box = 'SIMPLE' THEN
555            l_result := l_result || ' ' ||
556              CASE WHEN l_is_right THEN LPAD(l_sanitized, l_widths(i)) ELSE RPAD(l_sanitized, l_widths(i)) END ||
557              ' |';
558          ELSE
559            l_result := l_result ||
560              CASE WHEN l_is_right THEN LPAD(l_sanitized, l_widths(i)) ELSE RPAD(l_sanitized, l_widths(i)) END;
561            l_result := l_result || CASE WHEN i < l_col_count THEN '  ' END;
562          END IF;
563        END LOOP;
564  
565        l_result := l_result || CHR(10);
566      END LOOP;
567  
568      -- bottom border
569      IF l_box = 'SIMPLE' AND l_rows_count > 0 THEN
570        l_result := l_result || '+';
571        FOR i IN 1 .. l_col_count LOOP
572          l_result := l_result || RPAD('-', l_widths(i) + 2, '-') || '+';
573        END LOOP;
574        l_result := l_result || CHR(10);
575      END IF;
576  
577      RETURN l_result;
578    END fn_format_table;
579  END PKG_SQL;
580  /

