 55         truncate_status,
 56         source_row_count,
 57         target_row_count,
 58         retention_rule,
 59         cutoff_date,
 60         partition_high_value_date
 61    FROM candidate_partitions
 62   WHERE partition_high_value_date <= cutoff_date;
