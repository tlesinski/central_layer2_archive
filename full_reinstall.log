SQL> CREATE OR REPLACE PACKAGE BODY PKG_ARCHIVE_IMPORT
  2  AS
  3    /*
  4      Package      : PKG_ARCHIVE_IMPORT
  5      Developer    : Tomasz Lesinski
  6      Date         : 2026-05-28
  7      Purpose      : Import source partitions into target archive via EXCHANGE
  8  
  9      Prerequisite : PKG_SQL, PKG_ARCHIVE_LOG, PKG_ARCHIVE_PARTITION,
 10                     TW_ARCHIVE_IMPORT_PARTITIONS_VW
 11  
 12      Change History:
 13      ------------------------------------------------------------------------------
 14      Version    Date         Programmer         Description
 15      ------------------------------------------------------------------------------
 16      1.0        2026-05-28   Tomasz Lesinski    Initial version
 17       1.1        2026-05-28   Tomasz Lesinski    Add PARALLEL_DEGREE support,
 18                                                  ALTER SESSION ENABLE PARALLEL DML,
 19                                                  process summary logging
 20       1.2        2026-05-31   Tomasz Lesinski    Compact per-table summary, ORA-40478 fix
 21    */
 22    FUNCTION fn_normalize_execute(p_execute IN VARCHAR2) RETURN VARCHAR2 IS
 23    BEGIN
 24      RETURN CASE WHEN UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN 'Y' ELSE 'N' END;
 25    END;
 26  
 27    FUNCTION fn_normalize_name(p_name IN VARCHAR2) RETURN VARCHAR2 IS
 28    BEGIN
 29      IF p_name IS NULL OR TRIM(p_name) IS NULL THEN
 30        RETURN NULL;
 31      END IF;
 32  
 33      RETURN PKG_SQL.fn_assert_simple_name(p_name);
 34    END;
 35  
 36    PROCEDURE prc_mark_partition
 37    (
 38      p_source_db_link          IN VARCHAR2,
 39      p_source_owner            IN VARCHAR2,
 40      p_source_table_name       IN VARCHAR2,
 41      p_partition_high_value    IN VARCHAR2,
 42      p_subpartition_high_value IN VARCHAR2,
 43      p_archive_status   IN VARCHAR2,
 44      p_run_id           IN NUMBER,
 45      p_target_row_count IN NUMBER DEFAULT NULL,
 46      p_error_message    IN VARCHAR2 DEFAULT NULL
 47    )
 48    IS
 49    BEGIN
 50      UPDATE TW_ARCHIVE_PARTITIONS
 51         SET ARCHIVE_STATUS = p_archive_status,
 52             QUALITY_STATUS = CASE WHEN p_archive_status = 'Y' THEN 'N' ELSE QUALITY_STATUS END,
 53             TARGET_ROW_COUNT = COALESCE(p_target_row_count, TARGET_ROW_COUNT),
 54             LAST_RUN_ID = p_run_id,
 55             ERROR_MESSAGE = p_error_message,
 56             UPDATED_AT = SYSTIMESTAMP
 57       WHERE SOURCE_DB_LINK = p_source_db_link
 58         AND SOURCE_OWNER = p_source_owner
 59         AND SOURCE_TABLE_NAME = p_source_table_name
 60         AND PARTITION_HIGH_VALUE = p_partition_high_value
 61         AND SUBPARTITION_HIGH_VALUE = p_subpartition_high_value;
 62    END prc_mark_partition;
 63  
 64    PROCEDURE prc_import
 65    (
 66      p_execute           IN VARCHAR2 DEFAULT 'N',
 67      p_target_owner      IN VARCHAR2 DEFAULT NULL,
 68      p_target_table_name IN VARCHAR2 DEFAULT NULL
 69    )
 70    IS
 71      l_run_id          NUMBER;
 72      l_log_id          NUMBER;
 73      l_execute_flag    VARCHAR2(1);
 74      l_target_owner    VARCHAR2(128);
 75      l_target_table    VARCHAR2(128);
 76      l_sql             CLOB;
 77      l_rows_available  NUMBER := 0;
 78      l_rows_loaded     NUMBER;
 79      l_units           NUMBER := 0;
 80      l_imported        NUMBER := 0;
 81      l_tables          NUMBER := 0;
 82      l_staging_table   VARCHAR2(128);
 83      l_parallel_degree NUMBER;
 84      l_tablespace_name VARCHAR2(128);
 85      l_summary         CLOB := NULL;
 86      l_table_summary   CLOB;
 87      l_partition_columns VARCHAR2(1000) :=
 88        'NOTE|SOURCE_PARTITION_NAME|SOURCE_SUBPARTITION_NAME|PARTITION_NAME|SUBPARTITION_NAME|PARTITION_HIGH_VALUE|SUBPARTITION_HIGH_VALUE|ARCHIVE_STATUS|QUALITY_STATUS|TRUNCATE_STATUS|SOURCE_ROW_COUNT|TARGET_ROW_COUNT';
 89    BEGIN
 90      l_execute_flag := fn_normalize_execute(p_execute);
 91      l_target_owner := fn_normalize_name(p_target_owner);
 92      l_target_table := fn_normalize_name(p_target_table_name);
 93      l_run_id := PKG_ARCHIVE_LOG.fn_create_run('ARCHIVE', NULL, NULL, NULL, l_execute_flag);
 94      l_log_id := PKG_ARCHIVE_LOG.fn_get_log_id(l_run_id);
 95  
 96      PKG_ARCHIVE_LOG.prc_log_message
 97      (
 98        p_run_id  => l_run_id,
 99        p_log_msg => 'Started ARCHIVE with parameters:' || CHR(10) ||
100                     '  p_execute           => ' || l_execute_flag || CHR(10) ||
101                     '  p_target_owner      => ' || NVL(l_target_owner, '<ALL>') || CHR(10) ||
102                     '  p_target_table_name => ' || NVL(l_target_table, '<ALL>')
103      );
104  
105      IF l_execute_flag = 'Y' THEN
106        COMMIT;
107        EXECUTE IMMEDIATE 'ALTER SESSION ENABLE PARALLEL DML';
108      END IF;
109  
110      l_sql :=
111        'SELECT COUNT(*) ' ||
112        '  FROM TW_ARCHIVE_IMPORT_PARTITIONS_VW ' ||
113        ' WHERE (:1 IS NULL OR target_owner = :1) ' ||
114        '   AND (:2 IS NULL OR target_table_name = :2)';
115  
116      l_rows_available := PKG_SQL.fn_run_into_sql_in_bind
117      (
118        p_log_id     => l_log_id,
119        p_sql        => l_sql,
120        p_array_bind => SYS.ODCIVARCHAR2LIST(l_target_owner, l_target_table),
121        p_execute    => 'Y'
122      );
123  
124      FOR t IN (
125        SELECT DISTINCT source_db_link,
126               source_owner,
127               source_table_name,
128               target_owner,
129               target_table_name
130          FROM TW_ARCHIVE_IMPORT_PARTITIONS_VW
131         WHERE (l_target_owner IS NULL OR target_owner = l_target_owner)
132           AND (l_target_table IS NULL OR target_table_name = l_target_table)
133         ORDER BY source_db_link, source_owner, source_table_name
134      ) LOOP
135        l_tables := l_tables + 1;
136        l_table_summary := NULL;
137  
138        SELECT NVL(PARALLEL_DEGREE, 4),
139               TABLESPACE_NAME
140          INTO l_parallel_degree,
141               l_tablespace_name
142          FROM TW_ARCHIVE_TABLES
143         WHERE SOURCE_DB_LINK = t.source_db_link
144           AND SOURCE_OWNER = t.source_owner
145           AND SOURCE_TABLE_NAME = t.source_table_name;
146  
147        FOR r IN (
148          SELECT p.*
149            FROM TW_ARCHIVE_IMPORT_PARTITIONS_VW p
150           WHERE p.source_db_link = t.source_db_link
151             AND p.source_owner = t.source_owner
152             AND p.source_table_name = t.source_table_name
153             AND p.target_owner = t.target_owner
154             AND p.target_table_name = t.target_table_name
155            ORDER BY p.partition_high_value, p.subpartition_high_value
156        ) LOOP
157          l_units := l_units + 1;
158          l_rows_loaded := NULL;
159  
160          IF l_execute_flag = 'Y' THEN
161            prc_mark_partition(
162              r.SOURCE_DB_LINK,
163              r.SOURCE_OWNER,
164              r.SOURCE_TABLE_NAME,
165              r.PARTITION_HIGH_VALUE,
166              r.SUBPARTITION_HIGH_VALUE,
167              'N',
168              l_run_id
169            );
170          END IF;
171  
172          PKG_ARCHIVE_PARTITION.prc_create_exchange_staging
173          (
174            p_target_owner       => r.TARGET_OWNER,
175            p_target_table       => r.TARGET_TABLE_NAME,
176            p_partition_name     => r.PARTITION_NAME,
177            p_staging_table_name => l_staging_table,
178            p_execute            => l_execute_flag,
179            p_log_id             => l_log_id,
180            p_tablespace_name    => l_tablespace_name
181          );
182  
183          IF r.ARCHIVE_UNIT_TYPE = 'SUBPARTITION' THEN
184            PKG_ARCHIVE_PARTITION.prc_load_exchange_staging_subpartition
185            (
186              p_source_db_link             => r.SOURCE_DB_LINK,
187              p_source_owner               => r.SOURCE_OWNER,
188              p_source_table               => r.SOURCE_TABLE_NAME,
189              p_target_owner               => r.TARGET_OWNER,
190              p_target_table               => r.TARGET_TABLE_NAME,
191              p_staging_table_name         => l_staging_table,
192              p_partition_high_value       => r.PARTITION_HIGH_VALUE,
193              p_prev_partition_high_value  => r.PREV_PARTITION_HIGH_VALUE,
194              p_subpartition_high_value    => r.SUBPARTITION_HIGH_VALUE,
195              p_execute                    => l_execute_flag,
196              p_log_id                     => l_log_id,
197              p_parallel_degree            => l_parallel_degree,
198              p_rows_loaded                => l_rows_loaded
199            );
200          ELSE
201            PKG_ARCHIVE_PARTITION.prc_load_exchange_staging
202            (
203              p_source_db_link     => r.SOURCE_DB_LINK,
204              p_source_owner       => r.SOURCE_OWNER,
205              p_source_table       => r.SOURCE_TABLE_NAME,
206              p_target_owner       => r.TARGET_OWNER,
207              p_target_table       => r.TARGET_TABLE_NAME,
208              p_staging_table_name => l_staging_table,
209              p_high_value         => r.PARTITION_HIGH_VALUE,
210              p_prev_high_value    => r.PREV_PARTITION_HIGH_VALUE,
211              p_execute            => l_execute_flag,
212              p_log_id             => l_log_id,
213              p_parallel_degree    => l_parallel_degree,
214              p_rows_loaded        => l_rows_loaded
215            );
216          END IF;
217  
218          PKG_ARCHIVE_LOG.prc_log_message
219          (
220            p_run_id   => l_run_id,
221            p_log_type => 'ARCHIVE_LOAD',
222            p_log_msg  => 'ARCHIVE_LOAD ' ||
223                          'source=' || r.source_db_link || '.' || r.source_owner || '.' || r.source_table_name ||
224                          ' ' || r.source_partition_name ||
225                          CASE
226                            WHEN r.archive_unit_type = 'SUBPARTITION'
227                              THEN '.' || r.source_subpartition_name
228                          END ||
229                          ', target=' || r.target_owner || '.' || r.target_table_name ||
230                          ' ' || r.partition_name ||
231                          CASE
232                            WHEN r.archive_unit_type = 'SUBPARTITION'
233                              THEN '.' || r.subpartition_name
234                          END ||
235                          ', staging=' || r.target_owner || '.' || l_staging_table ||
236                          ', rows_loaded=' || NVL(TO_CHAR(l_rows_loaded), '<DRY_RUN>') ||
237                          ', execute=' || l_execute_flag
238          );
239  
240          PKG_ARCHIVE_PARTITION.prc_build_staging_indexes
241          (
242            p_target_owner       => r.TARGET_OWNER,
243            p_target_table       => r.TARGET_TABLE_NAME,
244            p_staging_table_name => l_staging_table,
245            p_execute            => l_execute_flag,
246            p_log_id             => l_log_id,
247            p_parallel_degree    => l_parallel_degree,
248            p_tablespace_name    => l_tablespace_name
249          );
250  
251          IF r.ARCHIVE_UNIT_TYPE = 'SUBPARTITION' THEN
252            PKG_ARCHIVE_PARTITION.prc_exchange_subpartition
253            (
254              p_target_owner       => r.TARGET_OWNER,
255              p_target_table       => r.TARGET_TABLE_NAME,
256              p_subpartition_name  => r.SUBPARTITION_NAME,
257              p_staging_table_name => l_staging_table,
258              p_execute            => l_execute_flag,
259              p_log_id             => l_log_id
260            );
261          ELSE
262            PKG_ARCHIVE_PARTITION.prc_exchange_partition
263            (
264              p_target_owner       => r.TARGET_OWNER,
265              p_target_table       => r.TARGET_TABLE_NAME,
266              p_partition_name     => r.PARTITION_NAME,
267              p_staging_table_name => l_staging_table,
268              p_execute            => l_execute_flag,
269              p_log_id             => l_log_id
270            );
271          END IF;
272  
273          PKG_ARCHIVE_PARTITION.prc_drop_staging
274          (
275            p_staging_owner      => r.TARGET_OWNER,
276            p_staging_table_name => l_staging_table,
277            p_execute            => l_execute_flag,
278            p_log_id             => l_log_id
279          );
280  
281          IF l_execute_flag = 'Y' THEN
282            prc_mark_partition(
283              r.SOURCE_DB_LINK,
284              r.SOURCE_OWNER,
285              r.SOURCE_TABLE_NAME,
286              r.PARTITION_HIGH_VALUE,
287              r.SUBPARTITION_HIGH_VALUE,
288              'Y',
289              l_run_id,
290              l_rows_loaded
291            );
292  
293            l_imported := l_imported + 1;
294            COMMIT;
295          END IF;
296  
297          DBMS_OUTPUT.PUT_LINE('IMPORT_DONE EXCHANGE ' ||
298                               r.SOURCE_DB_LINK || '.' || r.SOURCE_OWNER || '.' ||
299                               r.SOURCE_TABLE_NAME || ' ' || r.PARTITION_NAME ||
300                               CASE WHEN r.ARCHIVE_UNIT_TYPE = 'SUBPARTITION' THEN '.' || r.SUBPARTITION_NAME END ||
301                               ' loaded=' || NVL(TO_CHAR(l_rows_loaded), '<DRY_RUN>') ||
302                               ' target_rows=' || NVL(TO_CHAR(l_rows_loaded), '<DRY_RUN>'));
303  
304          IF l_execute_flag = 'Y' THEN
305            l_table_summary := l_table_summary ||
306              TO_CLOB(PKG_ARCHIVE_LOG.fn_summary_cell('EXCHANGED')) || '|' ||
307              PKG_ARCHIVE_LOG.fn_summary_cell(r.source_partition_name) || '|' ||
308              PKG_ARCHIVE_LOG.fn_summary_cell(r.source_subpartition_name) || '|' ||
309              PKG_ARCHIVE_LOG.fn_summary_cell(r.partition_name) || '|' ||
310              PKG_ARCHIVE_LOG.fn_summary_cell(r.subpartition_name) || '|' ||
311              PKG_ARCHIVE_LOG.fn_summary_cell(r.partition_high_value) || '|' ||
312              PKG_ARCHIVE_LOG.fn_summary_cell(r.subpartition_high_value) || '|' ||
313              PKG_ARCHIVE_LOG.fn_summary_cell('Y') || '|' ||
314              PKG_ARCHIVE_LOG.fn_summary_cell('N') || '|' ||
315              PKG_ARCHIVE_LOG.fn_summary_cell(r.truncate_status) || '|' ||
316              PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(r.source_row_count)) || '|' ||
317              PKG_ARCHIVE_LOG.fn_summary_cell(TO_CHAR(l_rows_loaded)) || CHR(10);
318          END IF;
319        END LOOP; -- FOR r
320  
321        IF l_execute_flag = 'Y' AND l_table_summary IS NOT NULL THEN
322          l_summary := l_summary ||
323            '=== TABLE: ' || t.source_db_link || '.' || t.source_owner || '.' || t.source_table_name || ' ===' || CHR(10) || CHR(10) ||
324            PKG_SQL.fn_format_table(
325              p_columns => 'SOURCE_DB_LINK|TABLE_OWNER|TABLE_NAME|EXECUTE',
326              p_rows    => PKG_ARCHIVE_LOG.fn_summary_cell(t.source_db_link) || '|' ||
327                           PKG_ARCHIVE_LOG.fn_summary_cell(t.source_owner) || '|' ||
328                           PKG_ARCHIVE_LOG.fn_summary_cell(t.source_table_name) || '|' ||
329                           PKG_ARCHIVE_LOG.fn_summary_cell(l_execute_flag) || CHR(10)
330            ) || CHR(10) ||
331            PKG_SQL.fn_format_table(
332              p_columns    => l_partition_columns,
333              p_rows       => l_table_summary
334            ) || CHR(10);
335        END IF;
336      END LOOP; -- FOR t
337  
338      IF l_summary IS NOT NULL THEN
339        PKG_ARCHIVE_LOG.prc_log_message(l_run_id, l_summary, 'SUMMARY');
340      END IF;
341  
342      DBMS_OUTPUT.PUT_LINE(
343        'IMPORT tables=' || l_tables ||
344        ' units=' || l_units ||
345        ' found=' || l_rows_available ||
346        ' imported=' || l_imported ||
347        ' target_owner=' || NVL(l_target_owner, '<ALL>') ||
348        ' target_table=' || NVL(l_target_table, '<ALL>') ||
349        ' execute=' || l_execute_flag
350      );
351  
352      PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'SUCCESS');
353    EXCEPTION
354      WHEN OTHERS THEN
355        IF l_run_id IS NOT NULL THEN
356          PKG_ARCHIVE_LOG.prc_log_error_stack(l_run_id);
357          PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', SQLERRM);
358        END IF;
359        RAISE;
360    END prc_import;
361  END PKG_ARCHIVE_IMPORT;
362  /

