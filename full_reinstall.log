SQL> @layer2_core/packages/pkg_archive_quality.body.sql
SQL> CREATE OR REPLACE PACKAGE BODY PKG_ARCHIVE_QUALITY
  2  AS
  3    /*
  4      Package      : PKG_ARCHIVE_QUALITY
  5      Developer    : Tomasz Lesinski
  6      Date         : 2026-05-28
  7      Purpose      : Quality check - compare source and target row counts,
  8                     set QUALITY_STATUS
  9  
 10      Prerequisite : PKG_SQL, PKG_ARCHIVE_LOG, PKG_ARCHIVE_AGENT,
 11                     TW_ARCHIVE_QUALITY_PARTITIONS_VW
 12  
 13      Change History:
 14      ------------------------------------------------------------------------------
 15      Version    Date         Programmer         Description
 16      ------------------------------------------------------------------------------
 17      1.0        2026-05-28   Tomasz Lesinski    Initial version
 18      1.1        2026-05-28   Tomasz Lesinski    Add process summary logging
 19    */
 20    FUNCTION fn_normalize_execute(p_execute IN VARCHAR2) RETURN VARCHAR2 IS
 21    BEGIN
 22      RETURN CASE WHEN UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN 'Y' ELSE 'N' END;
 23    END;
 24  
 25    FUNCTION fn_normalize_name(p_name IN VARCHAR2) RETURN VARCHAR2 IS
 26    BEGIN
 27      IF p_name IS NULL OR TRIM(p_name) IS NULL THEN
 28        RETURN NULL;
 29      END IF;
 30  
 31      RETURN PKG_SQL.fn_assert_simple_name(p_name);
 32    END;
 33  
 34    FUNCTION fn_qualified_agent_function(p_agent_schema IN VARCHAR2, p_source_db_link IN VARCHAR2) RETURN VARCHAR2 IS
 35      l_name VARCHAR2(400);
 36    BEGIN
 37      l_name := PKG_SQL.fn_assert_simple_name(p_agent_schema) || '.PKG_ARCHIVE_AGENT.FN_GET_ROW_COUNT';
 38      IF p_source_db_link IS NOT NULL AND UPPER(TRIM(p_source_db_link)) NOT IN ('LOCAL', 'NONE') THEN
 39        l_name := l_name || '@' || PKG_SQL.fn_assert_simple_name(p_source_db_link);
 40      END IF;
 41      RETURN l_name;
 42    END;
 43  
 44    PROCEDURE prc_quality
 45    (
 46      p_execute           IN VARCHAR2 DEFAULT 'N',
 47      p_target_owner      IN VARCHAR2 DEFAULT NULL,
 48      p_target_table_name IN VARCHAR2 DEFAULT NULL
 49    )
 50    IS
 51      l_run_id          NUMBER;
 52      l_log_id          NUMBER;
 53      l_execute_flag    VARCHAR2(1);
 54      l_target_owner    VARCHAR2(128);
 55      l_target_table    VARCHAR2(128);
 56      l_sql             CLOB;
 57      l_rows_available  NUMBER := 0;
 58      l_agent_function  VARCHAR2(400);
 59      l_source_rows     NUMBER;
 60      l_units           NUMBER := 0;
 61      l_tables          NUMBER := 0;
 62      l_ok              NUMBER := 0;
 63      l_failed          NUMBER := 0;
 64      l_quality_status  VARCHAR2(1);
 65      l_summary         CLOB := NULL;
 66      l_summary_columns VARCHAR2(1000) :=
 67        'SOURCE_DB_LINK|TABLE_OWNER|TABLE_NAME|SOURCE_PARTITION_NAME|SOURCE_SUBPARTITION_NAME|PARTITION_HIGH_VALUE|SUBPARTITION_HIGH_VALUE|ARCHIVE_STATUS|QUALITY_STATUS|TRUNCATE_STATUS|SOURCE_ROW_COUNT|TARGET_ROW_COUNT|NOTE';
 68    BEGIN
 69      l_execute_flag := fn_normalize_execute(p_execute);
 70      l_target_owner := fn_normalize_name(p_target_owner);
 71      l_target_table := fn_normalize_name(p_target_table_name);
 72      l_run_id := PKG_ARCHIVE_LOG.fn_create_run('QUALITY', NULL, NULL, NULL, l_execute_flag);
 73      l_log_id := PKG_ARCHIVE_LOG.fn_get_log_id(l_run_id);
 74  
 75      PKG_ARCHIVE_LOG.prc_log_message
 76      (
 77        p_run_id  => l_run_id,
 78        p_log_msg => 'Started QUALITY with parameters:' || CHR(10) ||
 79                     '  p_execute           => ' || l_execute_flag || CHR(10) ||
 80                     '  p_target_owner      => ' || NVL(l_target_owner, '<ALL>') || CHR(10) ||
 81                     '  p_target_table_name => ' || NVL(l_target_table, '<ALL>')
 82      );
 83  
 84      l_sql :=
 85        'SELECT COUNT(*) ' ||
 86        '  FROM TW_ARCHIVE_QUALITY_PARTITIONS_VW ' ||
 87        ' WHERE (:1 IS NULL OR target_owner = :1) ' ||
 88        '   AND (:2 IS NULL OR target_table_name = :2)';
 89  
 90      l_rows_available := PKG_SQL.fn_run_into_sql_in_bind
 91      (
 92        p_log_id     => l_log_id,
 93        p_sql        => l_sql,
 94        p_array_bind => SYS.ODCIVARCHAR2LIST(l_target_owner, l_target_table),
 95        p_execute    => 'Y'
 96      );
 97  
 98      FOR t IN (
 99        SELECT DISTINCT source_db_link,
100               source_agent_schema,
101               source_owner,
102               source_table_name,
103               target_owner,
104               target_table_name
105          FROM TW_ARCHIVE_QUALITY_PARTITIONS_VW
106         WHERE (l_target_owner IS NULL OR target_owner = l_target_owner)
107           AND (l_target_table IS NULL OR target_table_name = l_target_table)
108         ORDER BY source_db_link, source_owner, source_table_name
109      ) LOOP
110        l_tables := l_tables + 1;
111        l_agent_function := fn_qualified_agent_function(t.source_agent_schema, t.source_db_link);
112        l_sql := 'SELECT ' || l_agent_function || '(:1, :2, :3, :4) FROM dual';
113  
114        FOR r IN (
115          SELECT p.*
116            FROM TW_ARCHIVE_QUALITY_PARTITIONS_VW p
117           WHERE p.source_db_link = t.source_db_link
118             AND p.source_owner = t.source_owner
119             AND p.source_table_name = t.source_table_name
120             AND p.target_owner = t.target_owner
121             AND p.target_table_name = t.target_table_name
122           ORDER BY p.partition_position, p.subpartition_position
123        ) LOOP
124          l_units := l_units + 1;
125  
126          l_source_rows := PKG_SQL.fn_run_into_sql_in_bind
127          (
128            p_log_id     => l_log_id,
129            p_sql        => l_sql,
130            p_array_bind => SYS.ODCIVARCHAR2LIST
131                            (
132                              r.SOURCE_OWNER,
133                              r.SOURCE_TABLE_NAME,
134                              r.SOURCE_PARTITION_NAME,
135                              CASE WHEN r.SOURCE_SUBPARTITION_NAME = '#' THEN NULL ELSE r.SOURCE_SUBPARTITION_NAME END
136                            ),
137            p_execute    => 'Y'
138          );
139  
140          IF l_source_rows = r.TARGET_ROW_COUNT THEN
141            l_quality_status := 'Y';
142            l_ok := l_ok + 1;
143          ELSE
144            l_quality_status := 'N';
145            l_failed := l_failed + 1;
146          END IF;
147  
148          DBMS_OUTPUT.PUT_LINE('QUALITY ' || r.SOURCE_DB_LINK || '.' || r.SOURCE_OWNER || '.' ||
149                               r.SOURCE_TABLE_NAME || ' source_name=' || r.SOURCE_PARTITION_NAME ||
150                               CASE WHEN r.SOURCE_SUBPARTITION_NAME <> '#' THEN '.' || r.SOURCE_SUBPARTITION_NAME ELSE NULL END ||
151                               ' target_name=' || r.PARTITION_NAME ||
152                               CASE WHEN r.SUBPARTITION_NAME <> '#' THEN '.' || r.SUBPARTITION_NAME ELSE NULL END ||
153                               ' source_rows=' || NVL(TO_CHAR(l_source_rows), 'NULL') ||
154                               ' target_rows=' || NVL(TO_CHAR(r.TARGET_ROW_COUNT), 'NULL') ||
155                               ' status=' || l_quality_status || ' execute=' || l_execute_flag);
156  
157          IF l_execute_flag = 'Y' THEN
158            UPDATE TW_ARCHIVE_PARTITIONS
159               SET SOURCE_ROW_COUNT = l_source_rows,
160                   QUALITY_STATUS = l_quality_status,
161                   LAST_RUN_ID = l_run_id,
162                   ERROR_MESSAGE = CASE
163                                     WHEN l_quality_status = 'Y' THEN NULL
164                                     ELSE 'Source row count does not match target row count'
165                                   END,
166                   UPDATED_AT = SYSTIMESTAMP
167             WHERE SOURCE_DB_LINK = r.SOURCE_DB_LINK
168               AND SOURCE_OWNER = r.SOURCE_OWNER
169               AND SOURCE_TABLE_NAME = r.SOURCE_TABLE_NAME
170               AND PARTITION_HIGH_VALUE = r.PARTITION_HIGH_VALUE
171               AND SUBPARTITION_HIGH_VALUE = r.SUBPARTITION_HIGH_VALUE;
172  
173            COMMIT;
174          END IF;
175  
176          l_summary := l_summary ||
177            PKG_ARCHIVE_LOG.fn_summary_row
178            (
179              p_source_db_link          => r.source_db_link,
180              p_table_owner             => r.source_owner,
181              p_table_name              => r.source_table_name,
182              p_partition_name          => r.source_partition_name,
183              p_subpartition_name       => r.source_subpartition_name,
184              p_partition_high_value    => r.partition_high_value,
185              p_subpartition_high_value => r.subpartition_high_value,
186              p_archive_status          => r.archive_status,
187              p_quality_status          => l_quality_status,
188              p_truncate_status         => r.truncate_status,
189              p_source_row_count        => l_source_rows,
190              p_target_row_count        => r.target_row_count,
191              p_note                    => 'target=' || r.target_owner || '.' || r.target_table_name ||
192                                           ' ' || r.partition_name ||
193                                           CASE WHEN r.archive_unit_type = 'SUBPARTITION' THEN '.' || r.subpartition_name END ||
194                                           ', execute=' || l_execute_flag
195            );
196        END LOOP;
197      END LOOP;
198  
199      DBMS_OUTPUT.PUT_LINE(
200        'QUALITY tables=' || l_tables ||
201        ' units=' || l_units ||
202        ' found=' || l_rows_available ||
203        ' ok=' || l_ok ||
204        ' failed=' || l_failed ||
205        ' target_owner=' || NVL(l_target_owner, '<ALL>') ||
206        ' target_table=' || NVL(l_target_table, '<ALL>') ||
207        ' execute=' || l_execute_flag
208      );
209  
210      IF l_summary IS NOT NULL THEN
211        PKG_ARCHIVE_LOG.prc_log_summary
212        (
213          p_run_id       => l_run_id,
214          p_process_name => 'QUALITY',
215          p_columns      => l_summary_columns,
216          p_rows         => l_summary
217        );
218      END IF;
219  
220      PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, CASE WHEN l_failed > 0 THEN 'WARNING' ELSE 'SUCCESS' END);
221    EXCEPTION
222      WHEN OTHERS THEN
223        IF l_run_id IS NOT NULL THEN
224          PKG_ARCHIVE_LOG.prc_log_error_stack(l_run_id);
225          PKG_ARCHIVE_LOG.prc_finish_run(l_run_id, 'ERROR', SQLERRM);
226        END IF;
227        RAISE;
228    END prc_quality;
229  END PKG_ARCHIVE_QUALITY;
230  /

