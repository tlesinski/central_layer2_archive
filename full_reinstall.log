111    FUNCTION fn_run_into_sql
112    (
113      p_log_id  IN NUMBER,
114      p_sql     IN CLOB,
115      p_execute IN VARCHAR2 DEFAULT 'Y'
116    )
117    RETURN NUMBER
118    IS
119      l_result NUMBER;
120      l_sql    VARCHAR2(32767);
121    BEGIN
122      IF p_sql IS NULL THEN
123        raise_application_error(-20001, 'SQL text is required');
124      END IF;
125  
126      prc_log_sql(p_log_id => p_log_id, p_sql => p_sql, p_execute => p_execute);
