268  -- creates local log table md_process_log
269  -- and local log sequence md_process_log_seq
270  
271  PROCEDURE prc_log_create_table
272  IS
273  l_check NUMBER;
274  l_sql CLOB;
275  l_proc_name VARCHAR2(128) := 'prc_log_create_table';
276  BEGIN
277  --------------------------------------------
278  --create local log table g_log_table_name
279  --------------------------------------------
280  SELECT COUNT(*)
281  INTO l_check
282  FROM user_tables
283  WHERE table_name = g_log_table_name;
284  
285  SELECT COUNT(*)
286    INTO l_check
287  FROM (
288    SELECT 1
289      FROM user_tables
290     WHERE table_name = g_log_table_name
291     UNION ALL
292    SELECT 1
293      FROM user_synonyms
294     WHERE synonym_name = g_log_table_name
295  );
296  
297  IF l_check = 0 THEN
298    dbms_output.put_line('Try to create log table ' || g_log_table_name);
299  
300    l_sql := q'!CREATE TABLE "MD_PROCESS_LOG"
301  
302  ( "MSTR_LOG_ID" NUMBER NOT NULL ENABLE,
303  "LOG_ID" NUMBER NOT NULL ENABLE,
304  "LOG_CATEG" VARCHAR2(256 BYTE),
305  "MSTR_FUN" VARCHAR2(128 BYTE),
306  "LOG_STTUS" VARCHAR2(30 BYTE) NOT NULL ENABLE,
307  "START_DATE" DATE,
308  "END_DATE" DATE,
309  "INTERVAL_TIME" INTERVAL DAY (2) TO SECOND (6) GENERATED ALWAYS AS (NUMTODSINTERVAL("END_DATE"-"START_DATE",'DAY')) VIRTUAL ,
310  "LOG_MSG" CLOB NOT NULL ENABLE,
311  "LOG_JSON" CLOB,
312  "LAST_ERR_CODE" VARCHAR2(30 BYTE),
313  "LAST_ERR_DESC" VARCHAR2(256 BYTE),
314  "INST_ID" NUMBER,
315  "SID" NUMBER,
316  "SERIAL#" NUMBER,
317  "CLIENT_INFO" VARCHAR2(128 BYTE),
318  "MODULE" VARCHAR2(128 BYTE),
319  "CRTN_DT" DATE DEFAULT SYSDATE NOT NULL ENABLE,
320  "CRTN_BY" VARCHAR2(128 BYTE) DEFAULT sys_context('USERENV','SESSION_USER') NOT NULL ENABLE,
321  "LAST_UPDT_DT" DATE DEFAULT SYSDATE NOT NULL ENABLE,
322  "LAST_UPDT_BY" VARCHAR2(128 BYTE) DEFAULT sys_context('USERENV','SESSION_USER') NOT NULL ENABLE
323  )
324  PARTITION BY RANGE ("START_DATE") INTERVAL (NUMTOYMINTERVAL(1, 'MONTH'))
325  (PARTITION "P_START" VALUES LESS THAN (TO_DATE(' 2019-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')) )!';
326  
327  EXECUTE IMMEDIATE l_sql;
328  
329  l_sql := 'CREATE INDEX "MD_PROCESS_LOG_IDX1" ON "MD_PROCESS_LOG" ("MSTR_LOG_ID", "LOG_ID") LOCAL';
330  
331    EXECUTE IMMEDIATE l_sql;
332  ELSE
333    dbms_output.put_line('Local log table ' || g_log_table_name || ' or synonym already exists');
334  END IF;
335  
336  --------------------------------------------
337  --create local log sequence g_log_sequence_name
338  --------------------------------------------
339  SELECT COUNT(*)
340    INTO l_check
341  FROM (
342    SELECT 1
343      FROM user_sequences
344     WHERE sequence_name = g_log_sequence_name
345     UNION ALL
346    SELECT 1
347      FROM user_synonyms
348     WHERE synonym_name = g_log_sequence_name
349  );
350  
351  IF l_check = 0 THEN
352    dbms_output.put_line('Try to create log sequence ' || g_log_sequence_name);
353  
354    l_sql := 'CREATE SEQUENCE md_process_log_seq START WITH 1 INCREMENT BY 1';
355  
356    EXECUTE IMMEDIATE l_sql;
357  ELSE
358    dbms_output.put_line('Local log sequence ' || g_log_sequence_name || ' or synonym already exists');
359  END IF;
360  
361  prc_log_cleanup_table;
362  
363  EXCEPTION
364  WHEN OTHERS THEN
365  prc_error_stack(p_log_id=>null);
366  
367    raise_application_error( -20001, 'Creation of local log table ' || g_log_table_name || chr(10) ||
368  				   ' or sequence ' || g_log_sequence_name || chr(10) ||
369  				   ' failed turn on serveroutput to get more info' );
370  
371  END prc_log_create_table;
372  
373  --Procedure prc_init_log
374  -- initializes log in physical file and in md_process_log table
375  
376  PROCEDURE prc_init_log
377  (
378  p_force IN VARCHAR2 DEFAULT 'N'
379  )
380  IS
381  l_check NUMBER;
382  BEGIN
383  dbms_output.put_line('prc_init_log');
384  
385  IF g_curr_schema_name IS NULL OR p_force = 'Y' THEN
386    g_curr_schema_name := sys_context('USERENV', 'CURRENT_SCHEMA');
387  
388    prc_log_create_table;
389  END IF;
390  
391  END prc_init_log;
392  
393  -- cleanup old partitions in table md_process_log
394  
395  PROCEDURE prc_log_cleanup_table
396  IS
397  l_proc_name VARCHAR2(128) := 'prc_log_cleanup_table';
398  l_long VARCHAR2(4000);
399  l_interval_date DATE;
400  l_partition_date DATE;
401  l_sql CLOB;
402  BEGIN
403  dbms_output.put_line
404  (
405  'Calling procedure ' || $$plsql_unit|| '.' || l_proc_name
406  );
407  
408  l_interval_date := (SYSDATE - ABS(g_log_retention_days));
409  
410  dbms_output.put_line
411  (
412    'Drop partitions for table ' || g_log_table_name || chr(10) ||
413    '  older than ' || g_log_retention_days || ' days' || chr(10) ||
414    '  older than ' || to_char( l_interval_date, g_date_formt_const )
415  );
416  
417  FOR i IN ( SELECT table_name, partition_name, high_value
418  	     FROM user_tab_partitions
419  	    WHERE table_name = g_log_table_name
420  	      AND partition_name != 'P_START'
421  	    ORDER BY partition_position )
422  LOOP
423    --convert partition high_value long to date;
424    l_long := i.high_value;
425  
426    EXECUTE IMMEDIATE 'SELECT ' || l_long || ' FROM dual' INTO l_partition_date;
427  
428    IF l_interval_date > l_partition_date THEN
429      l_sql := 'ALTER TABLE ' || i.table_name || ' DROP PARTITION ' || i.partition_name;
430  
431      dbms_output.put_line
432      (
433        'Partition ' || i.partition_name || ' high_value ' || to_char( l_partition_date, g_date_formt_const ) || chr(10) ||
434        ' older than ' || to_char( l_interval_date, g_date_formt_const ) || chr(10) ||
435        ' to drop: ' || l_sql
436      );
437  
438      EXECUTE IMMEDIATE l_sql;
439    END IF;
440  END LOOP;
441  
442  dbms_output.put_line
443  (
444    'Completed procedure ' || $$plsql_unit || '.' || l_proc_name
445  );
446  
447  EXCEPTION
448  WHEN OTHERS THEN
449  dbms_output.put_line('Error cleaning log table ' || SQLCODE || substr(SQLERRM, 1, 200));
450  END prc_log_cleanup_table;
451  BEGIN
452  
453  --calling base procedure to intialize entries in md_process_log table and file with directories
454  
455  prc_init_log;
456  END PKG_TL_LOGGING;
457  /

