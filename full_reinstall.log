 18    FUNCTION fn_normalize_execute
 19    (
 20      p_execute IN VARCHAR2
 21    )
 22    RETURN VARCHAR2
 23    IS
 24    BEGIN
 25      IF UPPER(NVL(TRIM(p_execute), 'N')) = 'Y' THEN
 26        RETURN 'Y';
 27      END IF;
 28  
 29      RETURN 'N';
 30    END fn_normalize_execute;
 31  
 32    FUNCTION fn_format_sql_for_log
 33    (
 34      p_sql IN CLOB
 35    )
 36    RETURN CLOB
 37    IS
 38      l_sql CLOB;
 39    BEGIN
 40      IF p_sql IS NULL THEN
 41        RETURN NULL;
 42      END IF;
 43  
 44      l_sql := REGEXP_REPLACE(p_sql, '[[:space:]]+', ' ');
 45      l_sql := TRIM(l_sql);
 46  
 47      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(SELECT[[:space:]])', CHR(10) || 'SELECT ', 1, 0, 'i');
 48      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(FROM[[:space:]])', CHR(10) || 'FROM ', 1, 0, 'i');
 49      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(WHERE[[:space:]])', CHR(10) || 'WHERE ', 1, 0, 'i');
 50      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(AND[[:space:]])', CHR(10) || '  AND ', 1, 0, 'i');
 51      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(OR[[:space:]])', CHR(10) || '  OR ', 1, 0, 'i');
 52      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(WHEN[[:space:]])', CHR(10) || 'WHEN ', 1, 0, 'i');
 53      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(VALUES[[:space:]])', CHR(10) || 'VALUES ', 1, 0, 'i');
 54      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(PARTITION[[:space:]])', CHR(10) || 'PARTITION ', 1, 0, 'i');
 55      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(SUBPARTITION[[:space:]])', CHR(10) || 'SUBPARTITION ', 1, 0, 'i');
 56      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(FOR[[:space:]]+EXCHANGE[[:space:]])', CHR(10) || 'FOR EXCHANGE ', 1, 0, 'i');
 57      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(WITH[[:space:]]+TABLE[[:space:]])', CHR(10) || 'WITH TABLE ', 1, 0, 'i');
 58      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(INCLUDING[[:space:]]+INDEXES)', CHR(10) || 'INCLUDING INDEXES', 1, 0, 'i');
 59      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(EXCLUDING[[:space:]]+INDEXES)', CHR(10) || 'EXCLUDING INDEXES', 1, 0, 'i');
 60      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(WITHOUT[[:space:]]+VALIDATION)', CHR(10) || 'WITHOUT VALIDATION', 1, 0, 'i');
 61      l_sql := REGEXP_REPLACE(l_sql, '[[:space:]]+(UPDATE[[:space:]]+GLOBAL[[:space:]]+INDEXES)', CHR(10) || 'UPDATE GLOBAL INDEXES', 1, 0, 'i');
 62  
 63      RETURN l_sql;
 64    END fn_format_sql_for_log;
