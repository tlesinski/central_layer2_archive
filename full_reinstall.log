165    FUNCTION fn_run_sql_in_bind
166    (
167      p_log_id     IN NUMBER,
168      p_sql        IN CLOB,
169      p_array_bind IN SYS.ODCIVARCHAR2LIST,
170      p_execute    IN VARCHAR2 DEFAULT 'Y'
171    )
172    RETURN NUMBER
173    IS
174      l_cursor_id INTEGER;
175      l_rows      INTEGER;
176      l_attempt   NUMBER := 0;
177    BEGIN
178      IF p_sql IS NULL THEN
179        raise_application_error(-20001, 'SQL text is required');
180      END IF;
181  
182      prc_log_sql(p_log_id => p_log_id, p_sql => p_sql, p_execute => p_execute);
183  
184      IF p_log_id IS NOT NULL AND p_array_bind IS NOT NULL THEN
185        PKG_TL_LOGGING.prc_log
186        (
187          p_log_id    => p_log_id,
188          p_log_msg   => 'Bind count: ' || p_array_bind.COUNT,
189          p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
190          p_log_type  => 'SQL_BIND'
191        );
192  
193        FOR i IN 1 .. p_array_bind.COUNT LOOP
194          PKG_TL_LOGGING.prc_log
195          (
196            p_log_id    => p_log_id,
197            p_log_msg   => 'Bind ' || i || ': ' || NVL(p_array_bind(i), '<NULL>'),
198            p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
199            p_log_type  => 'SQL_BIND'
200          );
201        END LOOP;
202      END IF;
203  
204      IF fn_normalize_execute(p_execute) = 'N' THEN
205        RETURN 0;
206      END IF;
207  
208      LOOP
209        l_attempt := l_attempt + 1;
210  
211        BEGIN
212          l_cursor_id := DBMS_SQL.OPEN_CURSOR;
213          DBMS_SQL.PARSE(l_cursor_id, p_sql, DBMS_SQL.NATIVE);
214  
215          IF p_array_bind IS NOT NULL THEN
216            FOR i IN 1 .. p_array_bind.COUNT LOOP
217              DBMS_SQL.BIND_VARIABLE(l_cursor_id, ':' || i, p_array_bind(i));
218            END LOOP;
219          END IF;
220  
221          l_rows := DBMS_SQL.EXECUTE(l_cursor_id);
222          DBMS_SQL.CLOSE_CURSOR(l_cursor_id);
223  
224          RETURN l_rows;
225        EXCEPTION
226          WHEN OTHERS THEN
227            IF DBMS_SQL.IS_OPEN(l_cursor_id) THEN
228              DBMS_SQL.CLOSE_CURSOR(l_cursor_id);
229            END IF;
230  
231            IF SQLCODE IN (-4061, -4062, -4068) AND l_attempt = 1 THEN
232              IF p_log_id IS NOT NULL THEN
233                PKG_TL_LOGGING.prc_log
234                (
235                  p_log_id    => p_log_id,
236                  p_log_msg   => 'Retrying SQL after remote package state changed: ' || SQLERRM,
237                  p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
238                  p_log_type  => 'SQL_RETRY'
239                );
240              END IF;
241            ELSE
242              RAISE;
243            END IF;
244        END;
245      END LOOP;
246    END fn_run_sql_in_bind;
247  
248    FUNCTION fn_run_into_sql_in_bind
249    (
250      p_log_id     IN NUMBER,
251      p_sql        IN CLOB,
252      p_array_bind IN SYS.ODCIVARCHAR2LIST,
253      p_execute    IN VARCHAR2 DEFAULT 'Y'
254    )
255    RETURN NUMBER
256    IS
257      l_cursor_id INTEGER;
258      l_rows      INTEGER;
259      l_result    NUMBER;
260      l_attempt   NUMBER := 0;
261    BEGIN
262      IF p_sql IS NULL THEN
263        raise_application_error(-20001, 'SQL text is required');
264      END IF;
265  
266      prc_log_sql(p_log_id => p_log_id, p_sql => p_sql, p_execute => p_execute);
267  
268      IF p_log_id IS NOT NULL AND p_array_bind IS NOT NULL THEN
269        PKG_TL_LOGGING.prc_log
270        (
271          p_log_id    => p_log_id,
272          p_log_msg   => 'Bind count: ' || p_array_bind.COUNT,
273          p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
274          p_log_type  => 'SQL_BIND'
275        );
276  
277        FOR i IN 1 .. p_array_bind.COUNT LOOP
278          PKG_TL_LOGGING.prc_log
279          (
280            p_log_id    => p_log_id,
281            p_log_msg   => 'Bind ' || i || ': ' || NVL(p_array_bind(i), '<NULL>'),
282            p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
283            p_log_type  => 'SQL_BIND'
284          );
285        END LOOP;
286      END IF;
287  
288      IF fn_normalize_execute(p_execute) = 'N' THEN
289        RETURN NULL;
290      END IF;
291  
292      LOOP
293        l_attempt := l_attempt + 1;
294  
295        BEGIN
296          l_cursor_id := DBMS_SQL.OPEN_CURSOR;
297          DBMS_SQL.PARSE(l_cursor_id, p_sql, DBMS_SQL.NATIVE);
298  
299          IF p_array_bind IS NOT NULL THEN
300            FOR i IN 1 .. p_array_bind.COUNT LOOP
301              DBMS_SQL.BIND_VARIABLE(l_cursor_id, ':' || i, p_array_bind(i));
302            END LOOP;
303          END IF;
304  
305          DBMS_SQL.DEFINE_COLUMN(l_cursor_id, 1, l_result);
306          l_rows := DBMS_SQL.EXECUTE(l_cursor_id);
307  
308          IF DBMS_SQL.FETCH_ROWS(l_cursor_id) > 0 THEN
309            DBMS_SQL.COLUMN_VALUE(l_cursor_id, 1, l_result);
310          END IF;
311  
312          DBMS_SQL.CLOSE_CURSOR(l_cursor_id);
313  
314          RETURN l_result;
315        EXCEPTION
316          WHEN OTHERS THEN
317            IF DBMS_SQL.IS_OPEN(l_cursor_id) THEN
318              DBMS_SQL.CLOSE_CURSOR(l_cursor_id);
319            END IF;
320  
321            IF SQLCODE IN (-4061, -4062, -4068) AND l_attempt = 1 THEN
322              IF p_log_id IS NOT NULL THEN
323                PKG_TL_LOGGING.prc_log
324                (
325                  p_log_id    => p_log_id,
326                  p_log_msg   => 'Retrying SQL after remote package state changed: ' || SQLERRM,
327                  p_log_sttus => PKG_TL_LOGGING.g_sttus_running_const,
328                  p_log_type  => 'SQL_RETRY'
329                );
330              END IF;
331            ELSE
332              RAISE;
333            END IF;
334        END;
335      END LOOP;
336    END fn_run_into_sql_in_bind;
