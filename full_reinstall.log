159              fn_sanitize_summary_cell(p_table_name) || '|' ||
160              fn_sanitize_summary_cell(p_partition_name) || '|' ||
161              fn_sanitize_summary_cell(p_subpartition_name) || '|' ||
162              fn_sanitize_summary_cell(p_partition_high_value) || '|' ||
163              fn_sanitize_summary_cell(p_subpartition_high_value) || '|' ||
164              fn_sanitize_summary_cell(p_archive_status) || '|' ||
165              fn_sanitize_summary_cell(p_quality_status) || '|' ||
166              fn_sanitize_summary_cell(p_truncate_status) || '|' ||
167              fn_sanitize_summary_cell(TO_CHAR(p_source_row_count)) || '|' ||
168              fn_sanitize_summary_cell(TO_CHAR(p_target_row_count)) || CHR(10);
169     END fn_summary_row;
