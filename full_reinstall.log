  6         s.subpartition_name,
  7         EXTRACTVALUE
  8         (
  9           DBMS_XMLGEN.GETXMLTYPE
 10           (
 11             'select high_value from all_tab_partitions where table_owner = ''' ||
 12             REPLACE(p.table_owner, '''', '''''') ||
 13             ''' and table_name = ''' ||
 14             REPLACE(p.table_name, '''', '''''') ||
 15             ''' and partition_name = ''' ||
 16             REPLACE(p.partition_name, '''', '''''') || ''''
 17           ),
 18           '/ROWSET/ROW/HIGH_VALUE'
 19         ) AS partition_high_value,
 20         CASE
 21           WHEN s.subpartition_name IS NULL THEN NULL
 22           ELSE EXTRACTVALUE
 23                (
 24                  DBMS_XMLGEN.GETXMLTYPE
 25                  (
 26                    'select high_value from all_tab_subpartitions where table_owner = ''' ||
 27                    REPLACE(s.table_owner, '''', '''''') ||
 28                    ''' and table_name = ''' ||
 29                    REPLACE(s.table_name, '''', '''''') ||
 30                    ''' and partition_name = ''' ||
 31                    REPLACE(s.partition_name, '''', '''''') ||
 32                    ''' and subpartition_name = ''' ||
 33                    REPLACE(s.subpartition_name, '''', '''''') || ''''
 34                  ),
 35                  '/ROWSET/ROW/HIGH_VALUE'
 36                )
 37         END AS subpartition_high_value,
 38         p.partition_position,
 39         s.subpartition_position
 40    FROM all_tab_partitions p
 41    LEFT JOIN all_tab_subpartitions s
 42      ON p.table_owner = s.table_owner
 43     AND p.table_name = s.table_name
 44     AND p.partition_name = s.partition_name;

