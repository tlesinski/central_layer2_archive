SQL> @layer2_core/views/tw_archive_source_partitions_vw.sql
SQL> CREATE OR REPLACE VIEW TW_ARCHIVE_SOURCE_PARTITIONS_VW
  2  AS
  3  WITH cfg AS (
  4    SELECT source_db_link,
  5           source_agent_schema,
  6           source_owner,
  7           source_table_name,
  8           target_owner,
  9           target_table_name
 10      FROM tw_archive_tables
 11     WHERE enabled_flag = 'Y'
 12  ),
 13  src AS (
 14    SELECT c.source_db_link,
 15           c.source_agent_schema,
 16           c.source_owner,
 17           c.source_table_name,
 18           c.target_owner,
 19           c.target_table_name,
 20           CASE
 21             WHEN x.subpartition_name IS NULL THEN 'PARTITION'
 22             ELSE 'SUBPARTITION'
 23           END AS archive_unit_type,
 24           x.partition_name AS source_partition_name,
 25           NVL(x.subpartition_name, '#') AS source_subpartition_name,
 26           x.partition_name AS partition_name,
 27           NVL(x.subpartition_name, '#') AS subpartition_name,
 28           x.partition_high_value,
 29           NVL(x.subpartition_high_value, '#') AS subpartition_high_value,
 30           x.partition_position,
 31           NVL(x.subpartition_position, 0) AS subpartition_position
 32      FROM cfg c,
 33           XMLTABLE(
 34             '/ROWSET/ROW'
 35             PASSING DBMS_XMLGEN.GETXMLTYPE(
 36               'SELECT * FROM ' ||
 37               DBMS_ASSERT.SIMPLE_SQL_NAME(c.source_agent_schema) ||
 38               '.ARCHIVE_PARTITION_INFO_VW' ||
 39               CASE
 40                 WHEN c.source_db_link IS NOT NULL
 41                      AND UPPER(TRIM(c.source_db_link)) NOT IN ('LOCAL', 'NONE')
 42                   THEN '@' || DBMS_ASSERT.SIMPLE_SQL_NAME(c.source_db_link)
 43               END ||
 44               ' WHERE schema_name = ''' || REPLACE(UPPER(c.source_owner), '''', '''''') || '''' ||
 45               ' AND table_name = ''' || REPLACE(UPPER(c.source_table_name), '''', '''''') || ''''
 46             )
 47             COLUMNS
 48               schema_name              VARCHAR2(128)  PATH 'SCHEMA_NAME',
 49               table_name               VARCHAR2(128)  PATH 'TABLE_NAME',
 50               partition_name           VARCHAR2(128)  PATH 'PARTITION_NAME',
 51               subpartition_name        VARCHAR2(128)  PATH 'SUBPARTITION_NAME',
 52               partition_high_value     VARCHAR2(4000) PATH 'PARTITION_HIGH_VALUE',
 53               subpartition_high_value  VARCHAR2(4000) PATH 'SUBPARTITION_HIGH_VALUE',
 54               partition_position       NUMBER         PATH 'PARTITION_POSITION',
 55               subpartition_position    NUMBER         PATH 'SUBPARTITION_POSITION'
 56           ) x
 57     WHERE UPPER(TRIM(x.partition_high_value)) <> 'MAXVALUE'
 58  )
 59  SELECT source_db_link,
 60         source_agent_schema,
 61         source_owner,
 62         source_table_name,
 63         target_owner,
 64         target_table_name,
 65         archive_unit_type,
 66         source_partition_name,
 67         source_subpartition_name,
 68         partition_name,
 69         subpartition_name,
 70         partition_high_value,
 71         subpartition_high_value,
 72         partition_position,
 73         subpartition_position
 74    FROM src;

