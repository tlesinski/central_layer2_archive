SQL> DECLARE
  2    l_count NUMBER;
  3  
  4    PROCEDURE assert_count
  5    (
  6  	 p_label    IN VARCHAR2,
  7  	 p_actual   IN NUMBER,
  8  	 p_expected IN NUMBER
  9    ) IS
 10    BEGIN
 11  	 DBMS_OUTPUT.PUT_LINE(RPAD(p_label, 30) || ' actual=' || p_actual ||
 12  			      ' expected=' || p_expected);
 13  	 IF p_actual != p_expected THEN
 14  	   RAISE_APPLICATION_ERROR
 15  	   (
 16  	     -20090,
 17  	     p_label || ' expected ' || p_expected || ' rows, got ' || p_actual
 18  	   );
 19  	 END IF;
 20    END;
 21  BEGIN
 22    SELECT COUNT(*) INTO l_count FROM ORDERS_ARCH_SRC;
 23    assert_count('ORDERS_ARCH_SRC', l_count, 430);
 24  
 25    SELECT COUNT(*) INTO l_count FROM ORDERS_ARCH_SRC_2;
 26    assert_count('ORDERS_ARCH_SRC_2', l_count, 250);
 27  
 28    SELECT COUNT(*) INTO l_count FROM ORDERS_SUBPART_SRC;
 29    assert_count('ORDERS_SUBPART_SRC', l_count, 540);
 30  
 31    SELECT COUNT(*) INTO l_count FROM ORDERS_SUBPART_SRC_2;
 32    assert_count('ORDERS_SUBPART_SRC_2', l_count, 360);
 33  
 34    SELECT COUNT(*) INTO l_count FROM ORDERS_DAILY_INT_SRC;
 35    assert_count('ORDERS_DAILY_INT_SRC', l_count, 96);
 36  
 37    SELECT COUNT(*) INTO l_count FROM ORDERS_DAILY_INT_SRC_2;
 38    assert_count('ORDERS_DAILY_INT_SRC_2', l_count, 96);
 39  END;
 40  /
