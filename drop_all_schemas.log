SQL> BEGIN
  2    FOR r IN (
  3  	 SELECT owner, table_name, grantee, privilege
  4  	   FROM dba_tab_privs
  5  	  WHERE owner = 'CLIENT1'
  6  	    AND table_name IN ('ORDERS_ARCH_SRC', 'ORDERS_SUBPART_SRC', 'ORDERS_DAILY_INT_SRC')
  7  	    AND grantee IN ('CAGENT1', 'CARCH')
