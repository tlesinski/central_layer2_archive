SQL> BEGIN
  2    -- packages (body first)
  3    FOR r IN (
  4  	 SELECT object_name, object_type
  5  	   FROM dba_objects
  6  	  WHERE owner = 'CREPL'
  7  	    AND object_type IN ('PACKAGE', 'PACKAGE BODY')
  8  	    AND object_name IN (
  9  	       'PKG_REPLICA_RUNNER',
 10  	       'PKG_REPLICA_PURGE',
 11  	       'PKG_REPLICA_QUALITY',
 12  	       'PKG_REPLICA_REPLICATE',
 13  	       'PKG_REPLICA_PARTITION',
 14  	       'PKG_REPLICA_DISCOVERY',
 15  	       'PKG_REPLICA_LOG',
 16  	       'PKG_SQL',
 17  	       'PKG_TL_LOGGING'
 18  	    )
 19  	  ORDER BY object_type DESC
 20    ) LOOP
 21  	 BEGIN
 22  	   EXECUTE IMMEDIATE 'DROP ' || r.object_type || ' CREPL.' || r.object_name;
 23  	   DBMS_OUTPUT.PUT_LINE('Dropped ' || r.object_type || ' CREPL.' || r.object_name);
 24  	 EXCEPTION
 25  	   WHEN OTHERS THEN
 26  	     DBMS_OUTPUT.PUT_LINE('Could not drop ' || r.object_type || ' ' ||
 27  				  r.object_name || ': ' || SQLERRM);
 28  	 END;
 29    END LOOP;
 30  
 31    -- views
 32    FOR r IN (
 33  	 SELECT view_name
 34  	   FROM dba_views
 35  	  WHERE owner = 'CREPL'
 36  	    AND view_name LIKE 'TW\_REPLICA\_%' ESCAPE '\'
 37    ) LOOP
 38  	 BEGIN
 39  	   EXECUTE IMMEDIATE 'DROP VIEW CREPL.' || r.view_name;
 40  	   DBMS_OUTPUT.PUT_LINE('Dropped VIEW CREPL.' || r.view_name);
 41  	 EXCEPTION
 42  	   WHEN OTHERS THEN
 43  	     DBMS_OUTPUT.PUT_LINE('Could not drop VIEW ' ||
 44  				  r.view_name || ': ' || SQLERRM);
 45  	 END;
 46    END LOOP;
 47  
 48    -- synonyms to layer 2
 49    FOR r IN (
 50  	 SELECT synonym_name
 51  	   FROM dba_synonyms
 52  	  WHERE owner = 'CREPL'
 53  	    AND synonym_name IN (
 54  	      'TW_ARCHIVE_TABLES',
 55  	      'TW_ARCHIVE_PARTITIONS',
 56  	      'ORDERS_ARCH_SRC_L2',
 57  	      'ORDERS_SUBPART_SRC_L2'
 58  	    )
 59    ) LOOP
 60  	 BEGIN
 61  	   EXECUTE IMMEDIATE 'DROP SYNONYM CREPL.' || r.synonym_name;
 62  	   DBMS_OUTPUT.PUT_LINE('Dropped SYNONYM CREPL.' || r.synonym_name);
 63  	 EXCEPTION
 64  	   WHEN OTHERS THEN
 65  	     DBMS_OUTPUT.PUT_LINE('Could not drop SYNONYM ' ||
 66  				  r.synonym_name || ': ' || SQLERRM);
 67  	 END;
 68    END LOOP;
 69  
 70    -- tables
 71    FOR r IN (
 72  	 SELECT table_name
 73  	   FROM dba_tables
 74  	  WHERE owner = 'CREPL'
 75  	    AND table_name IN (
 76  	      'TW_REPLICA_PARTITIONS',
 77  	      'TW_REPLICA_RUNS',
 78  	      'TW_REPLICA_TABLES',
 79  	      'MD_PROCESS_LOG',
 80  	      'ORDERS_ARCH_SRC',
 81  	      'ORDERS_SUBPART_SRC'
 82  	    )
 83  	  ORDER BY CASE table_name
 84  		     WHEN 'TW_REPLICA_PARTITIONS' THEN 1
 85  		     WHEN 'TW_REPLICA_RUNS' THEN 2
 86  		     WHEN 'TW_REPLICA_TABLES' THEN 3
 87  		     WHEN 'MD_PROCESS_LOG' THEN 4
 88  		     ELSE 5
 89  		   END
 90    ) LOOP
 91  	 BEGIN
 92  	   EXECUTE IMMEDIATE 'DROP TABLE CREPL.' || r.table_name || ' PURGE';
 93  	   DBMS_OUTPUT.PUT_LINE('Dropped TABLE CREPL.' || r.table_name);
 94  	 EXCEPTION
 95  	   WHEN OTHERS THEN
 96  	     DBMS_OUTPUT.PUT_LINE('Could not drop TABLE ' ||
 97  				  r.table_name || ': ' || SQLERRM);
 98  	 END;
 99    END LOOP;
100  
101    -- function
102    FOR r IN (
103  	 SELECT object_name
104  	   FROM dba_objects
105  	  WHERE owner = 'CREPL'
106  	    AND object_type = 'FUNCTION'
107  	    AND object_name = 'FN_ARCHIVE_HIGH_VALUE_DATE'
108    ) LOOP
109  	 BEGIN
110  	   EXECUTE IMMEDIATE 'DROP FUNCTION CREPL.' || r.object_name;
111  	   DBMS_OUTPUT.PUT_LINE('Dropped FUNCTION CREPL.' || r.object_name);
112  	 EXCEPTION
113  	   WHEN OTHERS THEN
114  	     DBMS_OUTPUT.PUT_LINE('Could not drop FUNCTION ' ||
115  				  r.object_name || ': ' || SQLERRM);
116  	 END;
117    END LOOP;
118  
119    -- drop orphan replica staging tables
120    FOR r IN (
121  	 SELECT table_name
122  	   FROM dba_tables
123  	  WHERE owner = 'CREPL'
124  	    AND table_name LIKE 'STG\_TMP\_REPLICA\_%' ESCAPE '\'
125    ) LOOP
126  	 BEGIN
127  	   EXECUTE IMMEDIATE 'DROP TABLE CREPL.' || r.table_name || ' PURGE';
128  	   DBMS_OUTPUT.PUT_LINE('Dropped staging TABLE CREPL.' || r.table_name);
129  	 EXCEPTION
130  	   WHEN OTHERS THEN
131  	     DBMS_OUTPUT.PUT_LINE('Could not drop staging TABLE ' ||
132  				  r.table_name || ': ' || SQLERRM);
133  	 END;
134    END LOOP;
135  
136    -- sequence
137    FOR r IN (
138  	 SELECT sequence_name
139  	   FROM dba_sequences
140  	  WHERE sequence_owner = 'CREPL'
141  	     AND sequence_name IN ('MD_PROCESS_LOG_SEQ', 'STG_TMP_REPLICA_SEQ')
142    ) LOOP
143  	 BEGIN
144  	   EXECUTE IMMEDIATE 'DROP SEQUENCE CREPL.' || r.sequence_name;
145  	   DBMS_OUTPUT.PUT_LINE('Dropped SEQUENCE CREPL.' || r.sequence_name);
146  	 EXCEPTION
147  	   WHEN OTHERS THEN
148  	     DBMS_OUTPUT.PUT_LINE('Could not drop SEQUENCE ' ||
149  				  r.sequence_name || ': ' || SQLERRM);
150  	 END;
151    END LOOP;
152  END;
153  /

