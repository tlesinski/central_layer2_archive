 16           'PKG_SQL',
 17           'PKG_TL_LOGGING',
 18           'PKG_DATE',
 19           'DAT'
 20         )
 21       ORDER BY object_type DESC
 22    ) LOOP
 23      BEGIN
 24        EXECUTE IMMEDIATE 'DROP ' || r.object_type || ' CARCH.' || r.object_name;
 25        DBMS_OUTPUT.PUT_LINE('Dropped ' || r.object_type || ' CARCH.' || r.object_name);
 26      EXCEPTION
